        {
          "alias": false,
          "_styles": {
            "position": "relative",
            "background-color": "@cornerColor",
            ".module-inner": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)",
              "position": "relative",
              "border-radius": "0 0 30px 30px",
              "overflow": "hidden",
              "& when (@bg-type = \"color\")": {
                "background-color": "@bg-value"
              },
              "& when (@bg-type = \"image\")": {
                "background-image": "url(@bg-value)",
                "background-size": "cover",
                "background-position": "center center"
              }
            },
            ".mbr-overlay": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "pointer-events": "none"
            },
            ".row": {
              "gap": "2rem"
            },
            ".carousel-col": {
              "padding": "0"
            },
            ".artist-info-col": {
              "display": "flex",
              "align-items": "center"
            },
            ".artist-info-wrapper": {
              "padding": "2rem",
              "width": "100%"
            },
            ".artist-name": {
              "margin-bottom": "1.5rem",
              "background": "linear-gradient(90deg, #ff6eb4, #c471ed, #8b5cf6)",
              "-webkit-background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "background-clip": "text",
              "color": "#41807f"
            },
            ".artist-description": {
              "margin-bottom": "2rem",
              "opacity": "0.9",
              "line-height": "1.7",
              "color": "#ff9b00"
            },
