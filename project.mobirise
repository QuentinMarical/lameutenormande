                "height": "100vh !important",
                "max-height": "100vh !important",
                "margin": "0 !important",
                "border-radius": "0 !important",
                "box-shadow": "none !important",
                "animation": "legalSheetUp 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
