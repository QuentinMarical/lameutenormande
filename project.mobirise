            ".pricing-fullscreen-overlay": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "background": "rgba(0, 0, 0, 0.95)",
              "cursor": "pointer"
            },
            ".pricing-fullscreen img": {
              "position": "relative",
              "max-width": "95vw",
              "max-height": "95vh",
              "object-fit": "contain",
              "border-radius": "8px",
              "box-shadow": "0 10px 50px rgba(0, 0, 0, 0.5)"
            },
            ".pricing-fullscreen-close": {
              "position": "absolute",
