              "opacity": "0.7",
              "margin-bottom": "0.5rem",
              "text-transform": "uppercase",
              "font-weight": "600",
              "letter-spacing": "0.05em"
            },
            ".artist-info-text": {
              "font-size": "1rem",
              "line-height": "1.6",
              "font-weight": "500",
              "word-break": "break-word",
              "color": "rgba(255, 255, 255, 0.9)"
            },
            ".commission-status": {
              "display": "inline-block",
              "padding": "0.5rem 1rem",
              "border-radius": "20px",
              "font-weight": "600",
              "font-size": "0.95rem"
            },
            ".commission-status.open": {
              "background": "linear-gradient(135deg, rgba(76, 175, 80, 0.3), rgba(76, 175, 80, 0.1))",
              "border": "1px solid rgba(76, 175, 80, 0.5)",
              "color": "#81c784"
            },
            ".commission-status.closed": {
              "background": "linear-gradient(135deg, rgba(244, 67, 54, 0.3), rgba(244, 67, 54, 0.1))",
              "border": "1px solid rgba(244, 67, 54, 0.5)",
              "color": "#ef9a9a"
            },
            ".commission-types": {
              "display": "flex",
              "flex-wrap": "wrap",
              "gap": "0.5rem",
              "margin-top": "0.5rem"
            },
            ".commission-tag": {
              "display": "inline-block",
              "padding": "0.4rem 0.8rem",
              "background": "linear-gradient(135deg, rgba(255, 110, 180, 0.2), rgba(139, 92, 246, 0.2))",
              "border": "1px solid rgba(255, 110, 180, 0.4)",
              "border-radius": "15px",
              "font-size": "0.85rem",
              "font-weight": "500",
              "color": "#fff",
              "transition": "all 0.3s"
            },
            ".commission-tag:hover": {
              "background": "linear-gradient(135deg, rgba(255, 110, 180, 0.4), rgba(139, 92, 246, 0.4))",
              "transform": "scale(1.05)"
            },
            ".artist-social-links": {
              "display": "flex",
              "flex-wrap": "wrap",
              "gap": "0.6rem",
              "margin-top": "0.5rem"
            },
            ".social-btn": {
