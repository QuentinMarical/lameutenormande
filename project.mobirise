              "display": "inline-flex",
              "align-items": "center",
              "gap": "0.75rem",
              "padding": "1rem 2rem",
              "background-color": "#ff6eb4",
              "border": "none",
              "border-radius": "30px",
              "color": "#fff",
              "font-size": "1.1rem",
              "font-weight": "600",
              "cursor": "pointer",
              "transition": "all 0.3s ease",
              "box-shadow": "0 4px 20px rgba(0, 0, 0, 0.3)"
            },
            ".btn-artist-details:hover": {
              "transform": "translateY(-3px)",
