              "justify-content": "center",
              "width": "38px",
              "height": "38px",
              "border-radius": "50%",
              "position": "relative",
              "transition": "transform @durMed @easeOut",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "inset": "0",
                "border-radius": "50%",
                "background": "currentColor",
                "opacity": "0",
                "transform": "scale(0.6)",
                "transition": "opacity @durMed @easeOut, transform @durMed @easeOut"
              },
              "&:hover": {
                "transform": "rotate(8deg) scale(1.15)",
                "&::before": {
                  "opacity": "0.08",
                  "transform": "scale(1)"
                }
              },
              "&:active": {
                "transform": "rotate(0deg) scale(0.95)"
              },
              ".mbr-iconfont": {
                "position": "relative",
                "z-index": "1"
              }
            },
            ".navbar-buttons": {
              "text-align": "center",
              "min-width": "140px",
              ".btn": {
                "border-radius": "100vw",
                "padding": "10px 28px",
                "font-weight": "600",
                "letter-spacing": "0.03em",
                "position": "relative",
                "overflow": "hidden",
                "box-shadow": "0 2px 12px -2px rgba(0, 0, 0, 0.12)",
                "transition": "transform @durMed @easeOut, box-shadow @durMed @easeOut",
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "inset": "0",
                  "background": "linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, transparent 50%)",
                  "opacity": "0",
                  "transition": "opacity @durMed ease"
                },
                "&:hover": {
                  "transform": "translateY(-3px)",
                  "box-shadow": "0 8px 28px -4px rgba(0, 0, 0, 0.2)",
                  "&::before": {
                    "opacity": "1"
                  }
                },
                "&:active": {
                  "transform": "translateY(-1px) scale(0.98)",
                  "box-shadow": "0 4px 16px -2px rgba(0, 0, 0, 0.15)"
                }
              },
