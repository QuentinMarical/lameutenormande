            "<script>\n        'use strict';\n\n        // Fix z-index navbar + modal fullscreen mobile : injection globale dans <head>\n        // ⚠️ EXCLUT les modules artistes (.module-artiste) et leurs modales (.artist-modal)\n        // EXCLUT les modales gallery bloc (.artistgallery1) et leurs modales (.ag-modal)\n        // EXCLUT les fullscreen overlays (.carousel-fullscreen, .pricing-fullscreen)\n        (function() {\n            var s = document.createElement('style');\n            s.textContent = ''\n                + 'body.modal-open{overflow:hidden}'\n                + 'body.modal-open>*:not(.module-artiste):not(.artistgallery1):not(.carousel-fullscreen):not(.pricing-fullscreen){z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste{z-index:0!important;position:relative}'\n                + 'body.modal-open>.artistgallery1{z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste:has(.artist-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>.artistgallery1:has(.ag-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.event-modal){z-index:2147483647!important}'\n                + 'body.modal-open>.event-modal{z-index:2147483647!important}'\n                + 'body.modal-open>:has(.legal-modal){z-index:2147483647!important}'\n                + '.carousel-fullscreen,.pricing-fullscreen{position:fixed!important;z-index:2147483648!important}'\n                + '@media(max-width:767px){'\n                    + '.event-modal{padding:0!important;align-items:stretch!important}'\n                    + '.event-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.event-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:eventSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.event-modal.closing .event-modal-content{animation:eventSheetDown .25s ease forwards}'\n                    + '.event-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1e2e 0%,#181828 60%,#141422 100%)}'\n                    + '.event-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.event-modal-title{font-size:1.3rem!important}'\n                + '}'\n                + '@keyframes eventSheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}'\n                + '@keyframes eventSheetDown{from{transform:translateY(0)}to{transform:translateY(100%)}}';\n            document.head.appendChild(s);\n        })();\n\n        (function () {\n            const monthNames = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];\n\n            const container = document.querySelector('.container-calendar');\n            const getAttr = (name) => {\n                if (!container) return true;\n                const val = container.getAttribute(name);\n                return val !== 'false';\n            };\n\n            const allowListView = getAttr('data-allow-list-view');\n            const allowCalendarView = getAttr('data-allow-calendar-view');\n            const defaultListViewMobile = getAttr('data-default-list-view-mobile');\n\n            let calendar = null;\n            let currentDate = new Date();\n            let updateTimeout = null;\n            let currentView = (!allowCalendarView && allowListView) ? 'listMonth' : 'dayGridMonth';\n            let loadedEvents = [];\n            let allLoadedEvents = [];\n            const isMobile = () => window.innerWidth <= 768;\n            const isPortrait = () => window.matchMedia('(orientation: portrait)').matches;\n\n            const NORMANDIFURS_LOGO = 'data:image/svg+xml;base64,';\n\n            const REGIONS_DEPARTMENTS = {\n                'Auvergne-Rhône-Alpes': ['01 Ain','03 Allier','07 Ardèche','15 Cantal','26 Drôme','38 Isère','42 Loire','43 Haute-Loire','63 Puy-de-Dôme','69 Rhône','73 Savoie','74 Haute-Savoie'],\n                'Bourgogne-Franche-Comté': ['21 Côte-d\\'Or','25 Doubs','39 Jura','58 Nièvre','70 Haute-Saône','71 Saône-et-Loire','89 Yonne','90 Territoire de Belfort'],\n                'Bretagne': ['22 Côtes-d\\'Armor','29 Finistère','35 Ille-et-Vilaine','56 Morbihan'],\n                'Centre-Val de Loire': ['18 Cher','28 Eure-et-Loir','36 Indre','37 Indre-et-Loire','41 Loir-et-Cher','45 Loiret'],\n                'Corse': ['2A Corse-du-Sud','2B Haute-Corse'],\n                'Grand Est': ['08 Ardennes','10 Aube','51 Marne','52 Haute-Marne','54 Meurthe-et-Moselle','55 Meuse','57 Moselle','67 Bas-Rhin','68 Haut-Rhin','88 Vosges'],\n                'Hauts-de-France': ['02 Aisne','59 Nord','60 Oise','62 Pas-de-Calais','80 Somme'],\n                'Île-de-France': ['75 Paris','77 Seine-et-Marne','78 Yvelines','91 Essonne','92 Hauts-de-Seine','93 Seine-Saint-Denis','94 Val-de-Marne','95 Val-d\\'Oise'],\n                'Normandie': ['14 Calvados','27 Eure','50 Manche','61 Orne','76 Seine-Maritime'],\n                'Nouvelle-Aquitaine': ['16 Charente','17 Charente-Maritime','19 Corrèze','23 Creuse','24 Dordogne','33 Gironde','40 Landes','47 Lot-et-Garonne','64 Pyrénées-Atlantiques','79 Deux-Sèvres','86 Vienne','87 Haute-Vienne'],\n                'Occitanie': ['09 Ariège','11 Aude','12 Aveyron','30 Gard','31 Haute-Garonne','32 Gers','34 Hérault','46 Lot','48 Lozère','65 Hautes-Pyrénées','66 Pyrénées-Orientales','81 Tarn','82 Tarn-et-Garonne'],\n                'Pays de la Loire': ['44 Loire-Atlantique','49 Maine-et-Loire','53 Mayenne','72 Sarthe','85 Vendée'],\n                'Provence-Alpes-Côte d\\'Azur': ['04 Alpes-de-Haute-Provence','05 Hautes-Alpes','06 Alpes-Maritimes','13 Bouches-du-Rhône','83 Var','84 Vaucluse']\n            };\n\n            function getDeptCode(deptStr) {\n                return deptStr.split(' ')[0];\n            }\n\n            function getDeptName(deptStr) {\n                return deptStr.substring(deptStr.indexOf(' ') + 1);\n            }\n\n            // Old regions (before 2016 reform) mapped to their department codes\n            const OLD_REGIONS = {\n                'Auvergne-Rhône-Alpes': {\n                    'Auvergne': ['03','15','43','63'],\n                    'Rhône-Alpes': ['01','07','26','38','42','69','73','74']\n                },\n                'Bourgogne-Franche-Comté': {\n                    'Bourgogne': ['21','58','71','89'],\n                    'Franche-Comté': ['25','39','70','90']\n                },\n                'Grand Est': {\n                    'Alsace': ['67','68'],\n                    'Champagne-Ardenne': ['08','10','51','52'],\n                    'Lorraine': ['54','55','57','88']\n                },\n                'Hauts-de-France': {\n                    'Nord-Pas-de-Calais': ['59','62'],\n                    'Picardie': ['02','60','80']\n                },\n                'Normandie': {\n                    'Basse-Normandie': ['14','50','61'],\n                    'Haute-Normandie': ['27','76']\n                },\n                'Nouvelle-Aquitaine': {\n                    'Aquitaine': ['24','33','40','47','64'],\n                    'Limousin': ['19','23','87'],\n                    'Poitou-Charentes': ['16','17','79','86']\n                },\n                'Occitanie': {\n                    'Languedoc-Roussillon': ['11','30','34','48','66'],\n                    'Midi-Pyrénées': ['09','12','31','32','46','65','81','82']\n                }\n            };\n\n            // Build reverse lookup: dept code -> region name\n            const DEPT_CODE_TO_REGION = {};\n            Object.entries(REGIONS_DEPARTMENTS).forEach(([region, depts]) => {\n                depts.forEach(d => {\n                    const code = getDeptCode(d);\n                    DEPT_CODE_TO_REGION[code] = region;\n                });\n            });\n\n            // Build reverse lookup: dept code -> old region name\n            const DEPT_CODE_TO_OLD_REGION = {};\n            Object.entries(OLD_REGIONS).forEach(([newRegion, oldRegions]) => {\n                Object.entries(oldRegions).forEach(([oldName, codes]) => {\n                    codes.forEach(code => {\n                        DEPT_CODE_TO_OLD_REGION[code] = oldName;\n                    });\n                });\n            });\n\n            function extractDeptCodeFromLocation(location) {\n                if (!location) return null;\n                // Match a 5-digit French postal code\n                const match = location.match(/\\b(\\d{5})\\b/);\n                if (match) {\n                    const postal = match[1];\n                    // Handle Corsica: 20000-20999 -> 2A or 2B\n                    if (postal.startsWith('20')) {\n                        const num = parseInt(postal, 10);\n                        return num < 20200 ? '2A' : '2B';\n                    }\n                    // DOM-TOM: 97x\n                    if (postal.startsWith('97')) {\n                        return postal.substring(0, 3);\n                    }\n                    return postal.substring(0, 2);\n                }\n                return null;\n            }\n\n            // Geocoding cache: city name -> dept code\n            const geocodeCache = {};\n\n            async function geocodeCityToDept(query) {\n                if (!query || query.length < 2) return null;\n                const cacheKey = query.toLowerCase().trim();\n                if (geocodeCache[cacheKey] !== undefined) return geocodeCache[cacheKey];\n                try {\n                    const resp = await fetch('https://api-adresse.data.gouv.fr/search/?q=' + encodeURIComponent(query) + '&limit=1&type=municipality');\n                    if (!resp.ok) { geocodeCache[cacheKey] = null; return null; }\n                    const data = await resp.json();\n                    if (data.features && data.features.length > 0) {\n                        const props = data.features[0].properties;\n                        const postcode = props.postcode || '';\n                        if (postcode.length >= 5) {\n                            const code = extractDeptCodeFromPostal(postcode);\n                            geocodeCache[cacheKey] = code;\n                            return code;\n                        }\n                        // Fallback: use citycode (INSEE code, first 2 digits = dept)\n                        const citycode = props.citycode || '';\n                        if (citycode.length >= 2) {\n                            let code;\n                            if (citycode.startsWith('2A') || citycode.startsWith('2B')) {\n                                code = citycode.substring(0, 2);\n                            } else if (citycode.startsWith('97')) {\n                                code = citycode.substring(0, 3);\n                            } else {\n                                code = citycode.substring(0, 2);\n                            }\n                            geocodeCache[cacheKey] = code;\n                            return code;\n                        }\n                    }\n                    geocodeCache[cacheKey] = null;\n                    return null;\n                } catch (e) {\n                    console.warn('Geocoding error for \"' + query + '\":', e.message);\n                    geocodeCache[cacheKey] = null;\n                    return null;\n                }\n            }\n\n            function extractDeptCodeFromPostal(postal) {\n                if (postal.startsWith('20')) {\n                    const num = parseInt(postal, 10);\n                    return num < 20200 ? '2A' : '2B';\n                }\n                if (postal.startsWith('97')) return postal.substring(0, 3);\n                return postal.substring(0, 2);\n            }\n\n            function extractCityFromLocation(location) {\n                if (!location) return null;\n                // Remove postal codes, country names, street numbers, common noise\n                let cleaned = location\n                    .replace(/\\b\\d{5}\\b/g, '')\n                    .replace(/\\b(France|FR)\\b/gi, '')\n                    .replace(/\\b\\d{1,4}\\s*(rue|avenue|boulevard|allée|chemin|route|place|impasse|bd|av)\\b/gi, '')\n                    .replace(/\\b(rue|avenue|boulevard|allée|chemin|route|place|impasse|bd|av)\\s+[^\\s,]+/gi, '')\n                    .replace(/[,;]/g, ' ')\n                    .replace(/\\s+/g, ' ')\n                    .trim();\n                // Take the last meaningful word group (often the city)\n                const parts = cleaned.split(/\\s{2,}|\\s+-\\s+/).map(s => s.trim()).filter(s => s.length > 1);\n                if (parts.length > 0) return parts[parts.length - 1];\n                if (cleaned.length > 1) return cleaned;\n                return null;\n            }\n\n            async function resolveAllEventLocations(events) {\n                const toResolve = [];\n                events.forEach(ev => {\n                    const loc = ev.extendedProps?.location || '';\n                    const deptFromPostal = extractDeptCodeFromLocation(loc);\n                    if (deptFromPostal) {\n                        ev.extendedProps.resolvedDeptCode = deptFromPostal;\n                    } else if (loc.trim()) {\n                        toResolve.push(ev);\n                    }\n                });\n                // Batch geocode events without postal codes (throttled, max 5 at a time)\n                const batchSize = 5;\n                for (let i = 0; i < toResolve.length; i += batchSize) {\n                    const batch = toResolve.slice(i, i + batchSize);\n                    await Promise.all(batch.map(async ev => {\n                        const loc = ev.extendedProps?.location || '';\n                        const city = extractCityFromLocation(loc);\n                        if (city) {\n                            const code = await geocodeCityToDept(city);\n                            if (code) {\n                                ev.extendedProps.resolvedDeptCode = code;\n                            } else {\n                                // Try with full location string as fallback\n                                const code2 = await geocodeCityToDept(loc);\n                                if (code2) ev.extendedProps.resolvedDeptCode = code2;\n                            }\n                        }\n                    }));\n                }\n            }\n\n            function getEventDeptCode(ev) {\n                // Use pre-resolved code if available\n                if (ev.extendedProps?.resolvedDeptCode) return ev.extendedProps.resolvedDeptCode;\n                return extractDeptCodeFromLocation(ev.extendedProps?.location || '');\n            }\n\n            function populateRegionSelect() {\n                const regSelect = document.getElementById('filter-region');\n                if (!regSelect) return;\n                regSelect.innerHTML = '<option value=\"all\" selected>Partout</option><option value=\"hors-france\">Hors France 🌍</option>';\n                Object.keys(REGIONS_DEPARTMENTS).forEach(region => {\n                    const opt = document.createElement('option');\n                    opt.value = 'region:' + region;\n                    opt.textContent = region;\n                    opt.className = 'filter-option-region';\n                    regSelect.appendChild(opt);\n                });\n            }\n\n            function populateDetailSelect(region) {\n                const detailSelect = document.getElementById('filter-detail');\n                const detailWrap = document.getElementById('filter-detail-wrap');\n                if (!detailSelect || !detailWrap) return;\n                if (!region || region === 'all') {\n                    detailWrap.classList.remove('visible');\n                    setTimeout(() => {\n                        detailSelect.innerHTML = '<option value=\"all\" selected>Toute la région</option>';\n                    }, 400);\n                    return;\n                }\n                detailSelect.innerHTML = '<option value=\"all\" selected>Toute la région</option>';\n                const depts = REGIONS_DEPARTMENTS[region];\n                if (!depts) return;\n                const oldRegs = OLD_REGIONS[region];\n                if (oldRegs) {\n                    Object.entries(oldRegs).forEach(([oldName, oldCodes]) => {\n                        // Old region header\n                        const oldOpt = document.createElement('option');\n                        oldOpt.value = 'oldregion:' + oldName;\n                        oldOpt.textContent = '\\u25b9 ' + oldName;\n                        oldOpt.className = 'filter-option-oldregion';\n                        detailSelect.appendChild(oldOpt);\n                        // Departments belonging to this old region\n                        depts.filter(d => oldCodes.includes(getDeptCode(d))).forEach(d => {\n                            const opt = document.createElement('option');\n                            opt.value = 'dept:' + getDeptCode(d);\n                            opt.textContent = '\\u00A0\\u00A0\\u00A0' + d;\n                            opt.className = 'filter-option-dept';\n                            detailSelect.appendChild(opt);\n                        });\n                    });\n                } else {\n                    depts.forEach(d => {\n                        const opt = document.createElement('option');\n                        opt.value = 'dept:' + getDeptCode(d);\n                        opt.textContent = d;\n                        opt.className = 'filter-option-dept';\n                        detailSelect.appendChild(opt);\n                    });\n                }\n                requestAnimationFrame(() => { detailWrap.classList.add('visible'); });\n            }\n\n            function getFilteredEvents() {\n                const typeFilter = document.getElementById('filter-type')?.value || 'all';\n                const regionFilter = document.getElementById('filter-region')?.value || 'all';\n                const detailFilter = document.getElementById('filter-detail')?.value || 'all';\n\n                return allLoadedEvents.filter(ev => {\n                    // Type filter\n                    const foxEmojiRegex = /\\u{1F98A}/u;\n                    const isFurry = typeof ev.title === 'string' && foxEmojiRegex.test(ev.title);\n                    if (typeFilter === 'furry' && !isFurry) return false;\n                    if (typeFilter === 'standard' && isFurry) return false;\n\n                    // Region filter\n                    if (regionFilter === 'hors-france') {\n                        // Hors France : événements SANS code postal français\n                        const eventDeptCode = getEventDeptCode(ev);\n                        if (eventDeptCode) return false; // A un dept français → exclu\n                        return true;\n                    }\n\n                    if (regionFilter !== 'all') {\n                        const eventDeptCode = getEventDeptCode(ev);\n                        if (!eventDeptCode) return false;\n                        const filterRegion = regionFilter.substring(7);\n                        const eventRegion = DEPT_CODE_TO_REGION[eventDeptCode];\n                        if (eventRegion !== filterRegion) return false;\n\n                        // Detail filter (old region or department)\n                        if (detailFilter !== 'all') {\n                            if (detailFilter.startsWith('dept:')) {\n                                if (eventDeptCode !== detailFilter.substring(5)) return false;\n                            } else if (detailFilter.startsWith('oldregion:')) {\n                                const eventOldRegion = DEPT_CODE_TO_OLD_REGION[eventDeptCode];\n                                if (eventOldRegion !== detailFilter.substring(10)) return false;\n                            }\n                        }\n                    }\n\n                    return true;\n                });\n            }\n\n            function saveFilterSettings() {\n                const saveCheckbox = document.getElementById('filter-save');\n                if (!saveCheckbox || !saveCheckbox.checked) return;\n                const settings = {\n                    type: document.getElementById('filter-type')?.value || 'all',\n                    region: document.getElementById('filter-region')?.value || 'all',\n                    detail: document.getElementById('filter-detail')?.value || 'all'\n                };\n                try {\n                    localStorage.setItem('calendarFilterSettings', JSON.stringify(settings));\n                    localStorage.setItem('calendarFilterSave', 'true');\n                } catch(e) { /* storage blocked */ }\n            }\n\n            function restoreFilterSettings() {\n                let saved = null;\n                try { saved = localStorage.getItem('calendarFilterSave'); } catch(e) { /* storage blocked */ }\n                const saveCheckbox = document.getElementById('filter-save');\n                if (!saved || saved !== 'true' || !saveCheckbox) return false;\n                saveCheckbox.checked = true;\n                try {\n                    const settings = JSON.parse(localStorage.getItem('calendarFilterSettings'));\n                    if (!settings) return false;\n                    const filterType = document.getElementById('filter-type');\n                    const filterRegion = document.getElementById('filter-region');\n                    if (filterType && settings.type) filterType.value = settings.type;\n                    if (filterRegion && settings.region) {\n                        filterRegion.value = settings.region;\n                        if (settings.region !== 'all') {\n                            const regionName = settings.region.substring(7);\n                            populateDetailSelect(regionName);\n                            const filterDetail = document.getElementById('filter-detail');\n                            if (filterDetail && settings.detail) filterDetail.value = settings.detail;\n                        }\n                    }\n                    return true;\n                } catch (e) { return false; }\n            }\n\n            function applyFilters() {\n                saveFilterSettings();\n                const wrapper = document.getElementById('calendar-wrapper');\n                if (wrapper) wrapper.classList.add('calendar-filtering');\n                setTimeout(() => {\n                    loadedEvents = consolidateMultiDayEvents(getFilteredEvents());\n                    if (calendar) {\n                        calendar.removeAllEvents();\n                        calendar.addEventSource(loadedEvents);\n                    }\n                    if (wrapper) wrapper.classList.remove('calendar-filtering');\n                }, 250);\n            }\n\n            function closeEventModal() {\n                const modal = document.querySelector('.event-modal');\n                if (!modal || !modal.classList.contains('show')) return;\n\n                modal.classList.add('closing');\n                modal.setAttribute('aria-hidden', 'true');\n                document.body.classList.remove('modal-open');\n\n                setTimeout(() => {\n                    modal.classList.remove('show', 'closing');\n                }, 250);\n            }\n\n            function openEventModal(event, props) {\n                const modal = document.querySelector('.event-modal');\n                const modalTitle = document.querySelector('.event-modal-title');\n                const modalBody = document.querySelector('.event-modal-body');\n\n                if (!modal || !modalTitle || !modalBody) return;\n\n                document.body.classList.add('modal-open');\n\n                requestAnimationFrame(() => {\n                    modal.setAttribute('role', 'dialog');\n                    modal.setAttribute('aria-modal', 'true');\n                    modal.setAttribute('aria-hidden', 'false');\n                    modalTitle.id = 'modal-title';\n                    modal.setAttribute('aria-labelledby', 'modal-title');\n\n                    const titleText = props.summary || event.title;\n                    const isFCDModal = titleText && titleText.toUpperCase().includes('FCD');\n                    if (isFCDModal) {\n                        modalTitle.innerHTML = `<img src=\"${NORMANDIFURS_LOGO}\" class=\"event-logo-normandifurs modal-logo\" alt=\"\" title=\"Événement organisé par NormandiFurs\">${titleText}`;\n                    } else {\n                        modalTitle.textContent = titleText;\n                    }\n\n                    let leftHTML = '';\n                    let rightHTML = '';\n\n                    if (props.startDate) {\n                        const isAllDay = !!event.allDay;\n                        const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };\n                        const timeOptions = { hour: '2-digit', minute: '2-digit' };\n                        const startDateOnly = props.startDate.toLocaleDateString('fr-FR', dateOptions);\n                        const startTime = !isAllDay ? props.startDate.toLocaleTimeString('fr-FR', timeOptions) : null;\n                        const startDisplay = isAllDay ? `${startDateOnly} — Journée entière` : `${startDateOnly} • ${startTime}`;\n\n                        leftHTML += `\n                <div class=\"event-info-row\">\n                  <div class=\"event-info-icon\">📅</div>\n                  <div class=\"event-info-content\">\n                    <div class=\"event-info-label\">Début</div>\n                    <div class=\"event-info-text\">${startDisplay}</div>\n                  </div>\n                </div>`;\n                    }\n\n                    if (props.endDate && props.endDate.toDateString() !== props.startDate.toDateString()) {\n                        const isAllDay = !!event.allDay;\n                        let displayEndDate = new Date(props.endDate);\n                        if (isAllDay) displayEndDate = new Date(props.endDate.getTime() - 24 * 60 * 60 * 1000);\n                        const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };\n                        const timeOptions = { hour: '2-digit', minute: '2-digit' };\n                        const endDateOnly = displayEndDate.toLocaleDateString('fr-FR', dateOptions);\n                        const endTime = !isAllDay ? props.endDate.toLocaleTimeString('fr-FR', timeOptions) : null;\n                        const endDisplay = isAllDay ? `${endDateOnly} — Journée entière` : `${endDateOnly} • ${endTime}`;\n                        const durationDays = Math.ceil((displayEndDate - props.startDate) / (24 * 60 * 60 * 1000)) + (isAllDay ? 1 : 0);\n\n                        leftHTML += `\n                <div class=\"event-info-row\">\n                  <div class=\"event-info-icon\">🏁</div>\n                  <div class=\"event-info-content\">\n                    <div class=\"event-info-label\">Fin</div>\n                    <div class=\"event-info-text\">${endDisplay} (${durationDays} jour${durationDays > 1 ? 's' : ''})</div>\n                  </div>\n                </div>`;\n                    }\n\n                    if (props.location) {\n                        const encodedLocation = encodeURIComponent(props.location);\n                        leftHTML += `\n                <div class=\"event-info-row\">\n                  <div class=\"event-info-icon\">📍</div>\n                  <div class=\"event-info-content\">\n                    <div class=\"event-info-label\">Lieu</div>\n                    <div class=\"event-info-text\">${props.location}</div>\n                    <div class=\"event-location-buttons\">\n                      <a href=\"https://www.google.com/maps/search/${encodedLocation}\" target=\"_blank\" rel=\"noopener\" class=\"location-btn location-google\"><svg viewBox=\"0 0 32 32\" class=\"location-btn-logo\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M2 11.9556C2 8.47078 2 6.7284 2.67818 5.39739C3.27473 4.22661 4.22661 3.27473 5.39739 2.67818C6.7284 2 8.47078 2 11.9556 2H20.0444C23.5292 2 25.2716 2 26.6026 2.67818C27.7734 3.27473 28.7253 4.22661 29.3218 5.39739C30 6.7284 30 8.47078 30 11.9556V20.0444C30 23.5292 30 25.2716 29.3218 26.6026C28.7253 27.7734 27.7734 28.7253 26.6026 29.3218C25.2716 30 23.5292 30 20.0444 30H11.9556C8.47078 30 6.7284 30 5.39739 29.3218C4.22661 28.7253 3.27473 27.7734 2.67818 26.6026C2 25.2716 2 23.5292 2 20.0444V11.9556Z\" fill=\"white\" fill-opacity=\"0.15\"/><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M24 12.8116L23.9999 12.8541C23.9998 12.872 23.9996 12.8899 23.9994 12.9078C23.9998 12.9287 24 12.9498 24 12.971C24 16.3073 21.4007 19.2604 19.6614 21.2367C19.1567 21.8101 18.7244 22.3013 18.449 22.6957C17.4694 24.0986 16.9524 25.6184 16.8163 26.2029C16.8163 26.6431 16.4509 27 16 27C15.5491 27 15.1837 26.6431 15.1837 26.2029C15.0476 25.6184 14.5306 24.0986 13.551 22.6957C13.2756 22.3013 12.8433 21.8101 12.3386 21.2367C10.5993 19.2604 8 16.3073 8 12.971C8 12.9498 8.0002 12.9287 8.0006 12.9078C8.0002 12.8758 8 12.8437 8 12.8116C8 8.49736 11.5817 5 16 5C20.4183 5 24 8.49736 24 12.8116ZM16 15.6812C17.7132 15.6812 19.102 14.325 19.102 12.6522C19.102 10.9793 17.7132 9.62319 16 9.62319C14.2868 9.62319 12.898 10.9793 12.898 12.6522C12.898 14.325 14.2868 15.6812 16 15.6812Z\" fill=\"white\"/><path d=\"M23.1054 9.21856C22.1258 7.37546 20.4161 5.96177 18.3504 5.34277L13.7559 10.5615C14.3208 9.98352 15.1174 9.62346 16.0002 9.62346C17.7134 9.62346 19.1022 10.9796 19.1022 12.6524C19.1022 13.3349 18.8711 13.9646 18.4811 14.4711L23.1054 9.21856Z\" fill=\"white\" fill-opacity=\"0.8\"/><path d=\"M12.4311 21.3425C12.4004 21.3076 12.3695 21.2725 12.3383 21.2371C11.1918 19.9344 9.67162 18.2073 8.76855 16.2257L13.5439 10.8018C13.1387 11.3136 12.8976 11.9556 12.8976 12.6526C12.8976 14.3254 14.2865 15.6816 15.9997 15.6816C16.8675 15.6816 17.6521 15.3336 18.2151 14.7727L12.4311 21.3425Z\" fill=\"white\" fill-opacity=\"0.7\"/><path d=\"M9.89288 7.76562C8.71207 9.12685 8 10.8881 8 12.8117C8 12.8438 8.0002 12.8759 8.0006 12.9079C8.0002 12.9288 8 12.9499 8 12.9711C8 14.1082 8.30196 15.2009 8.76889 16.2254L13.5362 10.8106L9.89288 7.76562Z\" fill=\"white\" fill-opacity=\"0.6\"/><path d=\"M18.3499 5.34254C17.6068 5.11988 16.8176 5 15.9997 5C13.5514 5 11.36 6.07387 9.89258 7.76553L13.5359 10.8105L13.5438 10.8015C13.6101 10.7178 13.6807 10.6375 13.7554 10.5611L18.3499 5.34254Z\" fill=\"white\" fill-opacity=\"0.9\"/></svg><span class=\"location-btn-label\">Google Maps</span></a>\n                      <a href=\"https://www.waze.com/ul?q=${encodedLocation}\" target=\"_blank\" rel=\"noopener\" class=\"location-btn location-waze\"><svg viewBox=\"0 0 14 14\" class=\"location-btn-logo\" xmlns=\"http://www.w3.org/2000/svg\"><path fill=\"#ffffff\" d=\"m 12.937649,5.689685 c -0.11625,-0.68661 -0.388914,-1.33016 -0.810638,-1.91282 -0.476314,-0.65811 -1.127922,-1.20761 -1.884324,-1.58903 -0.7645339,-0.38552 -1.6178829,-0.58938 -2.4678369,-0.58938 -0.239783,0 -0.481475,0.0163 -0.71843,0.0482 -0.992367,0.13407 -1.968118,0.54689 -2.747572,1.16243 -0.878239,0.69354 -1.444993,1.58521 -1.638884,2.57878 -0.05777,0.29537 -0.08238,0.62212 -0.106209,0.93806 -0.03734,0.49456 -0.07594,1.00595 -0.233207,1.34013 -0.107482,0.