            },
            ".fc-listMonth-view .fc-list-day": {
              "display": "block !important",
              "background": "transparent !important",
              "border": "none !important",
              "margin-bottom": "0 !important"
            },
            ".fc-listMonth-view .fc-list-day-cushion": {
              "display": "block !important",
              "padding": "12px 20px !important",
              "border-radius": "8px !important",
              "font-size": "1rem !important",
              "background": "#667eea !important"
            },
            ".fc-listMonth-view .fc-list-event": {
              "display": "flex !important",
              "align-items": "center",
              "width": "100%",
              "box-sizing": "border-box",
              "padding": "22px 28px !important",
              "margin-bottom": "16px !important",
              "border-radius": "12px !important"
            },
            ".fc-listMonth-view .fc-list-event td": {
              "padding": "0 !important",
              "border": "none !important",
              "display": "block !important"
            },
            ".fc-listMonth-view .fc-list-event td.fc-list-event-time": {
              "display": "none !important"
            },
            ".fc-listMonth-view .fc-list-event .fc-event-title, .fc-listMonth-view .fc-list-event-title": {
              "font-size": "1.1rem !important",
              "font-weight": "700 !important"
            },
            ".fc-listMonth-view .fc-list-table tbody tr": {
              "border-bottom": "1px solid rgba(255, 255, 255, 0.06)"
            },
            ".fc-listMonth-view .fc-list-table tbody tr.fc-list-day": {
              "border-bottom": "none !important"
            },
            ".fc-listMonth-view .fc-list-table tbody tr > td": {
              "padding": "0 !important"
            },
            ".fc-listMonth-view .fc-list-day-side": {
              "display": "none !important"
            },
            ".fc-listMonth-view .fc-list-day-side-text": {
              "display": "none !important"
            },
            ".fc-listMonth-view .fc-list-day-text": {
              "padding-left": "0.4rem",
              "font-size": "0.85rem !important",
              "font-weight": "700 !important",
              "color": "#fff !important"
            },
            "th[scope=\"colgroup\"] .fc-list-day-cushion.fc-cell-shaded, th[scope=\"colgroup\"], .fc-list-day-cushion, .fc-cell-shaded": {
              "background": "transparent !important",
              "background-color": "transparent !important",
              "background-image": "none !important",
              "box-shadow": "none !important",
              "border": "none !important",
              "border-radius": "10px !important"
            },
            "th[scope=\"colgroup\"] .fc-list-day-cushion.fc-cell-shaded::before, th[scope=\"colgroup\"] .fc-list-day-cushion.fc-cell-shaded::after, .fc-list-day-cushion::before, .fc-list-day-cushion::after": {
              "content": "none !important",
              "display": "none !important",
              "background": "none !important",
              "background-image": "none !important",
              "-webkit-mask-image": "none !important",
              "mask-image": "none !important"
            },
            "th[scope=\"colgroup\"] .fc-list-day-text, th[scope=\"colgroup\"] .fc-list-day-side-text": {
              "background": "transparent !important",
              "background-image": "none !important"
            },
            ".fc, .fc-theme-standard": {
              "--fc-list-day-bg-color": "transparent",
              "--fc-neutral-bg-color": "transparent",
              "--fc-page-bg-color": "transparent",
              "--fc-list-event-hover-bg-color": "transparent"
            },
            ".fc .fc-list-sticky .fc-list-day > *": {
              "background": "#2a2a38",
              "position": "sticky",
              "top": "0px",
              "z-index": "10"
            },
            ".fc-day-other .fc-daygrid-day-number": {
              "visibility": "hidden !important"
            },
            ".fc-day-other": {
              "background": "rgba(30, 30, 46, 0.5) !important"
            }
          },
          "_name": "header09",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"mbr-section mbr-section--no-padding\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"@PROJECT_PATH@/assets/images/img-2921-2000x1186.webp\" parallax selected>\n            <input type=\"color\" title=\"Background Color\" value=\"#2d2d3d\">\n            <input type=\"video\" title=\"Background Video\" value>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#1a1a2e\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n\n        <header>Calendrier FullCalendar</header>\n        <input type=\"text\" title=\"URL iCalendar\" name=\"icalUrl\" value=\"https://raw.githubusercontent.com/QuentinMarical/lameutenormande/refs/heads/main/events.ics\" data-ical-url>\n\n        <header>Contrôles</header>\n        <input type=\"checkbox\" title=\"Autoriser Vue Calendrier\" name=\"allowCalendarView\" checked>\n        <input type=\"checkbox\" title=\"Autoriser Vue Liste\" name=\"allowListView\" checked>\n        <input type=\"checkbox\" title=\"Vue Liste par défaut (Mobile)\" name=\"defaultListViewMobile\" condition=\"allowListView\" checked>\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <style>\n        .mbr-section {\n            min-height: 100vh !important;\n            display: flex !important;\n            flex-direction: column !important;\n        }\n\n            .mbr-section > .container-calendar {\n                flex: 1 1 auto !important;\n                display: flex !important;\n                flex-direction: column !important;\n            }\n\n        .event-modal {\n            display: none !important;\n            position: fixed !important;\n            z-index: 2147483647 !important;\n            inset: 0 !important;\n            width: 100vw !important;\n            height: 100vh !important;\n            align-items: center;\n            justify-content: center;\n            padding: 1.25rem;\n            box-sizing: border-box;\n        }\n\n        .event-modal.show {\n            display: flex !important;\n        }\n\n        .event-modal.closing .event-modal-content {\n            animation: modalFadeOut 0.25s ease forwards;\n        }\n\n        .event-modal-overlay {\n            position: fixed !important;\n            inset: 0 !important;\n            background: rgba(10, 10, 25, 0.92) !important;\n            -webkit-backdrop-filter: blur(12px) !important;\n            backdrop-filter: blur(12px) !important;\n            z-index: 0 !important;\n            cursor: pointer;\n        }\n\n        .event-modal-content {\n            position: relative;\n            z-index: 1;\n            width: 100%;\n            max-width: 860px;\n            max-height: calc(100vh - 2.5rem);\n            border-radius: 20px !important;\n            margin: 0 auto;\n            padding: 0;\n            background: linear-gradient(155deg, #1e1e2e 0%, #181828 60%, #141422 100%);\n            border: 1px solid rgba(102, 126, 234, 0.18);\n            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06), 0 24px 60px rgba(0, 0, 0, 0.7), 0 0 80px rgba(102, 126, 234, 0.12);\n            overflow-y: auto;\n            overflow-x: hidden;\n            -webkit-overflow-scrolling: touch;\n            display: flex;\n            flex-direction: column;\n            animation: modalFadeIn 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n            scrollbar-width: thin;\n            scrollbar-color: rgba(102, 126, 234, 0.45) transparent;\n        }\n\n        .event-modal-content::-webkit-scrollbar {\n            width: 6px;\n        }\n\n        .event-modal-content::-webkit-scrollbar-track {\n            background: transparent;\n        }\n\n        .event-modal-content::-webkit-scrollbar-thumb {\n            background: rgba(102, 126, 234, 0.45);\n            border-radius: 3px;\n        }\n\n        .event-modal-content::-webkit-scrollbar-thumb:hover {\n            background: rgba(102, 126, 234, 0.7);\n        }\n\n        .event-modal-header {\n            display: flex;\n            align-items: flex-start;\n            justify-content: space-between;\n            padding: 1.75rem 2rem 1.25rem;\n            border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n            background: linear-gradient(90deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.06), transparent);\n            gap: 1rem;\n        }\n\n        .event-modal-title {\n            margin: 0;\n            font-size: 1.5rem;\n            font-weight: 700;\n            line-height: 1.3;\n            background: linear-gradient(90deg, #667eea, #764ba2, #a855f7);\n            -webkit-background-clip: text;\n            background-clip: text;\n            -webkit-text-fill-color: transparent;\n            flex: 1;\n            min-width: 0;\n            display: flex;\n            align-items: center;\n        }\n\n        .event-modal-title .event-logo-normandifurs {\n            -webkit-text-fill-color: initial;\n        }\n\n        .event-modal-close {\n            flex-shrink: 0;\n            background: rgba(255, 255, 255, 0.1);\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            color: rgba(255, 255, 255, 0.85);\n            font-size: 1.4rem;\n            width: 2.5rem;\n            height: 2.5rem;\n            border-radius: 50%;\n            cursor: pointer;\n            transition: all 0.25s ease;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            line-height: 1;\n            padding: 0;\n            margin-top: 0.15rem;\n        }\n\n        .event-modal-close:hover, .event-modal-close:focus {\n            background: rgba(102, 126, 234, 0.25);\n            border-color: rgba(102, 126, 234, 0.5);\n            color: #fff;\n            transform: rotate(90deg);\n        }\n\n        .event-modal-body {\n            padding: 1.5rem 2rem 2rem;\n            color: #fff;\n            flex: 1;\n        }\n\n        .event-modal-body-grid {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: 0.75rem;\n        }\n\n        .event-modal-left, .event-modal-right {\n            display: flex;\n            flex-direction: column;\n            gap: 0.75rem;\n        }\n\n        @media (min-width: 760px) {\n            .event-modal-body-grid {\n                grid-template-columns: 1fr 1fr;\n            }\n        }\n\n        @media (max-width: 767px) {\n            .event-modal {\n                padding: 0 !important;\n                align-items: stretch !important;\n            }\n\n            .event-modal-overlay {\n                position: fixed !important;\n                inset: 0 !important;\n            }\n\n            .event-modal-content {\n                position: fixed !important;\n                inset: 0 !important;\n                width: 100vw !important;\n                max-width: 100vw !important;\n                height: 100vh !important;\n                max-height: 100vh !important;\n                margin: 0 !important;\n                border-radius: 0 !important;\n                box-shadow: none !important;\n                animation: sheetUp 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n            }\n\n            .event-modal.closing .event-modal-content {\n                animation: sheetDown 0.25s ease forwards;\n            }\n\n            .event-modal-header {\n                padding: 1.5rem 1.25rem 1rem !important;\n                position: sticky !important;\n                top: 0 !important;\n                z-index: 10 !important;\n                background: linear-gradient(155deg, #1e1e2e 0%, #181828 60%, #141422 100%);\n            }\n\n            .event-modal-body {\n                padding: 1rem 1.25rem 2rem !important;\n                flex: 1;\n                overflow-y: auto;\n            }\n\n            .event-modal-title {\n                font-size: 1.3rem !important;\n            }\n\n            .location-btn {\n                min-width: 0;\n                flex: 1;\n            }\n        }\n\n        .event-info-row {\n            display: flex;\n            align-items: flex-start;\n            gap: 0.9rem;\n            padding: 1rem 1.25rem;\n            background: rgba(255, 255, 255, 0.04);\n            border: 1px solid rgba(255, 255, 255, 0.07);\n            border-radius: 12px;\n            transition: background 0.2s ease;\n        }\n\n        .event-info-row:hover {\n            background: rgba(255, 255, 255, 0.07);\n        }\n\n        .event-info-icon {\n            font-size: 1.35rem;\n            min-width: 28px;\n            flex-shrink: 0;\n            margin-top: 0.1rem;\n        }\n\n        .event-info-content {\n            flex: 1;\n            min-width: 0;\n        }\n\n        .event-info-label {\n            font-size: 0.73rem;\n            letter-spacing: 0.1em;\n            text-transform: uppercase;\n            font-weight: 700;\n            color: rgba(102, 126, 234, 0.85);\n            margin-bottom: 0.35rem;\n        }\n\n        .event-info-text {\n            font-size: 1rem;\n            line-height: 1.55;\n            font-weight: 500;\n            word-break: break-word;\n            color: rgba(255, 255, 255, 0.92);\n        }\n\n        .event-info-text a {\n            color: #667eea;\n            text-decoration: underline;\n            transition: color 0.2s;\n        }\n\n        .event-info-text a:hover {\n            color: #a855f7;\n        }\n\n        .event-description {\n            white-space: pre-line;\n        }\n\n        .event-location-buttons {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 0.6rem;\n            margin-top: 0.85rem;\n            padding-top: 0.85rem;\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .location-btn {\n            flex: 1;\n            min-width: 70px;\n            padding: 0.6rem 0.5rem;\n            border-radius: 10px;\n            font-size: 0.85rem;\n            font-weight: 600;\n            text-decoration: none;\n            text-align: center;\n            cursor: pointer;\n            transition: all 0.25s ease;\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            color: #fff;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 0.35rem;\n        }\n\n        .location-btn-logo {\n            width: 28px;\n            height: 28px;\n            flex-shrink: 0;\n        }\n\n        .location-btn-label {\n            font-size: 0.65rem;\n            font-weight: 600;\n            line-height: 1.1;\n            color: inherit;\n        }\n\n        .location-google {\n            background: rgba(66, 133, 244, 0.75);\n            border-color: rgba(66, 133, 244, 0.5);\n        }\n\n        .location-google:hover {\n            background: #4285F4;\n            box-shadow: 0 4px 14px rgba(66, 133, 244, 0.45);\n            transform: translateY(-1px);\n        }\n\n        .location-waze {\n            background: rgba(0, 198, 219, 0.75);\n            border-color: rgba(0, 198, 219, 0.5);\n        }\n\n        .location-waze:hover {\n            background: #00C6DB;\n            box-shadow: 0 4px 14px rgba(0, 198, 219, 0.45);\n            transform: translateY(-1px);\n        }\n\n        .location-apple {\n            background: rgba(140, 140, 155, 0.75);\n            border-color: rgba(140, 140, 155, 0.5);\n        }\n\n        .location-apple:hover {\n            background: #8c8c9b;\n            box-shadow: 0 4px 14px rgba(140, 140, 155, 0.45);\n            transform: translateY(-1px);\n        }\n\n        .event-url-button {\n            display: inline-flex;\n            align-items: center;\n            gap: 0.4rem;\n            margin-top: 0.5rem;\n            padding: 0.55rem 1.1rem;\n            background: linear-gradient(135deg, #667eea, #764ba2);\n            color: #fff !important;\n            text-decoration: none;\n            border-radius: 20px;\n            font-weight: 600;\n            font-size: 0.88rem;\n            transition: all 0.2s ease;\n        }\n\n        .event-url-button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.45);\n            color: #fff !important;\n        }\n\n        @keyframes modalFadeIn {\n            from { opacity: 0; transform: scale(0.94) translateY(12px); }\n            to { opacity: 1; transform: scale(1) translateY(0); }\n        }\n\n        @keyframes modalFadeOut {\n            from { opacity: 1; transform: scale(1) translateY(0); }\n            to { opacity: 0; transform: scale(0.94) translateY(12px); }\n        }\n\n        @keyframes sheetUp {\n            from { transform: translateY(100%); }\n            to { transform: translateY(0); }\n        }\n\n        @keyframes sheetDown {\n            from { transform: translateY(0); }\n            to { transform: translateY(100%); }\n        }\n\n        .calendar-zone::-webkit-scrollbar {\n            width: 6px;\n        }\n\n        .calendar-zone::-webkit-scrollbar-track {\n            background: rgba(45, 45, 61, 0.5);\n            border-radius: 3px;\n        }\n\n        .calendar-zone::-webkit-scrollbar-thumb {\n            background: rgba(255, 255, 255, 0.3);\n            border-radius: 3px;\n        }\n\n            .calendar-zone::-webkit-scrollbar-thumb:hover {\n                background: rgba(255, 255, 255, 0.5);\n            }\n\n        .fc-day-other .fc-daygrid-day-number {\n            visibility: hidden !important;\n        }\n\n        .fc-day-other {\n            background: rgba(30, 30, 46, 0.5) !important;\n        }\n\n            .fc-day-other:hover {\n                background: rgba(30, 30, 46, 0.5) !important;\n            }\n\n        /* z-index modal-open : règles injectées via JS (LESS peut scoper le style inline) */\n\n        body.scroll-locked,\n        html.scroll-locked {\n            overflow: hidden !important;\n        }\n\n        .fc .fc-time,\n        .fc .fc-event-time,\n        .fc .fc-list-event-time {\n            display: none !important;\n        }\n    </style>\n\n    <div class=\"container container-calendar\" mbr-class=\"{'container': !fullScreen}\" data-allow-list-view=\"{{allowListView}}\" data-allow-calendar-view=\"{{allowCalendarView}}\" data-default-list-view-mobile=\"{{defaultListViewMobile}}\">\n        <div class=\"calendar-zone\">\n            <div class=\"calendar-loader\" id=\"calendar-loader\" style=\"display: flex; align-items: center; justify-content: center; min-height: 300px;\">\n                <div style=\"text-align:center; width:100%;\">\n                    <div class=\"loader-spinner\" style=\"margin: 0 auto 1rem auto; width: 48px; height: 48px; border: 6px solid #eee; border-top: 6px solid #667eea; border-radius: 50%; animation: spin 1s linear infinite;\"></div>\n                    <div id=\"calendar-loader-message\" style=\"color:#888; font-size:1.1rem;\">Chargement du calendrier...</div>\n                    <div id=\"calendar-loader-progress\" style=\"width: 100%; max-width: 320px; height: 8px; background: #eee; border-radius: 5px; margin: 18px auto 0 auto; overflow: hidden; display: none;\">\n                        <div id=\"calendar-loader-bar\" style=\"height: 100%; width: 0%; background: linear-gradient(90deg, #667eea, #764ba2); transition: width 0.3s;\"></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"calendar-header\" id=\"calendar-header\" style=\"display:none;\">\n                <div class=\"calendar-header-row\">\n                    <button class=\"calendar-arrow-btn calendar-prev\">‹</button>\n                    <div class=\"calendar-controls-center\">\n                        <button class=\"calendar-btn calendar-today\">Aujourd'hui</button>\n                        <button class=\"calendar-btn\" id=\"btn-toggle-view\" mbr-if=\"allowListView && allowCalendarView\">Vue Liste</button>\n                        <button class=\"calendar-btn btn-subscribe-style\" id=\"btn-subscribe\">📅 S'abonner</button>\n                        <span class=\"calendar-month\">Décembre 2024</span>\n                    </div>\n                    <button class=\"calendar-arrow-btn calendar-next\">›</button>\n                </div>\n                <div class=\"calendar-filters-row\">\n                    <div class=\"calendar-filter-save\">\n                        <label class=\"calendar-save-label\" title=\"Conserver les filtres au prochain chargement\">\n                            <input type=\"checkbox\" id=\"filter-save\" class=\"calendar-save-checkbox\">\n                            <span class=\"calendar-save-text\">Conserver le filtrage</span>\n                        </label>\n                    </div>\n                    <div class=\"calendar-filter-group\">\n                        <label class=\"calendar-filter-label\">Type</label>\n                        <select class=\"calendar-filter-select\" id=\"filter-type\">\n                            <option value=\"all\" selected>Tous</option>\n                            <option value=\"standard\">Standard</option>\n                            <option value=\"furry\">Furry 🦊</option>\n                        </select>\n                    </div>\n                    <div class=\"calendar-filter-group calendar-filter-group-location\">\n                        <label class=\"calendar-filter-label\">Région</label>\n                        <select class=\"calendar-filter-select\" id=\"filter-region\">\n                            <option value=\"all\" selected>Partout</option>\n                            <option value=\"hors-france\">Hors France 🌍</option>\n                        </select>\n                    </div>\n                    <div class=\"calendar-filter-group calendar-filter-group-location calendar-filter-detail-wrap\" id=\"filter-detail-wrap\">\n                        <label class=\"calendar-filter-label\">Zone</label>\n                        <select class=\"calendar-filter-select\" id=\"filter-detail\">\n                            <option value=\"all\" selected>Toute la région</option>\n                        </select>\n                    </div>\n                </div>\n            </div>\n            <div class=\"calendar-wrapper\" id=\"calendar-wrapper\" style=\"display:none;\">\n                <div class=\"fullcalendar-container\"></div>\n            </div>\n        </div>\n    </div>\n\n    <style>\n        @keyframes spin {\n            0% {\n                transform: rotate(0deg);\n            }\n\n            100% {\n                transform: rotate(360deg);\n            }\n        }\n    </style>\n\n    <div class=\"event-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"event-modal-title\" aria-hidden=\"true\">\n        <div class=\"event-modal-overlay\"></div>\n        <div class=\"event-modal-content\" tabindex=\"-1\">\n            <div class=\"event-modal-header\">\n                <h3 class=\"event-modal-title\" id=\"event-modal-title\"></h3>\n                <button class=\"event-modal-close\" aria-label=\"Fermer\">×</button>\n            </div>\n            <div class=\"event-modal-body\"></div>\n        </div>\n    </div>\n\n\n    <!-- FullCalendar v6 & ical.js - CDN Cloudflare (meilleur support CORS) -->\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/6.1.15/index.global.min.css\" rel=\"stylesheet\" type=\"text/css\">\n    [JS_CODE_0]\n    [JS_CODE_1]\n\n    [JS_CODE_2]\n\n</section>",
