              },
              "&:nth-child(2)": {
                "width": "24px",
                "transform": "rotate(45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(3)": {
                "width": "24px",
                "transform": "rotate(-45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s @easeOut"
              }
