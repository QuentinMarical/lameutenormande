              "font-weight": "600",
              "font-size": "0.85rem",
              "color": "#fff !important",
              "transition": "all 0.3s ease",
              "border": "2px solid transparent",
              "span": {
                "color": "#fff !important"
              }
            },
            ".social-btn:hover": {
              "transform": "translateY(-2px)",
              "box-shadow": "0 4px 15px rgba(0, 0, 0, 0.3)"
            },
            ".social-icon": {
              "font-size": "1.1rem"
            },
            ".social-icon-img": {
              "width": "1.3rem",
              "height": "1.3rem",
              "object-fit": "contain",
              "flex-shrink": "0"
            },
            ".social-name": {
              "white-space": "nowrap"
            },
            ".social-website": {
