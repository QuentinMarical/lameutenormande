        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_name": "article11",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article11\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n       <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" step=\"1\" value=\"10\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#2d2d3d\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">        \n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\">\n    </div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"title col-md-12 col-lg-{{textWidth}}\">\n                <h3 class=\"mbr-section-title mbr-fonts-style align-center mt-0 mb-0\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\">\n                <b>Framing memories</b>\n                </h3>\n                <h4 class=\"mbr-section-subtitle align-center mbr-fonts-style mt-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\">\n                The everlasting charm of photographs\n                </h4>\n                <div class=\"mbr-section-btn align-center mt-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        Learn more\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v2JoqzSbTA",
          "_anchor": "article11-e",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".justify-content-center": {
              "align-items": "center"
            },
            ".mbr-section-title": {
              "text-align": "center",
              "color": "#ffffff"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "center"
            },
            ".item-wrapper": {
              "@media (max-width: 767px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem"
              }
            },
            ".image-wrapper img": {
              "display": "block",
              "width": "100%",
              "height": "auto",
              "border-radius": "1rem"
            },
            ".form-control, textarea.form-control": {
              "border-radius": "0.8rem"
            },
            "textarea.form-control": {
              "min-height": "160px",
              "resize": "vertical"
            },
            "input[type=\"file\"].form-control": {
              "padding": "0.75rem 1rem",
              "min-height": "58px",
              "background-color": "#ffffff",
              "border-radius": "0.8rem"
            },
            ".consent-wrapper": {
              "text-align": "left"
            },
            ".consent-label": {
              "display": "flex",
              "align-items": "flex-start",
              "gap": "0.75rem",
              "color": "#ffffff",
              "font-size": "0.95rem",
              "line-height": "1.5",
              "cursor": "pointer"
            },
            ".consent-label input[type=\"checkbox\"]": {
              "margin-top": "0.2rem",
              "flex": "0 0 auto"
            },
            ".consent-label span": {
              "display": "inline-block"
            },
            ".consent-label a": {
              "color": "#ffffff",
              "text-decoration": "underline"
            },
            ".consent-label a:hover": {
              "opacity": "0.85"
            },
            ".form-label": {
              "color": "#ffffff",
              "font-size": "0.9rem",
              "font-weight": "500",
              "margin-bottom": "0.75rem",
              "display": "block"
            },
            ".contact-network-grid": {
              "display": "grid",
              "grid-template-columns": "repeat(4, minmax(0, 1fr))",
              "gap": "0.75rem",
              "@media (max-width: 991px)": {
                "grid-template-columns": "repeat(2, minmax(0, 1fr))"
              },
              "@media (max-width: 575px)": {
                "grid-template-columns": "1fr 1fr"
              }
            },
            ".network-option": {
              "position": "relative"
            },
            ".network-option input[type=\"radio\"]": {
              "position": "absolute",
              "opacity": "0",
              "inset": "0",
              "width": "100%",
              "height": "100%",
              "margin": "0",
              "z-index": "2",
              "cursor": "pointer"
            },
            ".network-card": {
              "background": "#ffffff",
              "border": "2px solid transparent",
              "border-radius": "1rem",
              "padding": "0.8rem 0.55rem",
              "min-height": "92px",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "center",
              "align-items": "center",
              "gap": "0.5rem",
              "text-align": "center",
              "cursor": "pointer",
              "transition": "all 0.25s ease",
              "box-shadow": "0 6px 18px rgba(0, 0, 0, 0.12)",
              "position": "relative",
              "z-index": "1"
            },
            ".network-card:hover": {
              "transform": "translateY(-1px)",
              "box-shadow": "0 10px 22px rgba(0, 0, 0, 0.16)"
            },
            ".network-icon": {
              "width": "46px",
              "height": "46px",
              "border-radius": "50%",
              "background": "#f4f4f7",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "color": "#2d2d3d",
              "pointer-events": "none"
            },
            ".network-icon svg": {
              "width": "22px",
              "height": "22px"
            },
            ".network-icon-double": {
              "width": "auto",
              "min-width": "62px",
              "height": "46px",
              "padding": "0 0.6rem",
              "gap": "0.35rem",
              "border-radius": "999px"
            },
            ".network-icon-double svg:first-child": {
              "width": "18px",
              "height": "18px"
            },
            ".network-icon-double svg:last-child": {
              "width": "16px",
              "height": "16px"
            },
            ".network-name": {
              "color": "#2d2d3d",
              "font-size": "0.84rem",
              "font-weight": "600",
              "line-height": "1.25",
              "pointer-events": "none"
            },
            ".network-option input[type=\"radio\"]:checked + .network-card": {
              "border-color": "#6d78ff",
              "box-shadow": "0 0 0 4px rgba(109, 120, 255, 0.18)",
              "transform": "translateY(-1px)"
            },
            ".network-option input[type=\"radio\"]:checked + .network-card .network-icon": {
              "background": "#eef0ff",
              "color": "#6d78ff"
            },
            ".network-option input[type=\"radio\"]:focus + .network-card, .network-option input[type=\"radio\"]:focus-visible + .network-card": {
              "box-shadow": "0 0 0 4px rgba(109, 120, 255, 0.22)"
            },
            ".form-control:focus, textarea.form-control:focus, .consent-label input[type=\"checkbox\"]:focus, .consent-label input[type=\"checkbox\"]:focus-visible": {
              "box-shadow": "0 0 0 0.2rem rgba(109, 120, 255, 0.25)"
            }
          },
          "_name": "form03",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"form03\" group=\"Form\" mbr-class=\"{'mbr-fullscreen': fullScreen,'mbr-parallax-background': bg.parallax}\" plugins=\"formstyler, datepicker\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\" checked>\n\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Form Title\" name=\"showFormTitle\" checked>\n        <input type=\"checkbox\" title=\"Form Subtitle\" name=\"showFormSubtitle\" checked>\n\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#2d2d3d\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg item-wrapper\">\n                <div class=\"mbr-section-head mb-5\" mbr-if=\"showFormTitle || showFormSubtitle\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-1\" mbr-if=\"showFormTitle\" data-app-selector=\".mbr-section-title\">\n                        <b>Contact</b>\n                    </h3>\n\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showFormSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                        Pour rejoindre la meute ou pour un renseignement,<br>ce formulaire est fait pour ça !\n                    </h4>\n                </div>\n\n                <div mbr-form class=\"col-lg-12 mx-auto mbr-form\">\n                    <!-- FORMULAIRE BASIN -->\n                    <form action=\"https://usebasin.com/f/56e1aab16816\" name=\"Form Name\" method=\"POST\" accept-charset=\"UTF-8\" enctype=\"multipart/form-data\" class=\"mbr-form form-with-styler\">\n\n                        <div class=\"row\">\n                            <div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">\n                                Nous reviendrons vers toi bientôt ! 😸\n                            </div>\n                            <div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\">\n                                Oops... un problème est survenu.\n                            </div>\n                        </div>\n\n                        <div class=\"dragArea row\">\n                            <div class=\"col-md col-sm-12 form-group mb-3\" data-for=\"name\">\n                                <input type=\"text\" name=\"name\" placeholder=\"Nom / Prénom / Pseudo\" data-form-field=\"name\" class=\"form-control\" required>\n                            </div>\n\n                            <div class=\"col-md col-sm-12 form-group mb-3\" data-for=\"email\">\n                                <input type=\"text\" name=\"email\" placeholder=\"Identifiant / E-mail\" data-form-field=\"email\" class=\"form-control\" required>\n                            </div>\n\n                            <div class=\"col-12 form-group mb-3\" data-for=\"contact-network\">\n                                <label class=\"form-label\">Préférence de contact</label>\n\n                                <div class=\"contact-network-grid\" role=\"radiogroup\" aria-label=\"Préférence de contact\">\n                                    <div class=\"network-option\">\n                                        <input type=\"radio\" name=\"contact-network\" id=\"network-discord\" value=\"discord\" data-form-field=\"contact-network\" required>\n                                        <label class=\"network-card\" for=\"network-discord\">\n                                            <span class=\"network-icon\">\n                                                <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                                                    <path fill=\"currentColor\" d=\"M20.317 4.369A19.791 19.791 0 0 0 15.885 3c-.191.328-.404.775-.553 1.124a18.27 18.27 0 0 0-5.29 0A11.587 11.587 0 0 0 9.49 3a19.736 19.736 0 0 0-4.433 1.369C2.255 8.462 1.52 12.454 1.887 16.389a19.9 19.9 0 0 0 5.993 3.03c.48-.666.908-1.37 1.277-2.108-.705-.267-1.377-.6-2.006-.984.168-.124.332-.252.49-.385 3.87 1.817 8.067 1.817 11.892 0 .16.133.323.261.49.385a12.64 12.64 0 0 1-2.01.985c.37.737.798 1.44 1.278 2.107a19.86 19.86 0 0 0 6-3.03c.43-4.56-.735-8.515-3.97-12.02ZM9.75 13.978c-1.157 0-2.11-1.063-2.11-2.37 0-1.306.934-2.37 2.11-2.37 1.185 0 2.128 1.073 2.11 2.37 0 1.307-.934 2.37-2.11 2.37Zm4.5 0c-1.157 0-2.11-1.063-2.11-2.37 0-1.306.934-2.37 2.11-2.37 1.185 0 2.128 1.073 2.11 2.37 0 1.307-.925 2.37-2.11 2.37Z\"></path>\n                                                </svg>\n                                            </span>\n                                            <span class=\"network-name\">Discord</span>\n                                        </label>\n                                    </div>\n\n                                    <div class=\"network-option\">\n                                        <input type=\"radio\" name=\"contact-network\" id=\"network-telegram\" value=\"telegram\" data-form-field=\"contact-network\">\n                                        <label class=\"network-card\" for=\"network-telegram\">\n                                            <span class=\"network-icon\">\n                                                <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                                                    <path fill=\"currentColor\" d=\"M9.78 18.65 9.95 14l8.47-7.65c.37-.33-.08-.5-.57-.17L7.39 12.75l-4.5-1.4c-.98-.3-.99-.98.2-1.45L20.7 3.1c.82-.3 1.53.2 1.26 1.45l-3.03 14.28c-.23 1.01-.82 1.26-1.67.79l-4.62-3.4-2.23 2.15c-.25.25-.46.46-.93.28Z\"></path>\n                                                </svg>\n                                            </span>\n                                            <span class=\"network-name\">Telegram</span>\n                                        </label>\n                                    </div>\n\n                                    <div class=\"network-option\">\n                                        <input type=\"radio\" name=\"contact-network\" id=\"network-twitter\" value=\"twitter\" data-form-field=\"contact-network\">\n                                        <label class=\"network-card\" for=\"network-twitter\">\n                                            <span class=\"network-icon network-icon-double\">\n                                                <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                                                    <path fill=\"currentColor\" d=\"M22.46 6c-.77.35-1.6.58-2.46.69a4.3 4.3 0 0 0 1.88-2.37 8.59 8.59 0 0 1-2.72 1.04 4.28 4.28 0 0 0-7.4 2.92c0 .34.04.68.11 1A12.15 12.15 0 0 1 3.03 4.9a4.28 4.28 0 0 0 1.32 5.72 4.23 4.23 0 0 1-1.94-.54v.05a4.28 4.28 0 0 0 3.43 4.2 4.3 4.3 0 0 1-1.93.07 4.29 4.29 0 0 0 4 2.98A8.6 8.6 0 0 1 2 19.54a12.13 12.13 0 0 0 6.56 1.92c7.88 0 12.19-6.53 12.19-12.19 0-.19 0-.37-.01-.55A8.7 8.7 0 0 0 22.46 6z\"></path>\n                                                </svg>\n                                                <svg viewBox=\"0 0 16 16\" aria-hidden=\"true\">\n                                                    <path fill=\"currentColor\" d=\"M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z\"></path>\n                                                </svg>\n                                            </span>\n                                            <span class=\"network-name\">Twitter / X</span>\n                                        </label>\n                                    </div>\n\n                                    <div class=\"network-option\">\n                                        <input type=\"radio\" name=\"contact-network\" id=\"network-email\" value=\"email\" data-form-field=\"contact-network\">\n                                        <label class=\"network-card\" for=\"network-email\">\n                                            <span class=\"network-icon\">\n                                                <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                                                    <path fill=\"currentColor\" d=\"M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5L4 8V6l8 5 8-5v2Z\"></path>\n                                                </svg>\n                                            </span>\n                                            <span class=\"network-name\">Email</span>\n                                        </label>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"col-12 form-group mb-3\" data-for=\"textarea\">\n                                <textarea name=\"textarea\" placeholder=\"Message\" data-form-field=\"textarea\" class=\"form-control\" required></textarea>\n                            </div>\n\n                            <!-- Champ pièce jointe pour Basin -->\n                            <div class=\"col-12 form-group mb-3\" data-for=\"attachment\">\n                                <label class=\"form-label\" for=\"attachment\">Pièce jointe (optionnel)</label>\n                                <input type=\"file\" name=\"attachment\" id=\"attachment\" class=\"form-control\" accept=\".jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.zip,.txt\">\n                            </div>\n\n                            <div class=\"col-12 form-group mb-4 consent-wrapper\" data-for=\"consent\">\n                                <label class=\"consent-label\" for=\"contact-consent\">\n                                    <input type=\"checkbox\" id=\"contact-consent\" name=\"consent\" data-form-field=\"consent\" required>\n                                    <span>\n                                        J'accepte que mes données (nom, identifiant ou e-mail, message, pièce jointe éventuelle) soient utilisées uniquement pour traiter ma demande, conformément à la\n                                        <a href=\"privacy.html\" target=\"_blank\" rel=\"noopener noreferrer\">Politique de confidentialité</a>.\n                                    </span>\n                                </label>\n                            </div>\n\n                            <div mbr-buttons=\"true\" mbr-theme-style=\"display-7\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\" class=\"col-lg-12 col-md-12 col-sm-12 align-center mbr-section-btn\">\n                                <button type=\"submit\" class=\"btn btn-primary display-7\" id=\"contact-submit\">\n                                    Envoyer ✉️\n                                </button>\n                            </div>\n                        </div>\n                    </form>\n                    <!-- /FORMULAIRE BASIN -->\n                </div>\n            </div>\n\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"image-wrapper\">\n                    <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/la20meute20normandemodif202-1256x888.webp\" alt=\"La Meute Normande\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v2Jn1UwHO0",
          "_anchor": "form03-c",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            "position": "relative",
            "border-radius": "20px 20px 0 0",
            "margin-top": "-20px",
            ".mbr-overlay": {
              "position": "absolute",
              "inset": "0",
              "pointer-events": "none"
            },
            ".footer-divider": {
              "width": "100%",
              "height": "1px",
              "background": "linear-gradient(90deg, transparent, #38bdf8, #f97316, #a855f7, transparent)",
              "margin-bottom": "0.85rem"
            },
            ".container": {
              "position": "relative",
              "z-index": "2",
              "text-align": "center"
            },
            ".footer-credits": {
              "margin-bottom": "0.5rem"
            },
            ".footer-credits .mbr-text": {
              "color": "rgba(255, 255, 255, 0.65)",
              "font-size": "0.92rem",
              "margin": "0"
            },
            ".footer-link": {
              "text-decoration": "none",
              "font-weight": "600",
              "transition": "all 0.25s ease",
              "position": "relative"
            },
            ".footer-link::after": {
              "content": "''",
              "position": "absolute",
              "bottom": "-2px",
              "left": "0",
              "width": "0",
              "height": "1.5px",
              "transition": "width 0.3s ease"
            },
            ".footer-link:hover::after": {
              "width": "100%"
            },
            ".footer-link-nitra": {
              "color": "#38bdf8"
            },
            ".footer-link-nitra:hover": {
              "color": "#7dd3fc",
              "text-shadow": "0 0 12px rgba(56, 189, 248, 0.4)"
            },
            ".footer-link-nitra::after": {
              "background": "#38bdf8"
            },
            ".footer-link-spyro": {
              "color": "#a855f7"
            },
            ".footer-link-spyro:hover": {
              "color": "#c084fc",
              "text-shadow": "0 0 12px rgba(168, 85, 247, 0.45)"
            },
            ".footer-link-spyro::after": {
              "background": "#a855f7"
            },
            ".footer-legal-links": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "flex-wrap": "wrap",
              "gap": "0.35rem",
              "margin-bottom": "0.4rem"
            },
            ".footer-legal-btn": {
              "background": "none",
              "border": "none",
              "color": "rgba(255, 255, 255, 0.45)",
              "font-size": "0.78rem",
              "font-weight": "500",
              "cursor": "pointer",
              "padding": "0.3rem 0.6rem",
              "border-radius": "6px",
              "transition": "all 0.25s ease",
              "letter-spacing": "0.02em"
            },
            ".footer-legal-btn:hover, .footer-legal-btn:focus": {
              "color": "rgba(255, 255, 255, 0.85)",
              "background": "rgba(255, 255, 255, 0.07)",
              "outline": "none"
            },
            ".footer-legal-sep": {
              "color": "rgba(255, 255, 255, 0.2)",
              "font-size": "0.6rem",
              "user-select": "none"
            },
            ".footer-copyright": {
              "padding-bottom": "0.25rem"
            },
            ".footer-copyright .mbr-text": {
              "color": "rgba(255, 255, 255, 0.3)",
              "font-size": "0.75rem",
              "margin": "0",
              "letter-spacing": "0.03em"
            },
            ".legal-modal": {
              "display": "none !important",
              "position": "fixed !important",
