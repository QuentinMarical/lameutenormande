        {
          "alias": false,
          "_styles": {
            "position": "relative",
            "background-color": "@cornerColor",
            ".module-inner": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)",
              "position": "relative",
              "border-radius": "0 0 30px 30px",
              "overflow": "hidden",
              "& when (@bg-type = \"color\")": {
                "background-color": "@bg-value"
              },
              "& when (@bg-type = \"image\")": {
                "background-image": "url(@bg-value)",
                "background-size": "cover",
                "background-position": "center center"
              }
            },
            ".mbr-overlay": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "pointer-events": "none"
            },
            ".row": {
              "gap": "2rem"
            },
            ".carousel-col": {
              "padding": "0"
            },
            ".artist-info-col": {
              "display": "flex",
              "align-items": "center"
            },
            ".artist-info-wrapper": {
              "padding": "2rem",
              "width": "100%"
            },
            ".artist-name": {
              "margin-bottom": "1.5rem",
              "background": "linear-gradient(90deg, #ff6eb4, #c471ed, #8b5cf6)",
              "-webkit-background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "background-clip": "text",
              "color": "#edefeb"
            },
            ".artist-description": {
              "margin-bottom": "2rem",
              "opacity": "0.9",
              "line-height": "1.7",
              "color": "#edefeb"
            },
            ".artist-btn-wrapper": {
              "margin-top": "1.5rem"
            },
            ".btn-artist-details": {
              "display": "inline-flex",
              "align-items": "center",
              "gap": "0.75rem",
              "padding": "1rem 2rem",
              "background-color": "#ff6eb4",
              "border": "none",
              "border-radius": "30px",
              "color": "#fff",
              "font-size": "1.1rem",
              "font-weight": "600",
              "cursor": "pointer",
              "transition": "all 0.3s ease",
              "box-shadow": "0 4px 20px rgba(0, 0, 0, 0.3)"
            },
            ".btn-artist-details:hover": {
              "transform": "translateY(-3px)",
              "box-shadow": "0 8px 30px rgba(255, 110, 180, 0.6)"
            },
            ".btn-artist-details .btn-icon": {
              "font-size": "1.3rem"
            },
            "@media (min-width: 992px)": {
              ".carousel": {
                "max-height": "(@carouselHeight * 100px)",
                "border-radius": "16px",
                "overflow": "hidden",
                "box-shadow": "0 8px 40px rgba(0, 0, 0, 0.4)",
                "img": {
                  "height": "(@carouselHeight * 100px)",
                  "object-fit": "cover"
                }
              }
            },
            "@media (max-width: 991px) and (min-width: 768px)": {
              ".carousel": {
                "min-height": "(@carouselHeight * 65px)",
                "border-radius": "12px",
                "overflow": "hidden",
                "img": {
                  "height": "(@carouselHeight * 65px)",
                  "object-fit": "cover"
                }
              }
            },
            "@media (max-width: 767px)": {
              ".carousel": {
                "min-height": "(@carouselHeight * 55px)",
                "border-radius": "12px",
                "overflow": "hidden",
                "img": {
                  "height": "(@carouselHeight * 55px)",
                  "object-fit": "cover"
                }
              },
              ".container .carousel-control": {
                "margin-bottom": "0"
              },
              ".artist-info-wrapper": {
