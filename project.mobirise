              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.08) inset, 0 16px 48px -8px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.04)",
              "& when (@transparent)": {
