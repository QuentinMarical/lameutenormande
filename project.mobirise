                  "object-fit": "cover"
                }
              }
            },
            "@media (max-width: 991px) and (min-width: 768px)": {
              ".carousel": {
                "min-height": "(@carouselHeight * 65px)",
                "border-radius": "12px",
                "overflow": "hidden",
                "img": {
                  "height": "(@carouselHeight * 65px)",
                  "object-fit": "cover"
                }
              }
            },
            "@media (max-width: 767px)": {
              ".carousel": {
                "min-height": "(@carouselHeight * 55px)",
                "border-radius": "12px",
                "overflow": "hidden",
                "img": {
                  "height": "(@carouselHeight * 55px)",
                  "object-fit": "cover"
                }
              },
              ".container .carousel-control": {
                "margin-bottom": "0"
              },
              ".artist-info-wrapper": {
                "padding": "1.5rem 1rem",
                "text-align": "center"
              },
              ".artist-name": {
                "font-size": "1.8rem !important"
              },
              ".artist-modal": {
                "padding": "0",
                "align-items": "flex-end"
              },
              ".artist-modal-content": {
                "max-width": "100%",
                "max-height": "88vh",
                "border-radius": "20px 20px 0 0 !important",
                "animation": "artistSheetUp 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
              },
              ".artist-modal.closing .artist-modal-content": {
                "animation": "artistSheetDown 0.25s ease forwards"
              },
              ".artist-modal-header": {
                "padding": "1.25rem 1.25rem 1rem"
              },
              ".artist-modal-body": {
                "padding": "1rem 1.25rem 1.75rem"
              },
              ".artist-modal-title": {
                "font-size": "1.2rem"
              }
            },
            ".carousel, .carousel-inner": {
              "display": "flex",
              "align-items": "center"
            },
            ".item-wrapper": {
              "width": "100%",
              "border-radius": "inherit"
            },
            ".carousel-clickable-img": {
              "cursor": "pointer",
              "transition": "transform 0.3s ease, filter 0.3s ease"
            },
            ".carousel-clickable-img:hover": {
              "transform": "scale(1.02)",
              "filter": "brightness(1.05)"
            },
            ".carousel-control:hover": {
              "background": "rgba(255, 110, 180, 0.9)",
              "color": "#fff"
            },
            ".mobi-mbri-arrow-next": {
              "margin-left": "5px"
            },
            ".mobi-mbri-arrow-prev": {
              "margin-right": "5px"
            },
            ".container .carousel-indicators": {
              "margin-bottom": "3px"
            },
            ".carousel-control": {
              "top": "50%",
              "width": "50px",
              "height": "50px",
              "margin-top": "-25px",
              "font-size": "18px",
              "background-color": "rgba(0, 0, 0, 0.5)",
              "border": "2px solid rgba(255, 255, 255, 0.5)",
              "border-radius": "50%",
              "transition": "all 0.3s ease",
              "opacity": "0 !important",
              "visibility": "hidden",
              "&.carousel-control-prev": {
                "left": "0",
                "margin-left": "1rem"
              },
              "&.carousel-control-next": {
                "right": "0",
                "margin-right": "1rem"
              },
              "@media (max-width: 767px)": {
                "top": "auto",
                "bottom": "1rem",
                "width": "40px",
                "height": "40px"
              }
            },
            ".carousel:hover .carousel-control, .carousel-col:hover .carousel-control": {
              "opacity": "1 !important",
              "visibility": "visible"
            },
            ".carousel-indicators": {
              "position": "absolute",
              "bottom": "0",
              "margin-bottom": "1rem !important",
              "li": {
                "max-width": "12px",
                "height": "12px",
                "width": "12px",
                "max-height": "12px",
                "margin": "3px",
                "background-color": "rgba(255, 255, 255, 0.4)",
                "border": "2px solid #fff",
                "border-radius": "50%",
                "opacity": "0.6",
                "transition": "all 0.3s",
                "&.active, &:hover": {
                  "opacity": "1",
                  "background-color": "#ff6eb4"
                },
                "&::after, &::before": {
                  "content": "none"
                }
              },
              "@media (max-width: 768px)": {
                "display": "none !important"
              }
            },
            "body.modal-open": {
              "overflow": "hidden"
            },
            ".artist-modal": {
              "display": "none !important",
              "position": "fixed",
              "z-index": "2147483647 !important",
              "inset": "0 !important",
              "width": "100vw !important",
              "height": "100vh !important",
              "align-items": "center",
              "justify-content": "center",
              "padding": "1.25rem",
              "box-sizing": "border-box",
              "isolation": "isolate !important"
            },
            ".artist-modal.show": {
              "display": "flex !important"
            },
            ".artist-modal-overlay": {
              "position": "absolute",
              "inset": "0",
              "background": "rgba(10, 5, 20, 0.82)",
              "-webkit-backdrop-filter": "blur(8px)",
              "backdrop-filter": "blur(8px)",
              "z-index": "0",
              "cursor": "pointer"
            },
            ".artist-modal-content": {
              "position": "relative",
              "z-index": "1",
              "width": "100%",
              "max-width": "860px",
              "max-height": "calc(100vh - 2.5rem)",
              "border-radius": "20px !important",
              "margin": "0 auto",
              "padding": "0",
              "background": "linear-gradient(155deg, #1e1430 0%, #120d22 60%, #0d0a1c 100%)",
              "border": "1px solid rgba(255, 110, 180, 0.18)",
              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.06), 0 24px 60px rgba(0, 0, 0, 0.7), 0 0 80px rgba(196, 113, 237, 0.12)",
              "overflow-y": "auto",
              "overflow-x": "hidden",
              "-webkit-overflow-scrolling": "touch",
              "display": "flex",
              "flex-direction": "column",
              "animation": "artistFadeIn 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
              "scrollbar-width": "thin",
              "scrollbar-color": "rgba(255, 110, 180, 0.45) transparent"
            },
            ".artist-modal-content::-webkit-scrollbar": {
              "width": "6px"
            },
            ".artist-modal-content::-webkit-scrollbar-track": {
              "background": "transparent"
            },
            ".artist-modal-content::-webkit-scrollbar-thumb": {
              "background": "rgba(255, 110, 180, 0.45)",
              "border-radius": "3px"
            },
            ".artist-modal-content::-webkit-scrollbar-thumb:hover": {
              "background": "rgba(255, 110, 180, 0.7)"
            },
            "@keyframes artistFadeIn": {
              "from": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              },
              "to": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              }
            },
            "@keyframes artistFadeOut": {
              "from": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              },
              "to": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              }
            },
            ".artist-modal.closing .artist-modal-content": {
              "animation": "artistFadeOut 0.25s ease forwards"
            },
            ".artist-modal-header": {
              "display": "flex",
              "align-items": "flex-start",
              "justify-content": "space-between",
              "padding": "1.75rem 2rem 1.25rem",
              "border-bottom": "1px solid rgba(255, 255, 255, 0.1)",
              "background": "linear-gradient(90deg, rgba(233, 30, 99, 0.08), rgba(196, 113, 237, 0.06), transparent)",
              "gap": "1rem"
            },
            ".artist-modal-close": {
              "flex-shrink": "0",
              "background": "rgba(255, 255, 255, 0.1)",
              "border": "1px solid rgba(255, 255, 255, 0.15)",
