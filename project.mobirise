          "_JSplaceholders": [
            "<script>\n        'use strict';\n\n        (function () {\n            /* ============================================================\n               0. Portée du module (multi-instances safe : pas d'ID global)\n               ============================================================ */\n            var SCRIPT = document.currentScript;\n            var SECTION = SCRIPT ? SCRIPT.closest('section') : null;\n            if (!SECTION) SECTION = document.querySelector('.section-calendar-v2');\n            var ROOT = SECTION ? SECTION.querySelector('.mcal') : null;\n            var DIALOG = SECTION ? SECTION.querySelector('.mcal-dialog') : null;\n            if (!ROOT || ROOT.dataset.mcalInit === '1') return;\n            ROOT.dataset.mcalInit = '1';\n\n            const q = (sel) => ROOT.querySelector(sel);\n\n            /* ============================================================\n               1. Configuration (site publié : data-attributes remplacés\n                  par Mobirise ; éditeur : lecture des inputs mbr-parameters)\n               ============================================================ */\n            const DEFAULT_ICAL_URL = 'https://raw.githubusercontent.com/QuentinMarical/lameutenormande/refs/heads/main/events.ics';\n\n            function paramFlag(attr, inputName) {\n                const v = ROOT.getAttribute(attr);\n                if (v !== null && v.indexOf('{{') === -1) return v !== 'false';\n                const input = SECTION.querySelector('input[name=\"' + inputName + '\"]');\n                return input ? !!input.checked : true;\n            }\n\n            const cfg = {\n                allowMonth: paramFlag('data-allow-calendar-view', 'allowCalendarView'),\n                allowList: paramFlag('data-allow-list-view', 'allowListView'),\n                mobileList: paramFlag('data-default-list-view-mobile', 'defaultListViewMobile'),\n                icalUrl: (function () {\n                    const a = (ROOT.getAttribute('data-ical-source') || '').trim();\n                    if (a && a.indexOf('{{') === -1) return a;\n                    const input = SECTION.querySelector('input[name=\"icalUrl\"]');\n                    const v = input ? (input.value || input.getAttribute('value') || '').trim() : '';\n                    if (v && v.indexOf('{{') === -1) return v;\n                    return DEFAULT_ICAL_URL;\n                })()\n            };\n\n            const LS = {\n                filters: 'mcal_filters_v1',\n                keep: 'mcal_filters_keep_v1',\n                geo: 'mcal_geo_v1',\n                ics: (url) => 'mcal_ics_v1_' + encodeURIComponent(url)\n            };\n\n            /* ============================================================\n               2. Utilitaires dates / texte (Intl partout)\n               ============================================================ */\n            const DAY_MS = 864e5;\n            const startOfDay = (d) => new Date(d.getFullYear(), d.getMonth(), d.getDate());\n            const startOfMonth = (d) => new Date(d.getFullYear(), d.getMonth(), 1);\n            const addDays = (d, n) => { const x = new Date(d); x.setDate(x.getDate() + n); return x; };\n            const diffDays = (a, b) => Math.round((startOfDay(b) - startOfDay(a)) / DAY_MS);\n            const mondayOf = (d) => addDays(startOfDay(d), -((d.getDay() + 6) % 7));\n            const lastDayOf = (ev) => startOfDay(new Date(ev.end.getTime() - 1));\n            const cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);\n            const firstLine = (s) => String(s || '').split(/\\r\\n|\\r|\\n/)[0].trim();\n\n            const FMT = {\n                monthYear: new Intl.DateTimeFormat('fr-FR', { month: 'long', year: 'numeric' }),\n                dayFull: new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }),\n                dayHeader: new Intl.DateTimeFormat('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' }),\n                dayShort: new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'short' }),\n                monthTag: new Intl.DateTimeFormat('fr-FR', { month: 'short' }),\n                time: new Intl.DateTimeFormat('fr-FR', { hour: '2-digit', minute: '2-digit' }),\n                dateMed: new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })\n            };\n            const RELF = ('RelativeTimeFormat' in Intl) ? new Intl.RelativeTimeFormat('fr', { numeric: 'auto' }) : null;\n\n            const esc = (v) => String(v == null ? '' : v).replace(/[&<>\"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;', \"'\": '&#39;' }[c]));\n            const multiline = (v) => esc(v).replace(/\\r\\n?|\\n/g, '<br>');\n            const safeUrl = (u) => { u = String(u || '').trim(); return /^https?:\\/\\//i.test(u) ? u : ''; };\n            const normText = (v) => String(v || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');\n            const debounce = (fn, ms) => { let t; return function () { clearTimeout(t); const a = arguments; t = setTimeout(() => fn.apply(null, a), ms); }; };\n\n            const isMobile = () => window.innerWidth <= 768;\n            const isPortrait = () => window.matchMedia('(orientation: portrait)').matches;\n\n            function statusOf(ev, now) {\n                const t = (now || new Date()).getTime();\n                if (ev.end.getTime() <= t) return 'past';\n                if (ev.start.getTime() <= t) return 'now';\n                return 'future';\n            }\n\n            function countdownLabel(ev, now) {\n                now = now || new Date();\n                const st = statusOf(ev, now);\n                if (st === 'now') return 'En cours';\n                if (st === 'future') {\n                    const ms = ev.start.getTime() - now.getTime();\n                    if (ms < DAY_MS) return 'Dans ' + Math.max(1, Math.ceil(ms / 36e5)) + ' h';\n                    const days = Math.ceil(ms / DAY_MS);\n                    return RELF ? cap(RELF.format(days, 'day')) : 'Dans ' + days + ' jours';\n                }\n                const since = Math.max(1, diffDays(lastDayOf(ev), startOfDay(now)));\n                return 'Terminé ' + (RELF ? RELF.format(-since, 'day') : 'il y a ' + since + ' j');\n            }\n\n            /* ============================================================\n               3. État\n               ============================================================ */\n            const state = {\n                events: [],       // tous les événements normalisés\n                filtered: [],     // après filtres\n                cursor: startOfMonth(new Date()),\n                view: 'month',    // 'month' | 'list' | 'cards'\n                prevView: 'month',\n                cardsPast: false,\n                uiReady: false,\n                userChoseView: false,\n                suggestIndex: -1,\n                modalEvent: null\n            };\n\n            /* ============================================================\n               4. Chargement ical.js (ESM, fallback classique)\n               ============================================================ */\n            let ICALLib = null;\n\n            async function loadIcalLib() {\n                if (ICALLib) return ICALLib;\n                if (window.ICAL) { ICALLib = window.ICAL; return ICALLib; }\n                const esmSources = [\n                    'https://cdn.jsdelivr.net/npm/ical.js@2/+esm',\n                    'https://unpkg.com/ical.js@2/dist/ical.min.js'\n                ];\n                for (const src of esmSources) {\n                    try {\n                        const mod = await import(src);\n                        ICALLib = mod.default || mod.ICAL || mod;\n                        if (ICALLib && ICALLib.parse) return ICALLib;\n                    } catch (e) { /* source suivante */ }\n                }\n                // Dernier recours : build classique (expose window.ICAL)\n                await new Promise((resolve, reject) => {\n                    const s = document.createElement('script');\n                    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/ical.js/1.5.0/ical.min.js';\n                    s.onload = resolve;\n                    s.onerror = () => reject(new Error('CDN inaccessible'));\n                    document.head.appendChild(s);\n                });\n                if (!window.ICAL) throw new Error('ical.js indisponible');\n                ICALLib = window.ICAL;\n                return ICALLib;\n            }\n\n            /* ============================================================\n               5. Récupération du flux (local → direct → proxy, timeout)\n               ============================================================ */\n            async function fetchIcsText(url) {\n                const candidates = [];\n                if (/^https?:$/.test(location.protocol)) candidates.push(new URL('/events.ics', location.origin).href);\n                candidates.push(url);\n                candidates.push('https://api.allorigins.win/raw?url=' + encodeURIComponent(url));\n\n                let lastErr = null;\n                for (const cu of candidates) {\n                    try {\n                        const opts = { headers: { 'Accept': 'text/calendar, text/plain, */*' }, cache: 'no-store' };\n                        if (typeof AbortSignal !== 'undefined' && AbortSignal.timeout) opts.signal = AbortSignal.timeout(15000);\n                        const r = await fetch(cu, opts);\n                        if (!r.ok) { lastErr = new Error('HTTP ' + r.status); continue; }\n                        const t = await r.text();\n                        if (t && t.indexOf('BEGIN:VCALENDAR') !== -1) return t;\n                        lastErr = new Error('Réponse invalide (pas un fichier iCal)');\n                    } catch (e) { lastErr = e; }\n                }\n                throw lastErr || new Error('Chargement impossible');\n            }\n\n            /* ============================================================\n               6. Parsing + normalisation des événements\n               ------------------------------------------------------------\n               - DTEND exclusif respecté (RFC 5545) pour VALUE=DATE\n               - \"Fausses journées entières\" Zoho (00:00 → 23:59 locale)\n                 converties en vraies journées entières\n               - Titres nettoyés (heures parasites), détection 🦊\n               - Récurrences étendues sur [année-1 ; année+2]\n               ============================================================ */\n            function normalizeEvent(icalEv, id, start, end, isDateOnly) {\n                let allDay = isDateOnly;\n                if (isDateOnly) {\n                    start = startOfDay(start);\n                    end = end && end > start ? startOfDay(end) : addDays(start, 1);\n                    if (end <= start) end = addDays(start, 1);\n                } else {\n                    const pseudo = start.getHours() === 0 && start.getMinutes() <= 1 &&\n                        end && end.getHours() === 23 && end.getMinutes() >= 59;\n                    if (pseudo) {\n                        allDay = true;\n                        start = startOfDay(start);\n                        end = addDays(startOfDay(end), 1);\n                    } else if (!end || end <= start) {\n                        end = new Date(start.getTime() + 36e5);\n                    }\n                }\n\n                const rawTitle = icalEv.summary || 'Sans titre';\n                const title = rawTitle\n                    .replace(/\\s*\\b\\d{1,2}h(\\d{2})?\\b\\s*/gi, ' ')\n                    .replace(/\\s*\\b\\d{1,2}:\\d{2}\\b.*$/i, '')\n                    .replace(/\\s+/g, ' ').trim() || 'Sans titre';\n\n                let url = '';\n                try {\n                    url = icalEv.component.getFirstPropertyValue('url') || icalEv.component.getFirstPropertyValue('attach') || '';\n                } catch (e) { }\n\n                return {\n                    id: id,\n                    uid: icalEv.uid || id,\n                    title: title,\n                    start: start,\n                    end: end,\n                    allDay: allDay,\n                    description: icalEv.description || '',\n                    location: icalEv.location || '',\n                    url: String(url || ''),\n                    isFurry: /\\u{1F98A}/u.test(rawTitle),\n                    deptCode: null\n                };\n            }\n\n            function parseIcs(text) {\n                const jcal = ICALLib.parse(text);\n                const comp = new ICALLib.Component(jcal);\n\n                // Enregistrement des fuseaux horaires du flux (Google/Outlook…)\n                try {\n                    comp.getAllSubcomponents('vtimezone').forEach((vt) => {\n                        try { ICALLib.TimezoneService.register(new ICALLib.Timezone(vt)); } catch (e) { }\n                    });\n                } catch (e) { }\n\n                const vevents = comp.getAllSubcomponents('vevent');\n\n                // Occurrences remplacées (RECURRENCE-ID)\n                const overrides = new Set();\n                vevents.forEach((v) => {\n                    if (!v.getFirstProperty('recurrence-id')) return;\n                    try {\n                        const e = new ICALLib.Event(v);\n                        const rid = e.recurrenceId ? e.recurrenceId.toJSDate().toISOString() : '';\n                        overrides.add((e.uid || '') + '_' + rid);\n                    } catch (err) { }\n                });\n\n                const out = [];\n                const seen = new Set();\n\n                vevents.forEach((vevent, idx) => {\n                    try {\n                        const ev = new ICALLib.Event(vevent);\n                        if (!ev.startDate) return;\n                        const isDateOnly = !!ev.startDate.isDate;\n\n                        const push = (s, e) => {\n                            const key = (ev.uid || 'evt' + idx) + '_' + s.toISOString();\n                            if (seen.has(key)) return;\n                            seen.add(key);\n                            out.push(normalizeEvent(ev, key, s, e, isDateOnly));\n                        };\n\n                        if (ev.isRecurring()) {\n                            const now = new Date();\n                            const rangeStart = new Date(now.getFullYear() - 1, 0, 1);\n                            const rangeEnd = new Date(now.getFullYear() + 2, 11, 31);\n                            const iter = ev.iterator();\n                            let next, guard = 0;\n                            while ((next = iter.next()) && guard++ < 500) {\n                                const s = next.toJSDate();\n                                if (s > rangeEnd) break;\n                                if (s < rangeStart) continue;\n                                if (overrides.has((ev.uid || '') + '_' + s.toISOString())) continue;\n                                let e;\n                                if (ev.endDate) {\n                                    const dur = ev.endDate.subtractDate(ev.startDate);\n                                    const occEnd = next.clone();\n                                    occEnd.addDuration(dur);\n                                    e = occEnd.toJSDate();\n                                } else {\n                                    e = new Date(s);\n                                }\n                                push(s, e);\n                            }\n                        } else {\n                            const s = ev.startDate.toJSDate();\n                            push(s, ev.endDate ? ev.endDate.toJSDate() : new Date(s));\n                        }\n                    } catch (err) {\n                        console.warn('[calendrier] évènement ignoré :', err && err.message);\n                    }\n                });\n\n                out.sort((a, b) => a.start - b.start);\n                return out;\n            }\n\n            /* ============================================================\n               7. Régions / départements + géocodage (data.gouv, cache 30 j)\n               ============================================================ */\n            const REGIONS = {\n                'Auvergne-Rhône-Alpes': ['01 Ain', '03 Allier', '07 Ardèche', '15 Cantal', '26 Drôme', '38 Isère', '42 Loire', '43 Haute-Loire', '63 Puy-de-Dôme', '69 Rhône', '73 Savoie', '74 Haute-Savoie'],\n                'Bourgogne-Franche-Comté': ['21 Côte-d\\'Or', '25 Doubs', '39 Jura', '58 Nièvre', '70 Haute-Saône', '71 Saône-et-Loire', '89 Yonne', '90 Territoire de Belfort'],\n                'Bretagne': ['22 Côtes-d\\'Armor', '29 Finistère', '35 Ille-et-Vilaine', '56 Morbihan'],\n                'Centre-Val de Loire': ['18 Cher', '28 Eure-et-Loir', '36 Indre', '37 Indre-et-Loire', '41 Loir-et-Cher', '45 Loiret'],\n                'Corse': ['2A Corse-du-Sud', '2B Haute-Corse'],\n                'Grand Est': ['08 Ardennes', '10 Aube', '51 Marne', '52 Haute-Marne', '54 Meurthe-et-Moselle', '55 Meuse', '57 Moselle', '67 Bas-Rhin', '68 Haut-Rhin', '88 Vosges'],\n                'Hauts-de-France': ['02 Aisne', '59 Nord', '60 Oise', '62 Pas-de-Calais', '80 Somme'],\n                'Île-de-France': ['75 Paris', '77 Seine-et-Marne', '78 Yvelines', '91 Essonne', '92 Hauts-de-Seine', '93 Seine-Saint-Denis', '94 Val-de-Marne', '95 Val-d\\'Oise'],\n                'Normandie': ['14 Calvados', '27 Eure', '50 Manche', '61 Orne', '76 Seine-Maritime'],\n                'Nouvelle-Aquitaine': ['16 Charente', '17 Charente-Maritime', '19 Corrèze', '23 Creuse', '24 Dordogne', '33 Gironde', '40 Landes', '47 Lot-et-Garonne', '64 Pyrénées-Atlantiques', '79 Deux-Sèvres', '86 Vienne', '87 Haute-Vienne'],\n                'Occitanie': ['09 Ariège', '11 Aude', '12 Aveyron', '30 Gard', '31 Haute-Garonne', '32 Gers', '34 Hérault', '46 Lot', '48 Lozère', '65 Hautes-Pyrénées', '66 Pyrénées-Orientales', '81 Tarn', '82 Tarn-et-Garonne'],\n                'Pays de la Loire': ['44 Loire-Atlantique', '49 Maine-et-Loire', '53 Mayenne', '72 Sarthe', '85 Vendée'],\n                'Provence-Alpes-Côte d\\'Azur': ['04 Alpes-de-Haute-Provence', '05 Hautes-Alpes', '06 Alpes-Maritimes', '13 Bouches-du-Rhône', '83 Var', '84 Vaucluse']\n            };\n\n            const OLD_REGIONS = {\n                'Auvergne-Rhône-Alpes': { 'Auvergne': ['03', '15', '43', '63'], 'Rhône-Alpes': ['01', '07', '26', '38', '42', '69', '73', '74'] },\n                'Bourgogne-Franche-Comté': { 'Bourgogne': ['21', '58', '71', '89'], 'Franche-Comté': ['25', '39', '70', '90'] },\n                'Grand Est': { 'Alsace': ['67', '68'], 'Champagne-Ardenne': ['08', '10', '51', '52'], 'Lorraine': ['54', '55', '57', '88'] },\n                'Hauts-de-France': { 'Nord-Pas-de-Calais': ['59', '62'], 'Picardie': ['02', '60', '80'] },\n                'Normandie': { 'Basse-Normandie': ['14', '50', '61'], 'Haute-Normandie': ['27', '76'] },\n                'Nouvelle-Aquitaine': { 'Aquitaine': ['24', '33', '40', '47', '64'], 'Limousin': ['19', '23', '87'], 'Poitou-Charentes': ['16', '17', '79', '86'] },\n                'Occitanie': { 'Languedoc-Roussillon': ['11', '30', '34', '48', '66'], 'Midi-Pyrénées': ['09', '12', '31', '32', '46', '65', '81', '82'] }\n            };\n\n            const deptCodeOf = (s) => s.split(' ')[0];\n            const DEPT_TO_REGION = {};\n            const DEPT_TO_OLD = {};\n            Object.keys(REGIONS).forEach((r) => REGIONS[r].forEach((d) => { DEPT_TO_REGION[deptCodeOf(d)] = r; }));\n            Object.keys(OLD_REGIONS).forEach((r) => Object.keys(OLD_REGIONS[r]).forEach((o) => OLD_REGIONS[r][o].forEach((c) => { DEPT_TO_OLD[c] = o; })));\n\n            function deptFromPostal(postal) {\n                if (postal.slice(0, 2) === '20') return parseInt(postal, 10) < 20200 ? '2A' : '2B';\n                if (postal.slice(0, 2) === '97') return postal.slice(0, 3);\n                return postal.slice(0, 2);\n            }\n\n            function deptFromText(loc) {\n                const m = String(loc || '').match(/\\b(\\d{5})\\b/);\n                return m ? deptFromPostal(m[1]) : null;\n            }\n\n            function cityFromLocation(loc) {\n                if (!loc) return null;\n                const cleaned = String(loc)\n                    .replace(/\\b\\d{5}\\b/g, '')\n                    .replace(/\\b(France|FR)\\b/gi, '')\n                    .replace(/\\b\\d{1,4}\\s*(rue|avenue|boulevard|allée|chemin|route|place|impasse|bd|av)\\b/gi, '')\n                    .replace(/\\b(rue|avenue|boulevard|allée|chemin|route|place|impasse|bd|av)\\s+[^\\s,]+/gi, '')\n                    .replace(/[,;]/g, ' ')\n                    .replace(/\\s+/g, ' ')\n                    .trim();\n                const parts = cleaned.split(/\\s{2,}|\\s+-\\s+/).map((s) => s.trim()).filter((s) => s.length > 1);\n                if (parts.length) return parts[parts.length - 1];\n                return cleaned.length > 1 ? cleaned : null;\n            }\n\n            const geoCache = (function () {\n                try {\n                    const stored = JSON.parse(localStorage.getItem(LS.geo));\n                    if (stored && stored.ts && Date.now() - stored.ts < 30 * DAY_MS && stored.entries) return stored.entries;\n                } catch (e) { }\n                return {};\n            })();\n\n            const saveGeoCache = debounce(() => {\n                try { localStorage.setItem(LS.geo, JSON.stringify({ ts: Date.now(), entries: geoCache })); } catch (e) { }\n            }, 400);\n\n            async function geocodeCity(query) {\n                if (!query || query.length < 2) return null;\n                const key = query.toLowerCase().trim();\n                if (key in geoCache) return geoCache[key];\n                let code = null;\n                try {\n                    const r = await fetch('https://api-adresse.data.gouv.fr/search/?q=' + encodeURIComponent(query) + '&limit=1&type=municipality');\n                    if (r.ok) {\n                        const data = await r.json();\n                        const props = data.features && data.features[0] && data.features[0].properties;\n                        if (props) {\n                            if (props.postcode && props.postcode.length >= 5) code = deptFromPostal(props.postcode);\n                            else if (props.citycode && props.citycode.length >= 2) code = deptFromPostal(props.citycode);\n                        }\n                    }\n                } catch (e) { }\n                geoCache[key] = code;\n                saveGeoCache();\n                return code;\n            }\n\n            const eventDept = (ev) => ev.deptCode || deptFromText(ev.location);\n\n            // Résolution en arrière-plan (ne bloque pas le premier rendu)\n            async function resolveLocations(events) {\n                const pending = events.filter((ev) => {\n                    const fromPostal = deptFromText(ev.location);\n                    if (fromPostal) { ev.deptCode = fromPostal; return false; }\n                    return !!firstLine(ev.location);\n                });\n                let changed = false;\n                for (let i = 0; i < pending.length; i += 5) {\n                    await Promise.all(pending.slice(i, i + 5).map(async (ev) => {\n                        const city = cityFromLocation(ev.location);\n                        let code = city ? await geocodeCity(city) : null;\n                        if (!code) code = await geocodeCity(ev.location);\n                        if (code) { ev.deptCode = code; changed = true; }\n                    }));\n                }\n                return changed;\n            }\n\n            /* ============================================================\n               8. Filtres + persistance\n               ============================================================ */\n            function populateRegions() {\n                const sel = q('.mcal-f-region');\n                Object.keys(REGIONS).forEach((r) => {\n                    const o = document.createElement('option');\n                    o.value = 'region:' + r;\n                    o.textContent = r;\n                    sel.appendChild(o);\n                });\n            }\n\n            function populateDetail(regionName) {\n                const wrap = q('.mcal-fdetail');\n                const sel = q('.mcal-f-detail');\n                sel.innerHTML = '<option value=\"all\" selected>Toute la région</option>';\n                if (!regionName) { wrap.classList.remove('visible'); return; }\n                const depts = REGIONS[regionName] || [];\n                const olds = OLD_REGIONS[regionName];\n                if (olds) {\n                    Object.keys(olds).forEach((oldName) => {\n                        const oh = document.createElement('option');\n                        oh.value = 'oldregion:' + oldName;\n                        oh.textContent = '▹ ' + oldName;\n                        oh.className = 'opt-oldregion';\n                        sel.appendChild(oh);\n                        depts.filter((d) => olds[oldName].indexOf(deptCodeOf(d)) !== -1).forEach((d) => {\n                            const o = document.createElement('option');\n                            o.value = 'dept:' + deptCodeOf(d);\n                            o.textContent = '   ' + d;\n                            o.className = 'opt-dept';\n                            sel.appendChild(o);\n                        });\n                    });\n                } else {\n                    depts.forEach((d) => {\n                        const o = document.createElement('option');\n                        o.value = 'dept:' + deptCodeOf(d);\n                        o.textContent = d;\n                        o.className = 'opt-dept';\n                        sel.appendChild(o);\n                    });\n                }\n                wrap.classList.add('visible');\n            }\n\n            function readFilters() {\n                return {\n                    type: q('.mcal-f-type').value,\n                    region: q('.mcal-f-region').value,\n                    detail: q('.mcal-f-detail').value,\n                    search: normText(q('.mcal-f-search').value).trim()\n                };\n            }\n\n            function filterEvents() {\n                const f = readFilters();\n                return state.events.filter((ev) => {\n                    if (f.search) {\n                        const hay = normText(ev.title + ' ' + ev.location + ' ' + ev.description);\n                        if (hay.indexOf(f.search) === -1) return false;\n                    }\n                    if (f.type === 'furry' && !ev.isFurry) return false;\n                    if (f.type === 'standard' && ev.isFurry) return false;\n                    if (f.region !== 'all') {\n                        const code = eventDept(ev);\n                        if (!code) return false;\n                        if (DEPT_TO_REGION[code] !== f.region.slice(7)) return false;\n                        if (f.detail !== 'all') {\n                            if (f.detail.indexOf('dept:') === 0 && code !== f.detail.slice(5)) return false;\n                            if (f.detail.indexOf('oldregion:') === 0 && DEPT_TO_OLD[code] !== f.detail.slice(10)) return false;\n                        }\n                    }\n                    return true;\n                });\n            }\n\n            function persistFilters() {\n                const keep = q('.mcal-f-save');\n                if (!keep || !keep.checked) return;\n                try {\n                    localStorage.setItem(LS.filters, JSON.stringify({\n                        type: q('.mcal-f-type').value,\n                        region: q('.mcal-f-region').value,\n                        detail: q('.mcal-f-detail').value,\n                        search: q('.mcal-f-search').value\n                    }));\n                    localStorage.setItem(LS.keep, 'true');\n                } catch (e) { }\n            }\n\n            function restoreFilters() {\n                if (localStorage.getItem(LS.keep) !== 'true') return false;\n                const keep = q('.mcal-f-save');\n                if (keep) keep.checked = true;\n                try {\n                    const s = JSON.parse(localStorage.getItem(LS.filters));\n                    if (!s) return false;\n                    if (typeof s.search === 'string') q('.mcal-f-search').value = s.search;\n                    if (s.type) q('.mcal-f-type').value = s.type;\n                    if (s.region) {\n                        q('.mcal-f-region').value = s.region;\n                        if (s.region !== 'all') {\n                            populateDetail(s.region.slice(7));\n                            if (s.detail) q('.mcal-f-detail').value = s.detail;\n                        }\n                    }\n                    syncSearchClear();\n                    return true;\n                } catch (e) { return false; }\n            }\n\n            function applyFilters() {\n                persistFilters();\n                state.filtered = filterEvents();\n\n                // Recherche active sans résultat dans le mois affiché :\n                // sauter au mois du premier résultat (à venir de préférence)\n                const raw = q('.mcal-f-search').value.trim();\n                if (raw.length > 1 && state.filtered.length) {\n                    const mStart = state.cursor;\n                    const mEnd = new Date(state.cursor.getFullYear(), state.cursor.getMonth() + 1, 1);\n                    const inMonth = state.filtered.some((ev) => ev.start < mEnd && ev.end > mStart);\n                    if (!inMonth) {\n                        const now = new Date();\n                        const target = state.filtered.find((ev) => ev.end >= now) || state.filtered[state.filtered.length - 1];\n                        if (target) state.cursor = startOfMonth(target.start);\n                    }\n                }\n                render();\n            }\n\n            /* ============================================================\n               9. Suggestions de recherche\n               ============================================================ */\n            function buildMatches(query) {\n                const nq = normText(query).trim();\n                if (!nq) return [];\n                const now = new Date();\n                const scored = [];\n                state.events.forEach((ev) => {\n                    const nTitle = normText(ev.title);\n                    let score = -1;\n                    if (nTitle.indexOf(nq) === 0) score = 0;\n                    else if (nTitle.indexOf(nq) !== -1) score = 1;\n                    else if (normText(ev.location).indexOf(nq) !== -1) score = 2;\n                    else if (normText(ev.description).indexOf(nq) !== -1) score = 3;\n                    if (score < 0) return;\n                    scored.push({ ev: ev, score: score, isPast: statusOf(ev, now) === 'past' });\n                });\n                scored.sort((a, b) => {\n                    if (a.isPast !== b.isPast) return a.isPast ? 1 : -1;\n                    if (a.score !== b.score) return a.score - b.score;\n                    return a.isPast ? b.ev.start - a.ev.start : a.ev.start - b.ev.start;\n                });\n                return scored.slice(0, 8);\n            }\n\n            function hideSuggest() {\n                const box = q('.mcal-suggest');\n                box.hidden = true;\n                box.innerHTML = '';\n                state.suggestIndex = -1;\n            }\n\n            function renderSuggest() {\n                const box = q('.mcal-suggest');\n                const input = q('.mcal-f-search');\n                const raw = input.value.trim();\n                if (raw.length < 2) { hideSuggest(); return; }\n                const matches = buildMatches(raw);\n                state.suggestIndex = -1;\n                if (!matches.length) {\n                    box.innerHTML = '<div class=\"mcal-suggest-empty\">Aucun événement trouvé</div>';\n                    box.hidden = false;\n                    return;\n                }\n                let html = '<div class=\"mcal-suggest-count\">' + matches.length + ' résultat' + (matches.length > 1 ? 's' : '') + ' — cliquez pour ouvrir</div>';\n                html += matches.map((m, i) =>\n                    '<button type=\"button\" class=\"mcal-suggest-item' + (m.isPast ? ' is-past' : '') + '\" data-suggest-index=\"' + i + '\" role=\"option\">' +\n                    '<span class=\"mcal-suggest-title\">' + esc(m.ev.title) + '</span>' +\n                    '<span class=\"mcal-suggest-date\">' + esc(FMT.dateMed.format(m.ev.start)) + '</span>' +\n                    '</button>').join('');\n                box.innerHTML = html;\n                box.hidden = false;\n                box.querySelectorAll('[data-suggest-index]').forEach((btn) => {\n                    btn.addEventListener('click', () => {\n                        const m = matches[parseInt(btn.getAttribute('data-suggest-index'), 10)];\n                        if (m) { hideSuggest(); openModal(m.ev); }\n                    });\n                });\n            }\n\n            function suggestKeydown(e) {\n                const box = q('.mcal-suggest');\n                if (box.hidden) return;\n                const items = Array.prototype.slice.call(box.querySelectorAll('.mcal-suggest-item'));\n                if (e.key === 'Escape') { e.stopPropagation(); hideSuggest(); return; }\n                if (!items.length) return;\n                if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {\n                    e.preventDefault();\n                    state.suggestIndex = e.key === 'ArrowDown'\n                        ? (state.suggestIndex + 1) % items.length\n                        : (state.suggestIndex <= 0 ? items.length - 1 : state.suggestIndex - 1);\n                    items.forEach((el, i) => el.classList.toggle('is-active', i === state.suggestIndex));\n                    items[state.suggestIndex].scrollIntoView({ block: 'nearest' });\n                } else if (e.key === 'Enter' && state.suggestIndex >= 0 && items[state.suggestIndex]) {\n                    e.preventDefault();\n                    items[state.suggestIndex].click();\n                }\n            }\n\n            /* ============================================================\n               10. Rendu des vues\n               ============================================================ */\n            function render() {\n                q('.mcal-month-label').textContent = cap(FMT.monthYear.format(state.cursor));\n                q('.mcal-view-month').hidden = state.view !== 'month';\n                q('.mcal-view-list').hidden = state.view !== 'list';\n                q('.mcal-view-cards').hidden = state.view !== 'cards';\n                const tbtn = q('.mcal-btn-toggle');\n                if (tbtn) tbtn.textContent = state.view === 'month' ? 'Vue Liste' : 'Vue Calendrier';\n                if (state.view === 'month') renderMonth();\n                else if (state.view === 'list') renderList();\n                else renderCards();\n            }\n\n            function renderMonth() {\n                const el = q('.mcal-view-month');\n                const y = state.cursor.getFullYear();\n                const m = state.cursor.getMonth();\n                const first = new Date(y, m, 1);\n                const last = new Date(y, m + 1, 0);\n                const today = startOfDay(new Date());\n                const now = new Date();\n\n                const evs = state.filtered.slice().sort((a, b) =>\n                    a.start - b.start || (b.end - b.start) - (a.end - a.start));\n\n                let wk = mondayOf(first);\n                const weeks = [];\n                while (wk <= last) {\n                    const wkEnd = addDays(wk, 6);\n                    let nums = '';\n                    let bgs = '';\n                    for (let i = 0; i < 7; i++) {\n                        const d = addDays(wk, i);\n                        const out = d.getMonth() !== m;\n                        const isToday = d.getTime() === today.getTime();\n                        bgs += '<div class=\"mcal-daybg' + (out ? ' is-out' : '') + (isToday ? ' is-today' : '') + '\"></div>';\n                        nums += '<div class=\"mcal-daynum' + (isToday ? ' is-today' : '') + '\" style=\"grid-column:' + (i + 1) + ';grid-row:1\">' + (out ? '' : '<span>' + d.getDate() + '</span>') + '</div>';\n                    }\n                    const lanes = [];\n                    let bars = '';\n                    evs.forEach((ev) => {\n                        const s = startOfDay(ev.start);\n                        const e = lastDayOf(ev);\n                        if (e < wk || s > wkEnd) return;\n                        const c1 = s < wk ? 0 : diffDays(wk, s);\n                        const c2 = e > wkEnd ? 6 : diffDays(wk, e);\n                        let lane = -1;\n                        for (let li = 0; li < lanes.length; li++) { if (lanes[li] < c1) { lane = li; break; } }\n                        if (lane === -1) { lane = lanes.length; lanes.push(c2); } else { lanes[lane] = c2; }\n                        const st = statusOf(ev, now);\n                        let cls = 'mcal-evt is-' + st;\n                        if (ev.isFurry && st === 'future') cls += ' is-fox';\n                        if (s < wk) cls += ' is-cont-l';\n                        if (e > wkEnd) cls += ' is-cont-r';\n                        bars += '<button type=\"button\" class=\"' + cls + '\" style=\"grid-column:' + (c1 + 1) + '/' + (c2 + 2) + ';grid-row:' + (lane + 2) + '\" data-evt-id=\"' + esc(ev.id) + '\" title=\"' + esc(ev.title) + '\">' + esc(ev.title) + '</button>';\n                    });\n                    weeks.push('<div class=\"mcal-week\"><div class=\"mcal-week-bg\">' + bgs + '</div><div class=\"mcal-week-fg\">' + nums + bars + '</div></div>');\n                    wk = addDays(wk, 7);\n                }\n\n                const head = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'].map((d) => '<div class=\"mcal-dow\">' + d + '</div>').join('');\n                el.innerHTML = '<div class=\"mcal-grid-head\">' + head + '</div>' + weeks.join('');\n            }\n\n            function renderList() {\n                const el = q('.mcal-view-list');\n                const y = state.cursor.getFullYear();\n                const m = state.cursor.getMonth();\n                const mStart = new Date(y, m, 1);\n                const mEnd = new Date(y, m + 1, 1);\n                const items = state.filtered.filter((ev) => ev.start < mEnd && ev.end > mStart);\n\n                if (!items.length) {\n                    el.innerHTML = '<p class=\"mcal-empty\">Aucun événement ne correspond à cette période ou à ces filtres.</p>';\n                    return;\n                }\n\n                const groups = new Map();\n                items.forEach((ev) => {\n                    const day = startOfDay(ev.start) < mStart ? mStart : startOfDay(ev.start);\n                    const k = day.getTime();\n                    if (!groups.has(k)) groups.set(k, []);\n                    groups.get(k).push(ev);\n                });\n\n                let html = '';\n                Array.from(groups.keys()).sort((a, b) => a - b).forEach((k) => {\n                    html += '<div class=\"mcal-list-day\">' + esc(cap(FMT.dayHeader.format(new Date(k)))) + '</div>';\n                    groups.get(k).forEach((ev) => { html += listCard(ev); });\n                });\n                el.innerHTML = html;\n            }\n\n            function listCard(ev) {\n                const st = statusOf(ev);\n                const nbDays = diffDays(startOfDay(ev.start), lastDayOf(ev)) + 1;\n                const badge = nbDays > 1 ? '<span class=\"mcal-badge\">' + nbDays + ' jours</span>' : '';\n                const dates = nbDays > 1 ? 'Du ' + FMT.dayShort.format(ev.start) + ' au ' + FMT.dayShort.format(lastDayOf(ev)) : '';\n                const loc = firstLine(ev.location);\n                const chip = countdownLabel(ev);\n                const chipCls = st === 'now' ? 'is-now' : (st === 'past' ? 'is-past' : 'is-future');\n                const meta = [\n                    dates ? '<span>' + esc(dates) + '</span>' : '',\n                    loc ? '<span class=\"mcal-list-loc\">📍 ' + esc(loc) + '</span>' : ''\n                ].filter(Boolean).join('<span class=\"mcal-sep\">•</span>');\n                return '<article class=\"mcal-list-card is-' + st + (ev.isFurry ? ' is-fox' : '') + '\" role=\"button\" tabindex=\"0\" data-evt-id=\"' + esc(ev.id) + '\" aria-label=\"Ouvrir ' + esc(ev.title) + '\">' +\n                    '<div class=\"mcal-list-main\">' +\n                    '<div class=\"mcal-list-titleline\"><span class=\"mcal-list-name\">' + esc(ev.title) + '</span>' + badge + '</div>' +\n                    (meta ? '<div class=\"mcal-list-meta\">' + meta + '</div>' : '') +\n                    '</div>' +\n                    '<span class=\"mcal-chip ' + chipCls + '\">' + esc(chip) + '</span>' +\n                    '</article>';\n            }\n\n            function renderCards() {\n                const el = q('.mcal-view-cards');\n                const now = new Date();\n                const future = state.filtered.filter((ev) => statusOf(ev, now) !== 'past');\n                const past = state.filtered.filter((ev) => statusOf(ev, now) === 'past').sort((a, b) => b.end - a.end);\n                const visible = state.cardsPast ? past : future;\n\n                let html = '<article class=\"mcal-card is-control\" role=\"button\" tabindex=\"0\" data-action=\"cards-toggle\" aria-label=\"' + (state.cardsPast ? 'Afficher les événements à venir' : 'Afficher les événements terminés') + '\">' +\n                    '<div class=\"mcal-card-date\"><span class=\"mcal-card-day\">' + (state.cardsPast ? '↺' : '✓') + '</span><span class=\"mcal-card-month\">' + (state.cardsPast ? 'RETOUR' : 'FILTRE') + '</span></div>' +\n                    '<div class=\"mcal-card-content\">' +\n                    '<h4 class=\"mcal-card-title\">' + (state.cardsPast ? 'Afficher les événements à venir' : 'Afficher uniquement les événements terminés') + '</h4>' +\n                    '<p class=\"mcal-card-loc\">' + (state.cardsPast ? 'Retour à la liste des prochains événements' : 'Filtrer la grille sur les événements déjà terminés') + '</p>' +\n                    '<p class=\"mcal-card-cd\">' + (state.cardsPast ? past.length + ' événement(s) terminé(s)' : future.length + ' événement(s) à venir/en cours') + '</p>' +\n                    '</div></article>';\n\n                if (!visible.length) {\n                    html += '<p class=\"mcal-empty\">Aucun événement dans cette vue.</p>';\n                } else {\n                    html += visible.map((ev) => {\n                        const st = statusOf(ev, now);\n                        const cls = st === 'past' ? 'is-past' : (st === 'now' ? 'is-now' : (ev.isFurry ? 'is-future is-fox' : 'is-future'));\n                        const cd = countdownLabel(ev, now);\n                        return '<article class=\"mcal-card ' + cls + '\" role=\"button\" tabindex=\"0\" data-evt-id=\"' + esc(ev.id) + '\" aria-label=\"Ouvrir ' + esc(ev.title) + '\">' +\n                            '<div class=\"mcal-card-date\"><span class=\"mcal-card-day\">' + ev.start.getDate() + '</span><span class=\"mcal-card-month\">' + esc(FMT.monthTag.format(ev.start).replace('.', '').toUpperCase()) + '</span></div>' +\n                            '<div class=\"mcal-card-content\">' +\n                            '<h4 class=\"mcal-card-title\">' + esc(ev.title) + '</h4>' +\n                            '<p class=\"mcal-card-loc\">📍 ' + esc(firstLine(ev.location) || 'Lieu non renseigné') + '</p>' +\n                            '<p class=\"mcal-card-cd' + (st === 'past' ? ' is-past' : '') + '\">' + esc(cd) + '</p>' +\n                            '</div></article>';\n                    }).join('');\n                }\n                el.innerHTML = '<div class=\"mcal-cards-grid\">' + html + '</div>';\n            }\n\n            /* ============================================================\n               11. Modale <dialog> (focus, Échap et backdrop natifs)\n               ============================================================ */\n            function openModal(ev) {\n                if (!DIALOG || typeof DIALOG.showModal !== 'function') return;\n                state.modalEvent = ev;\n                DIALOG.querySelector('.mcal-dialog-title').textContent = ev.title;\n\n                const lastD = lastDayOf(ev);\n                const multi = lastD.getTime() > startOfDay(ev.start).getTime();\n                const nbDays = diffDays(startOfDay(ev.start), lastD) + 1;\n                const sDate = cap(FMT.dayFull.format(ev.start));\n                const eDate = cap(FMT.dayFull.format(ev.allDay ? lastD : ev.end));\n                const startDisplay = ev.allDay\n                    ? (multi ? sDate : sDate + ' — Journée entière')\n                    : sDate + ' • ' + FMT.time.format(ev.start);\n                const endDisplay = (ev.allDay ? eDate : eDate + ' • ' + FMT.time.format(ev.end)) + (multi ? ' (' + nbDays + ' jours)' : '');\n\n                let left = '<div class=\"mcal-info-row\"><div class=\"mcal-info-icon\">📅</div><div class=\"mcal-info-content\">' +\n                    '<div class=\"mcal-info-label\">Dates</div>' +\n                    '<div class=\"mcal-info-text mcal-dates\">' +\n                    '<span class=\"mcal-date-item\"><span class=\"mcal-date-label\">Début:</span>' + esc(startDisplay) + '</span>' +\n                    '<span class=\"mcal-date-item\"><span class=\"mcal-date-label\">Fin:</span>' + esc(endDisplay) + '</span>' +\n                    '</div></div></div>';\n\n                if (ev.location) {\n                    const encoded = encodeURIComponent(ev.location);\n                    left += '<div class=\"mcal-info-row\"><div class=\"mcal-info-icon\">📍</div><div class=\"mcal-info-content\">' +\n                        '<div class=\"mcal-info-label\">Lieu</div>' +\n                        '<div class=\"mcal-info-text\">' + multiline(ev.location) + '</div>' +\n                        '<div class=\"mcal-map-btns\">' +\n                        '<a href=\"https://www.google.com/maps/search/' + encoded + '\" target=\"_blank\" rel=\"noopener\" class=\"mcal-map-btn mcal-map-google\">Google Maps</a>' +\n                        '<a href=\"https://www.waze.com/ul?q=' + encoded + '\" target=\"_blank\" rel=\"noopener\" class=\"mcal-map-btn mcal-map-waze\">Waze</a>' +\n                        '<a href=\"https://maps.apple.com/?q=' + encoded + '\" target=\"_blank\" rel=\"noopener\" class=\"mcal-map-btn mcal-map-apple\">Apple Plans</a>' +\n                        '</div></div></div>';\n                }\n\n                let right = '';\n                const url = safeUrl(ev.url);\n                const urlBtn = url ? '<a href=\"' + esc(url) + '\" target=\"_blank\" rel=\"noopener\" class=\"mcal-url-btn\">Voir l\\'événement</a>' : '';\n\n                if (ev.description) {\n                    const lineBreaks = (ev.description.match(/\\r\\n?|\\n/g) || []).length;\n                    const collapse = ev.description.length > 260 || lineBreaks > 4;\n                    right += '<div class=\"mcal-info-row\"><div class=\"mcal-info-icon\">📝</div><div class=\"mcal-info-content\">' +\n                        '<div class=\"mcal-info-label\">Description</div>' +\n                        '<div class=\"mcal-info-text mcal-desc' + (collapse ? ' is-collapsed' : '') + '\">' + multiline(ev.description) + '</div>' +\n                        (collapse ? '<button type=\"button\" class=\"mcal-desc-toggle\" data-action=\"toggle-desc\" aria-expanded=\"false\">Voir plus</button>' : '') +\n                        urlBtn + '</div></div>';\n                } else if (urlBtn) {\n                    right += '<div class=\"mcal-info-row\"><div class=\"mcal-info-content\">' + urlBtn + '</div></div>';\n                }\n\n                const body = DIALOG.querySelector('.mcal-dialog-body');\n                body.innerHTML = '<div class=\"mcal-dialog-grid\"><div class=\"mcal-dialog-col\">' + left + '</div><div class=\"mcal-dialog-col\">' + right + '</div></div>';\n\n                const toggle = body.querySelector('[data-action=\"toggle-desc\"]');\n                if (toggle) {\n                    const desc = body.querySelector('.mcal-desc');\n                    toggle.addEventListener('click', () => {\n                        const expanded = desc.classList.toggle('is-collapsed') === false;\n                        toggle.textContent = expanded ? 'Voir moins' : 'Voir plus';\n                        toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');\n                    });\n                }\n\n                DIALOG.showModal();\n            }\n\n            /* ============================================================\n               12. Export .ics d'un événement (RFC 5545)\n               ============================================================ */\n            function icsForEvent(ev) {\n                const pad2 = (n) => String(n).padStart(2, '0');\n                const dateLocal = (d) => '' + d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate());\n                const dateUtc = (d) => d.getUTCFullYear() + pad2(d.getUTCMonth() + 1) + pad2(d.getUTCDate()) + 'T' + pad2(d.getUTCHours()) + pad2(d.getUTCMinutes()) + pad2(d.getUTCSeconds()) + 'Z';\n                const escT = (v) => String(v || '').replace(/\\\\/g, '\\\\\\\\').replace(/;/g, '\\\\;').replace(/,/g, '\\\\,').replace(/\\r\\n|\\r|\\n/g, '\\\\n');\n                const lines = ['BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//Mobirise Calendar v2//FR', 'BEGIN:VEVENT',\n                    'UID:' + (ev.uid || ev.id),\n                    'DTSTAMP:' + dateUtc(new Date()),\n                    'SUMMARY:' + escT(ev.title)];\n                if (ev.allDay) {\n                    lines.push('DTSTART;VALUE=DATE:' + dateLocal(ev.start));\n                    lines.push('DTEND;VALUE=DATE:' + dateLocal(ev.end));\n                } else {\n                    lines.push('DTSTART:' + dateUtc(ev.start));\n                    lines.push('DTEND:' + dateUtc(ev.end));\n                }\n                if (ev.description) lines.push('DESCRIPTION:' + escT(ev.description));\n                if (ev.location) lines.push('LOCATION:' + escT(String(ev.location).replace(/\\r\\n|\\r|\\n/g, ' ')));\n                const u = safeUrl(ev.url);\n                if (u) lines.push('URL:' + u);\n                lines.push('END:VEVENT', 'END:VCALENDAR');\n                return lines.join('\\r\\n');\n            }\n\n            function downloadIcs(ev) {\n                const slug = normText(ev.title).replace(/[^a-z0-9\\s-]/g, '').trim().replace(/\\s+/g, '-') || 'evenement';\n                const blob = new Blob([icsForEvent(ev)], { type: 'text/calendar' });\n                const url = URL.createObjectURL(blob);\n                const a = document.createElement('a');\n                a.href = url;\n                a.download = slug + '.ics';\n                document.body.appendChild(a);\n                a.click();\n                setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);\n            }\n\n            /* ============================================================\n               13. Interface : câblage des contrôles (délégation)\n               ============================================================ */\n            function syncSearchClear() {\n                const input = q('.mcal-f-search');\n                const box = q('.mcal-searchbox');\n                if (box && input) box.classList.toggle('has-value', input.value.trim().length > 0);\n            }\n\n            function setView(view) {\n                state.view = view;\n                if (view !== 'cards') state.prevView = view;\n                render();\n            }\n\n            function wireUi() {\n                q('.mcal-prev').addEventListener('click', () => {\n                    state.cursor = new Date(state.cursor.getFullYear(), state.cursor.getMonth() - 1, 1);\n                    render();\n                });\n                q('.mcal-next').addEventListener('click', () => {\n                    state.cursor = new Date(state.cursor.getFullYear(), state.cursor.getMonth() + 1, 1);\n                    render();\n                });\n                q('.mcal-today').addEventListener('click', () => {\n                    state.cursor = startOfMonth(new Date());\n                    render();\n                });\n\n                const tbtn = q('.mcal-btn-toggle');\n                if (tbtn) tbtn.addEventListener('click', () => {\n                    state.userChoseView = true;\n                    setView(state.view === 'month' ? 'list' : 'month');\n                });\n\n                // Vue cartes : double-clic sur le nom du mois (parité v1)\n                q('.mcal-month-label').addEventListener('dblclick', (e) => {\n                    e.preventDefault();\n                    if (state.view !== 'cards') {\n                        state.cardsPast = false;\n                        state.view = 'cards';\n                    } else {\n                        state.view = state.prevView;\n                    }\n                    render();\n                });\n\n                // Filtres\n                q('.mcal-f-type').addEventListener('change', applyFilters);\n                q('.mcal-f-detail').addEventListener('change', applyFilters);\n                q('.mcal-f-region').addEventListener('change', () => {\n                    const val = q('.mcal-f-region').value;\n                    populateDetail(val === 'all' ? null : val.slice(7));\n                    applyFilters();\n                });\n\n                // Recherche\n                const input = q('.mcal-f-search');\n                const debouncedApply = debounce(applyFilters, 350);\n                const onSearchChange = () => { syncSearchClear(); renderSuggest(); debouncedApply(); };\n                input.addEventListener('input', onSearchChange);\n                input.addEventListener('search', onSearchChange);\n                input.addEventListener('focus', renderSuggest);\n                input.addEventListener('keydown', suggestKeydown);\n                q('.mcal-search-clear').addEventListener('click', () => {\n                    input.value = '';\n                    syncSearchClear();\n                    hideSuggest();\n                    applyFilters();\n                    input.focus();\n                });\n                document.addEventListener('mousedown', (e) => {\n                    const box = q('.mcal-searchbox');\n                    if (box && !box.contains(e.target)) hideSuggest();\n                });\n\n                // Case \"Conserver le filtrage\"\n                q('.mcal-f-save').addEventListener('change', (e) => {\n                    if (e.target.checked) persistFilters();\n                    else {\n                        try {\n                            localStorage.removeItem(LS.filters);\n                            localStorage.removeItem(LS.keep);\n                        } catch (err) { }\n                    }\n                });\n\n                // Ouverture de la modale (délégation sur le panneau des vues)\n                const panel = q('.mcal-panel');\n                const openFromTarget = (target) => {\n                    const ctl = target.closest('[data-action=\"cards-toggle\"]');\n                    if (ctl) { state.cardsPast = !state.cardsPast; renderCards(); return true; }\n                    const el = target.closest('[data-evt-id]');\n                    if (!el) return false;\n                    const id = el.getAttribute('data-evt-id');\n                    const ev = state.events.find((x) => x.id === id);\n                    if (ev) openModal(ev);\n                    return true;\n                };\n                panel.addEventListener('click', (e) => { openFromTarget(e.target); });\n                panel.addEventListener('keydown', (e) => {\n                    if ((e.key === 'Enter' || e.key === ' ') && e.target.matches('[role=\"button\"]')) {\n                        e.preventDefault();\n                        openFromTarget(e.target);\n                    }\n                });\n\n                // Modale\n                if (DIALOG) {\n                    DIALOG.querySelector('[data-action=\"close-dialog\"]').addEventListener('click', () => DIALOG.close());\n                    DIALOG.querySelector('[data-action=\"download-ics\"]').addEventListener('click', () => {\n                        if (state.modalEvent) downloadIcs(state.modalEvent);\n                    });\n                    // Clic sur le backdrop = fermer\n                    DIALOG.addEventListener('click', (e) => { if (e.target === DIALOG) DIALOG.close(); });\n                }\n\n                // Vue par défaut selon l'orientation / la taille d'écran.\n                // Ne s'applique jamais si l'utilisateur a choisi sa vue manuellement.\n                window.addEventListener('resize', debounce(() => {\n                    if (!state.uiReady || state.view === 'cards' || state.userChoseView) return;\n                    const target = initialView();\n                    if (target !== state.view) setView(target);\n                }, 200));\n            }\n\n            /* ============================================================\n               14. Démarrage (cache stale-while-revalidate)\n               ============================================================ */\n            function initialView() {\n                if (!cfg.allowMonth && cfg.allowList) return 'list';\n                if (!cfg.allowList) return 'month';\n                if (isMobile() && isPortrait() && cfg.mobileList) return 'list';\n                return 'month';\n            }\n\n            function showUi() {\n                // La vue initiale est décidée ici (et non au chargement du script)\n                // pour mesurer le viewport réel au moment du premier affichage\n                state.view = initialView();\n                state.prevView = state.view;\n                q('.mcal-loader').hidden = true;\n                q('.mcal-toolbar').hidden = false;\n                q('.mcal-panel').hidden = false;\n                state.uiReady = true;\n            }\n\n            function ingest(text) {\n                state.events = parseIcs(text);\n                state.filtered = filterEvents();\n                if (!state.uiReady) showUi();\n                render();\n                // Géocodage en arrière-plan ; re-filtre si un filtre région est actif\n                resolveLocations(state.events).then((changed) => {\n                    if (changed && readFilters().region !== 'all') {\n                        state.filtered = filterEvents();\n                        render();\n                    }\n                }).catch(() => { });\n            }\n\n            function fatal(error) {\n                console.error('Erreur de chargement du calendrier :', error);\n                const loader = q('.mcal-loader');\n                loader.hidden = false;\n                q('.mcal-toolbar').hidden = true;\n                q('.mcal-panel').hidden = true;\n                let msg = (error && error.message) || 'Erreur inconnue';\n                let tips = '';\n                if (/HTTP 40[13]/.test(msg)) {\n                    msg = 'Accès refusé au calendrier.';\n                    tips = '<br><strong>Action :</strong> vérifiez que le calendrier est <strong>public</strong>.';\n                } else if (/iCal|VCALENDAR|invalide/i.test(msg)) {\n                    msg = 'Le fichier iCal n\\'est pas au bon format.';\n                    tips = '<br><strong>Conseil :</strong> vérifiez que l\\'URL pointe vers un fichier .ics valide.';\n                } else if (/ical\\.js|CDN/i.test(msg)) {\n                    msg = 'Les librairies externes n\\'ont pas pu être chargées (CDN bloqué).';\n                } else {\n                    msg = 'Impossible de charger le calendrier.';\n                    tips = '<br><strong>Solutions :</strong><ul><li>Vérifiez que l\\'URL iCal est correcte et publique</li><li>Testez l\\'URL dans votre navigateur</li><li>Vérifiez votre connexion Internet</li></ul>';\n                }\n                loader.innerHTML = '<div class=\"mcal-error\">❌ ' + msg +\n                    '<small>Ouvrez la console (F12) pour les détails techniques</small>' + tips +\n                    '<button type=\"button\" class=\"mcal-btn\" data-action=\"retry\" style=\"margin-top:1rem;\">🔄 Réessayer</button></div>';\n                const retry = loader.querySelector('[data-action=\"retry\"]');\n                if (retry) retry.addEventListener('click', () => {\n                    loader.innerHTML = '<div class=\"mcal-spinner\" aria-hidden=\"true\"></div><p class=\"mcal-loader-msg\">Chargement du calendrier...</p>';\n                    loadData();\n                });\n            }\n\n            async function loadData() {\n                try {\n                    await loadIcalLib();\n                } catch (e) {\n                    return fatal(new Error('ical.js indisponible (CDN bloqué)'));\n                }\n\n                const cacheKey = LS.ics(cfg.icalUrl);\n                let cached = null;\n                try { cached = JSON.parse(localStorage.getItem(cacheKey) || 'null'); } catch (e) { }\n\n                // 1. Affichage immédiat depuis le cache\n                if (cached && cached.text) {\n                    try { ingest(cached.text); } catch (e) { cached = null; }\n                }\n\n                // 2. Données fraîches en arrière-plan\n                try {\n                    const fresh = await fetchIcsText(cfg.icalUrl);\n                    try { localStorage.setItem(cacheKey, JSON.stringify({ ts: Date.now(), text: fresh })); } catch (e) { }\n                    // 3. Re-rendu seulement si le contenu a changé\n                    if (!cached || cached.text !== fresh) ingest(fresh);\n                } catch (err) {\n                    if (state.uiReady) {\n                        console.warn('Rafraîchissement impossible, affichage du cache conservé :', err && err.message);\n                    } else {\n                        fatal(err);\n                    }\n                }\n            }\n\n            function main() {\n                populateRegions();\n                wireUi();\n                restoreFilters();\n                loadData();\n            }\n\n            main();\n        })();\n    </script>"
          ],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            "position": "relative",
            "border-radius": "20px 20px 0 0",
            "margin-top": "-20px",
            ".mbr-overlay": {
              "position": "absolute",
              "inset": "0",
              "pointer-events": "none"
            },
            ".footer-divider": {
              "width": "100%",
              "height": "1px",
              "background": "linear-gradient(90deg, transparent, #38bdf8, #f97316, #a855f7, transparent)",
              "margin-bottom": "0.85rem"
            },
            ".container": {
              "position": "relative",
              "z-index": "2",
              "text-align": "center"
            },
            ".footer-credits": {
              "margin-bottom": "0.5rem"
            },
            ".footer-credits .mbr-text": {
              "color": "rgba(255, 255, 255, 0.65)",
