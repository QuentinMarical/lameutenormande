              "color": "#adb5bd !important",
              "font-weight": "500"
            },
            ".fc .fc-list-event-time:empty": {
              "display": "none !important"
            },
            ".fc-list-event-dot": {
              "display": "none !important"
            },
            "@media (min-width: 1200px)": {
              ".container-calendar": {
                "max-width": "1150px",
                "padding": "0 0.75rem"
              },
              ".calendar-wrapper": {
                "padding": "0.65rem"
              },
              ".fc .fc-col-header-cell": {
