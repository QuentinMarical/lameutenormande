            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "rgba(255, 255, 255, 0.65)",
              "text-align": "center"
            },
            ".faq-header": {
              "margin-bottom": "2rem"
            },
            ".faq-title": {
              "color": "#ffffff",
              "font-size": "2.5rem",
              "font-weight": "bold",
              "text-align": "center"
            },
            ".faq-subtitle": {
              "color": "rgba(255, 255, 255, 0.75)",
              "font-size": "1.25rem",
              "text-align": "center"
            },
            ".faq-cards": {
              "display": "flex",
              "flex-direction": "column",
              "gap": "2.5rem",
              "padding-bottom": "3rem"
            },
            ".faq-card": {
              "background": "rgba(0, 0, 0, 0.55)",
              "backdrop-filter": "blur(6px)",
              "-webkit-backdrop-filter": "blur(6px)",
              "border-radius": "12px",
              "padding": "1.5rem",
              "border": "1px solid rgba(255, 255, 255, 0.1)",
              "border-top": "2px solid #ffa43c",
              "box-shadow": "0 4px 24px rgba(0, 0, 0, 0.25)",
              "transition": "transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease",
              "cursor": "pointer"
            },
            ".faq-card:hover": {
              "background": "rgba(0, 0, 0, 0.7)",
              "transform": "translateY(-5px)",
              "box-shadow": "0 6px 28px rgba(0, 0, 0, 0.4)"
            },
            ".faq-question": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between",
              "width": "100%",
              "background": "none",
              "border": "none",
              "padding": "0",
              "font-size": "1.25rem",
              "font-weight": "bold",
              "color": "#ffa43c",
              "cursor": "pointer",
              "text-align": "left",
              "gap": "1rem"
            },
            ".faq-icon": {
              "flex-shrink": "0",
              "color": "#ffa43c",
              "transition": "transform 0.3s ease"
            },
            ".faq-card.open .faq-icon": {
              "transform": "rotate(180deg)"
            },
            ".faq-answer": {
              "font-size": "1rem",
              "color": "rgba(255, 255, 255, 0.8)",
              "line-height": "1.7",
              "max-height": "0",
              "overflow": "hidden",
              "transition": "max-height 0.4s ease, padding-top 0.3s ease",
              "padding-top": "0"
            },
            ".faq-card.open .faq-answer": {
              "max-height": "600px",
              "padding-top": "0.75rem"
            },
            ".faq-answer p": {
              "margin": "0 0 0.75rem 0",
              "color": "rgba(255, 255, 255, 0.8)",
              "line-height": "1.7"
            },
            ".faq-answer p:last-child": {
              "margin-bottom": "0"
            },
            ".faq-answer a": {
              "color": "#ffa43c",
              "text-decoration": "underline",
              "text-underline-offset": "3px"
            },
            ".faq-answer a:hover": {
              "color": "#ffbe70"
            },
            "@media (max-width: 768px)": {
              ".faq-title": {
                "font-size": "2rem"
              },
              ".faq-subtitle": {
                "font-size": "1rem"
              },
              ".faq-card": {
                "padding": "1rem 1.25rem"
              },
              ".faq-question": {
                "font-size": "1.1rem"
              },
              ".faq-answer": {
                "font-size": "0.9rem"
              }
            }
          },
          "_name": "list05",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"parallax-faq\" group=\"FAQ\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/photo-2024-04-27-22-34-50-1280x720.webp\" selected parallax>\n            <input type=\"color\" title=\"Color\" value=\"#090909\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n        <header>FAQ Settings</header>\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Subtitle\" name=\"showSubtitle\">\n        <input type=\"color\" title=\"Card Background\" name=\"cardBg\" value=\"#1a1a1a\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container-fluid\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"faq-header text-center\">\n                    <h2 class=\"faq-title\" mbr-if=\"showTitle\">Questions fréquentes</h2>\n                    <p class=\"faq-subtitle\" mbr-if=\"showSubtitle\">Find answers to common questions below</p>\n                </div>\n\n                <div class=\"faq-cards\">\n                    <div class=\"faq-card\">\n                        <button class=\"faq-question\" aria-expanded=\"false\">\n                            <span>Où sommes-nous ?</span>\n                            <svg class=\"faq-icon\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><path d=\"M12 15.5l-7-7 1.4-1.4 5.6 5.6 5.6-5.6L19 8.5z\" fill=\"currentColor\"></path></svg>\n                        </button>\n                        <div class=\"faq-answer\">Nous sommes basés principalement en Haute-Normandie, mais nos membres viennent de toute la région et même en dehors de la Normandie pour certains.</div>\n                    </div>\n                    <div class=\"faq-card\">\n                        <button class=\"faq-question\" aria-expanded=\"false\">\n                            <span>Qui sommes-nous ?</span>\n                            <svg class=\"faq-icon\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><path d=\"M12 15.5l-7-7 1.4-1.4 5.6 5.6 5.6-5.6L19 8.5z\" fill=\"currentColor\"></path></svg>\n                        </button>\n                        <div class=\"faq-answer\">\n                            <p>La Meute Normande, c'est avant tout un groupe d'amis réunis autour de la culture furry et des univers créatifs qui l'entourent. Furs, cosplayeurs ou les deux, tout le monde y trouve sa place !</p>\n                            <p>Ensemble, nous organisons des sorties, participons à des événements et donnons vie à des villages furry en convention.</p>\n                            <p>Notre premier village furry a vu le jour lors de l'édition 2025 de PontoGeek à Pont-Audemer (27), grâce à l'initiative de Protofactory517 et du staff de la Meute Normande.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-card\">\n                        <button class=\"faq-question\" aria-expanded=\"false\">\n                            <span>Comment savoir où la Meute sera présente et trouver des événements près de chez moi ?</span>\n                            <svg class=\"faq-icon\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"20\" height=\"20\"><path d=\"M12 15.5l-7-7 1.4-1.4 5.6 5.6 5.6-5.6L19 8.5z\" fill=\"currentColor\"></path></svg>\n                        </button>\n                        <div class=\"faq-answer\">Les trois prochains événements auxquels nous participons sont mis à jour automatiquement sur la page <a href=\"https://lameutenormande.fr/actus\" target=\"_blank\" rel=\"noopener\">Actus</a>. Pour retrouver tous les événements en France et à l'étranger, le staff recense un maximum de conventions et grands événements furry afin que chacun puisse trouver ce qui se passe près de chez soi, direction la page <a href=\"https://lameutenormande.fr/events\" target=\"_blank\" rel=\"noopener\">Événements</a> !</div>\n                    </div>\n                </div>\n\n                [JS_CODE_0]\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v2D9yvLDaG",
          "_anchor": "list05-3",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n                (function() {\n                    var cards = document.querySelectorAll('.parallax-faq .faq-card');\n                    cards.forEach(function(card) {\n                        var btn = card.querySelector('.faq-question');\n                        card.addEventListener('click', function() {\n                            var isOpen = card.classList.contains('open');\n                            cards.forEach(function(c) {\n                                c.classList.remove('open');\n                                c.querySelector('.faq-question').setAttribute('aria-expanded', 'false');\n                            });\n                            if (!isOpen) {\n                                card.classList.add('open');\n                                btn.setAttribute('aria-expanded', 'true');\n                            }\n                        });\n                    });\n                })();\n                </script>"
          ],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            "position": "relative",
            "border-radius": "20px 20px 0 0",
