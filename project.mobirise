              "border-top": "1px solid rgba(255, 255, 255, 0.1)"
            },
            ".location-btn": {
              "flex": "1",
              "min-width": "70px",
              "padding": "0.6rem 0.5rem",
              "border-radius": "10px",
              "font-size": "0.85rem",
              "font-weight": "600",
              "text-decoration": "none",
              "text-align": "center",
              "cursor": "pointer",
              "transition": "all 0.25s ease",
              "border": "1px solid rgba(255, 255, 255, 0.15)",
              "color": "#fff",
              "display": "flex",
              "flex-direction": "column",
