              "border-color": "rgba(140, 140, 155, 0.5)"
            },
            ".location-apple:hover": {
              "background": "#8c8c9b",
              "box-shadow": "0 4px 14px rgba(140, 140, 155, 0.45)",
              "transform": "translateY(-1px)"
            },
            ".event-url-button": {
              "display": "inline-flex",
              "align-items": "center",
              "gap": "0.4rem",
              "margin-top": "0.5rem",
              "padding": "0.55rem 1.1rem",
              "background": "linear-gradient(135deg, #ff6eb4, #c471ed)",
              "color": "#fff !important",
              "text-decoration": "none",
              "border-radius": "20px",
              "font-weight": "600",
              "font-size": "0.88rem",
              "transition": "all 0.2s ease"
            },
