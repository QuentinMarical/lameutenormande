                "&:nth-child(1)": {
                  "top": "0",
                  "width": "26px",
                  "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "width": "18px",
                  "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s cubic-bezier(0.22, 1, 0.36, 1)"
              },
              "&:nth-child(2)": {
                "width": "24px",
                "transform": "rotate(45deg)",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s"
              },
              "&:nth-child(3)": {
                "width": "24px",
                "transform": "rotate(-45deg)",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s"
              },
              "&:nth-child(4)": {
