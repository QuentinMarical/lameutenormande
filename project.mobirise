            },
            ".navbar-buttons": {
              "text-align": "center",
              "min-width": "140px",
              ".btn": {
                "border-radius": "100vw",
                "padding": "10px 28px",
                "font-weight": "600",
                "letter-spacing": "0.03em",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)",
                "box-shadow": "0 2px 12px -2px rgba(0, 0, 0, 0.12)",
                "position": "relative",
                "overflow": "hidden",
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "inset": "0",
                  "background": "linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, transparent 50%)",
                  "opacity": "0",
                  "transition": "opacity 0.4s ease"
                },
                "&:hover": {
                  "transform": "translateY(-3px)",
                  "box-shadow": "0 8px 28px -4px rgba(0, 0, 0, 0.2)",
                  "&::before": {
                    "opacity": "1"
                  }
                },
                "&:active": {
                  "transform": "translateY(-1px) scale(0.98)",
                  "box-shadow": "0 4px 16px -2px rgba(0, 0, 0, 0.15)"
                }
              },
              "@media (max-width: 992px)": {
                "text-align": "left"
              }
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "31px",
              "height": "20px",
              "cursor": "pointer",
              "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)",
              "position": "relative",
              "align-self": "center",
              "&:hover .hamburger span": {
                "&:nth-child(1)": {
                  "width": "20px"
                },
                "&:nth-child(4)": {
                  "width": "24px"
                }
              },
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "height": "2px",
                "border-right": "5px",
                "background-color": "@hamburgerColor",
                "border-radius": "4px",
                "&:nth-child(1)": {
                  "top": "0",
                  "width": "26px",
                  "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s cubic-bezier(0.22, 1, 0.36, 1) 0.05s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "width": "18px",
                  "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s cubic-bezier(0.22, 1, 0.36, 1)"
              },
              "&:nth-child(2)": {
                "width": "24px",
                "transform": "rotate(45deg)",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s"
              },
              "&:nth-child(3)": {
                "width": "24px",
                "transform": "rotate(-45deg)",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s cubic-bezier(0.22, 1, 0.36, 1)"
              }
            },
