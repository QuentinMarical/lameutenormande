            },
            ".event-modal-body": {
              "padding": "1.5rem 2rem 2rem",
              "color": "#fff",
              "flex": "1"
            },
            ".event-modal-body-grid": {
              "display": "grid",
              "grid-template-columns": "1fr",
              "gap": "0.75rem"
            },
            ".event-modal-left, .event-modal-right": {
              "display": "flex",
              "flex-direction": "column",
              "gap": "0.75rem"
            },
            ".event-info-row": {
              "display": "flex",
              "align-items": "flex-start",
              "gap": "0.9rem",
              "padding": "1rem 1.25rem",
              "background": "rgba(255, 255, 255, 0.04)",
              "border": "1px solid rgba(255, 255, 255, 0.07)",
              "border-radius": "12px",
              "transition": "background 0.2s ease"
            },
            ".event-info-row:hover": {
              "background": "rgba(255, 255, 255, 0.07)"
            },
            ".event-info-icon": {
              "font-size": "1.35rem",
              "min-width": "28px",
              "flex-shrink": "0",
              "margin-top": "0.1rem"
            },
            ".event-info-content": {
              "flex": "1",
              "min-width": "0"
            },
            ".event-info-label": {
              "font-size": "0.73rem",
              "letter-spacing": "0.1em",
              "text-transform": "uppercase",
              "font-weight": "700",
              "color": "rgba(255, 110, 180, 0.85)",
              "margin-bottom": "0.35rem"
            },
            ".event-info-text": {
              "font-size": "1rem",
              "line-height": "1.55",
              "font-weight": "500",
              "word-break": "break-word",
              "color": "rgba(255, 255, 255, 0.92)"
            },
            ".event-info-text a": {
              "color": "#ff6eb4",
              "text-decoration": "underline",
              "transition": "color 0.2s"
            },
            ".event-info-text a:hover": {
