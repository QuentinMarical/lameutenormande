              }
            },
            ".iconfont-wrapper": {
              "color": "@iconsColor !important",
              "font-size": "1.35rem",
              "padding-right": "0",
              "display": "inline-flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "38px",
              "height": "38px",
              "border-radius": "50%",
              "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)",
