          "_name": "header09",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"module-artiste\" group=\"Content\">\n    <mbr-parameters>\n        <input type=\"id\" name=\"sliderId\">\n        <header>Disposition</header>\n        <input type=\"checkbox\" title=\"Carrousel à droite\" name=\"carouselRight\" checked>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" name=\"carouselWidth\" title=\"Largeur Carrousel\" min=\"4\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"range\" name=\"carouselHeight\" title=\"Hauteur Carrousel\" min=\"2\" max=\"8\" step=\"1\" value=\"4\">\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Fade Effect\" name=\"fade\">\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\">\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"3\" max=\"10\" value=\"5\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Bullets\" name=\"bullets\">\n        <input type=\"checkbox\" title=\"Arrows\" name=\"arrows\">\n        <header>Fond Images Carrousel</header>\n        <input type=\"color\" title=\"Fond Image 1\" name=\"imgBg1\" value=\"#eea600\">\n        <input type=\"color\" title=\"Fond Image 2\" name=\"imgBg2\" value=\"#1a1a2e\">\n        <input type=\"color\" title=\"Fond Image 3\" name=\"imgBg3\" value=\"#1a1a2e\">\n        <header>Infos Artiste</header>\n        <input type=\"checkbox\" title=\"Afficher Nom\" name=\"showName\" checked>\n        <input type=\"color\" title=\"Couleur Nom Artiste\" name=\"artistNameColor\" value=\"#edefeb\" condition=\"showName\">\n        <input type=\"checkbox\" title=\"Afficher Description\" name=\"showDescription\" checked>\n        <input type=\"checkbox\" title=\"Afficher Bouton Détails\" name=\"showDetailsBtn\" checked>\n        <input type=\"text\" title=\"Texte Bouton\" name=\"btnText\" value=\"En savoir plus\" condition=\"showDetailsBtn\">\n        <input type=\"color\" title=\"Couleur Bouton\" name=\"btnColor\" value=\"#edefeb\" condition=\"showDetailsBtn\">\n        <input type=\"checkbox\" title=\"Bouton redirige vers URL\" name=\"btnRedirect\" condition=\"showDetailsBtn\">\n        <input type=\"text\" title=\"URL de redirection\" name=\"btnRedirectUrl\" value=\"https://\" condition=\"showDetailsBtn && btnRedirect\">\n        <header>Détails Popup</header>\n        <input type=\"text\" title=\"Site Web\" name=\"artistWebsite\" value=\"https://kuranaika.carrd.co/\">\n        <input type=\"text\" title=\"Instagram\" name=\"artistInstagram\" value=\"kuranaika\">\n        <input type=\"text\" title=\"Twitter/X\" name=\"artistTwitter\" value=\"kuranaika\">\n        <input type=\"text\" title=\"Bluesky\" name=\"artistBluesky\" value>\n        <input type=\"text\" title=\"Facebook\" name=\"artistFacebook\" value>\n        <input type=\"text\" title=\"Telegram\" name=\"artistTelegram\" value=\"Kuranaika\">\n        <input type=\"text\" title=\"FurAffinity\" name=\"artistFuraffinity\" value>\n        <input type=\"text\" title=\"TikTok\" name=\"artistTiktok\" value=\"kuranaika\">\n        <input type=\"text\" title=\"Threads\" name=\"artistThreads\" value>\n        <input type=\"text\" title=\"YouTube\" name=\"artistYoutube\" value=\"kuranaika\">\n        <input type=\"text\" title=\"Types de commandes\" name=\"commissionTypes\" value=\"Illustrations, Badges, Fursuits partielles\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"color\" title=\"Color\" value=\"#b26000\" selected>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type === 'image'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#1a1a2e\" condition=\"overlay && bg.type === 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type === 'image'\">\n        <header>Coins Arrondis</header>\n        <input type=\"color\" title=\"Couleur des coins\" name=\"cornerColor\" value=\"#1a1a2e\">\n    </mbr-parameters>\n\n    <div class=\"module-inner\">\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type === 'image'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row align-items-center\" mbr-class=\"{'flex-row-reverse': carouselRight}\">\n            \n            <!-- Carrousel -->\n            <div class=\"col-12 col-lg-{{carouselWidth}} carousel-col\">\n                <div id=\"{{sliderId}}\" class=\"carousel slide\" mbr-class=\"{'carousel-fade': fade}\" data-ride=\"{{autoplay ? 'carousel' : false}}\" data-bs-ride=\"{{autoplay ? 'carousel' : false}}\" data-interval=\"{{interval*1000}}\" data-bs-interval=\"{{interval*1000}}\">\n                    <ol class=\"carousel-indicators\" mbr-if=\"bullets\">\n                        <li data-target=\"#{{sliderId}}\" data-bs-target=\"#{{sliderId}}\" data-slide-to=\"0\" data-bs-slide-to=\"0\" class=\"active\"></li>\n                        <li data-target=\"#{{sliderId}}\" data-bs-target=\"#{{sliderId}}\" data-slide-to=\"1\" data-bs-slide-to=\"1\"></li><li data-target=\"#{{sliderId}}\" data-bs-target=\"#{{sliderId}}\" data-slide-to=\"2\" data-bs-slide-to=\"2\"></li>\n                        \n                    </ol>\n                    <div class=\"carousel-inner\">\n                        <div class=\"carousel-item slider-image item active\">\n                            <div class=\"item-wrapper\" mbr-style=\"{'background-color': imgBg1}\">\n                                <img class=\"d-block w-100 carousel-clickable-img\" src=\"@PROJECT_PATH@/assets/images/kuranaika20logo-1980x1980.webp\" alt onclick=\"openCarouselFullscreen(this)\">\n                            </div>\n                        </div>\n                        \n                        <div class=\"carousel-item slider-image item\">\n                            <div class=\"item-wrapper\" mbr-style=\"{'background-color': imgBg3}\">\n                                <img class=\"d-block w-100 carousel-clickable-img\" src=\"@PROJECT_PATH@/assets/images/kuranaika-img1-1280x1280.webp\" alt onclick=\"openCarouselFullscreen(this)\" data-slide-to=\"1\" data-bs-slide-to=\"1\">\n                            </div>\n                        </div><div class=\"carousel-item slider-image item\">\n                            <div class=\"item-wrapper\" mbr-style=\"{'background-color': imgBg3}\">\n                                <img class=\"d-block w-100 carousel-clickable-img\" src=\"@PROJECT_PATH@/assets/images/kuranaika-img2-591x1280.webp\" alt onclick=\"openCarouselFullscreen(this)\" data-slide-to=\"2\" data-bs-slide-to=\"2\">\n                            </div>\n                        </div>\n                    </div>\n                    <a class=\"carousel-control carousel-control-prev\" href=\"#{{sliderId}}\" role=\"button\" data-slide=\"prev\" data-bs-slide=\"prev\" mbr-if=\"arrows\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-prev\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden\">Précédent</span>\n                    </a>\n                    <a class=\"carousel-control carousel-control-next\" href=\"#{{sliderId}}\" role=\"button\" data-slide=\"next\" data-bs-slide=\"next\" mbr-if=\"arrows\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-next\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden\">Suivant</span>\n                    </a>\n                </div>\n            </div>\n            \n            <!-- Infos Artiste -->\n            <div class=\"col-12 col-lg artist-info-col\">\n                <div class=\"artist-info-wrapper\">\n                    <h2 class=\"artist-name mbr-fonts-style mbr-white\" mbr-if=\"showName\" mbr-theme-style=\"display-2\" data-app-selector=\".artist-name\" mbr-style=\"{'color': artistNameColor, '-webkit-text-fill-color': artistNameColor, 'background-image': 'none'}\">\n                        <b>Kuranaika</b></h2>\n                    <p class=\"artist-description mbr-fonts-style mbr-white\" mbr-if=\"showDescription\" mbr-theme-style=\"display-7\" data-app-selector=\".artist-description\">🌟Hello je suis Kuranaika!🌟\n<br>Artiste furry depuis 2014, je propose des illustrations de vos fursonas avec un style doux et expressif, en mettant l'accent sur ce qui les rend uniques✨️<br></p>\n                    <div class=\"artist-btn-wrapper\" mbr-if=\"showDetailsBtn\">\n                        <button mbr-if=\"!btnRedirect\" class=\"btn btn-artist-details\" onclick=\"openArtistModal(this)\" mbr-style=\"{'background-color': btnColor, 'background-image': 'none'}\" data-website=\"{{artistWebsite}}\" data-instagram=\"{{artistInstagram}}\" data-twitter=\"{{artistTwitter}}\" data-bluesky=\"{{artistBluesky}}\" data-facebook=\"{{artistFacebook}}\" data-telegram=\"{{artistTelegram}}\" data-furaffinity=\"{{artistFuraffinity}}\" data-tiktok=\"{{artistTiktok}}\" data-threads=\"{{artistThreads}}\" data-youtube=\"{{artistYoutube}}\" data-commission-types=\"{{commissionTypes}}\">\n                            <span class=\"btn-icon\">🎨</span> <span mbr-text=\"btnText\"><b>En savoir plus</b></span>\n                        </button>\n                        <a mbr-if=\"btnRedirect\" class=\"btn btn-artist-details\" href=\"{{btnRedirectUrl}}\" target=\"_blank\" rel=\"noopener\" mbr-style=\"{'background-color': btnColor, 'background-image': 'none', 'text-decoration': 'none', 'color': '#fff'}\">\n                            <span class=\"btn-icon\">🎨</span> <span mbr-text=\"btnText\">En savoir plus</span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n            \n        </div>\n    </div>\n    </div>\n    \n    <!-- Modal Artiste -->\n    <div class=\"artist-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"artist-modal-title\" aria-hidden=\"true\">\n        <div class=\"artist-modal-overlay\"></div>\n        <div class=\"artist-modal-content\" tabindex=\"-1\">\n            <div class=\"artist-modal-header\">\n                <h3 class=\"artist-modal-title\" id=\"artist-modal-title\"></h3>\n                <button class=\"artist-modal-close\" aria-label=\"Fermer\">×</button>\n            </div>\n            <div class=\"artist-modal-body\"></div>\n        </div>\n    </div>\n    \n    <!-- Script Modal Artiste -->\n    [JS_CODE_0]\n</section>",
          "_JSplaceholders": [
            "<script>\n    (function() {\n        'use strict';\n        \n        let currentKeyHandler = null;\n        let lastFocusedElement = null;\n        \n        // Échapper le HTML\n        function escapeHtml(text) {\n            if (!text) return '';\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n        \n        // Ouvrir la modal artiste\n        window.openArtistModal = function(btn) {\n            const section = btn.closest('.module-artiste');\n            const modal = section.querySelector('.artist-modal');\n            const titre = section.querySelector('.artist-modal-title');\n            const corps = section.querySelector('.artist-modal-body');\n            \n            if (!modal || !titre || !corps) return;\n            \n            // Récupérer les infos de l'artiste\n            const artistName = section.querySelector('.artist-name')?.textContent || 'Artiste';\n            const artistDesc = section.querySelector('.artist-description')?.textContent || '';\n            const website = btn.dataset.website || '';\n            const instagram = btn.dataset.instagram || '';\n            const twitter = btn.dataset.twitter || '';\n            const bluesky = btn.dataset.bluesky || '';\n            const facebook = btn.dataset.facebook || '';\n            const telegram = btn.dataset.telegram || '';\n            const furaffinity = btn.dataset.furaffinity || '';\n            const tiktok = btn.dataset.tiktok || '';\n            const threads = btn.dataset.threads || '';\n            const youtube = btn.dataset.youtube || '';\n            const commissionTypes = btn.dataset.commissionTypes || '';\n\n            titre.textContent = artistName;\n            lastFocusedElement = btn;\n            \n            let html = '<div class=\"artist-modal-grid\">';\n            \n            // Colonne gauche\n            html += '<div class=\"artist-modal-left\">';\n            \n            // Description\n            if (artistDesc) {\n                html += `\n                    <div class=\"artist-info-row\">\n                        <span class=\"artist-info-icon\">📝</span>\n                        <div class=\"artist-info-content\">\n                            <div class=\"artist-info-label\">À propos</div>\n                            <div class=\"artist-info-text\">${escapeHtml(artistDesc)}</div>\n                        </div>\n                    </div>`;\n            }\n            \n            // Site web et réseaux sociaux\n            const hasLinks = website || instagram || twitter || bluesky || facebook || telegram || furaffinity || tiktok || threads || youtube;\n            if (hasLinks) {\n                html += `\n                    <div class=\"artist-info-row\">\n                        <span class=\"artist-info-icon\">🔗</span>\n                        <div class=\"artist-info-content\">\n                            <div class=\"artist-info-label\">Liens & Réseaux sociaux</div>\n                            <div class=\"artist-social-links\">`;\n                \n                if (website) {\n                    html += `<a href=\"${escapeHtml(website)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-website\" title=\"Site Web\"><span class=\"social-icon socicon socicon-internet\"></span><span class=\"social-name\">Site Web</span></a>`;\n                }\n                if (instagram) {\n                    const igUrl = instagram.startsWith('http') ? instagram : `https://instagram.com/${instagram.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(igUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-instagram\" title=\"Instagram\"><span class=\"social-icon socicon socicon-instagram\"></span><span class=\"social-name\">Instagram</span></a>`;\n                }\n                if (twitter) {\n                    const twUrl = twitter.startsWith('http') ? twitter : `https://x.com/${twitter.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(twUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-twitter\" title=\"Twitter/X\"><span class=\"social-icon socicon socicon-twitter\"></span><span class=\"social-name\">Twitter/X</span></a>`;\n                }\n                if (bluesky) {\n                    const bsUrl = bluesky.startsWith('http') ? bluesky : `https://bsky.app/profile/${bluesky.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(bsUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-bluesky\" title=\"Bluesky\"><span class=\"social-icon socicon socicon-bluesky\"></span><span class=\"social-name\">Bluesky</span></a>`;\n                }\n                if (facebook) {\n                    const fbUrl = facebook.startsWith('http') ? facebook : `https://facebook.com/${facebook}`;\n                    html += `<a href=\"${escapeHtml(fbUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-facebook\" title=\"Facebook\"><span class=\"social-icon socicon socicon-facebook\"></span><span class=\"social-name\">Facebook</span></a>`;\n                }\n                if (telegram) {\n                    const tgUrl = telegram.startsWith('http') ? telegram : `https://t.me/${telegram.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(tgUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-telegram\" title=\"Telegram\"><span class=\"social-icon socicon socicon-telegram\"></span><span class=\"social-name\">Telegram</span></a>`;\n                }\n                if (furaffinity) {\n                    const faUrl = furaffinity.startsWith('http') ? furaffinity : `https://www.furaffinity.net/user/${furaffinity}`;\n                    html += `<a href=\"${escapeHtml(faUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-furaffinity\" title=\"FurAffinity\"><img class=\"social-icon-img\" src=\"https://www.furaffinity.net/themes/beta/img/banners/fa_logo.webp?v2\" alt=\"FA\"><span class=\"social-name\">FurAffinity</span></a>`;\n                }\n                if (tiktok) {\n                    const tkUrl = tiktok.startsWith('http') ? tiktok : `https://www.tiktok.com/@${tiktok.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(tkUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-tiktok\" title=\"TikTok\"><span class=\"social-icon socicon socicon-tiktok\"></span><span class=\"social-name\">TikTok</span></a>`;\n                }\n                if (threads) {\n                    const thUrl = threads.startsWith('http') ? threads : `https://www.threads.net/@${threads.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(thUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-threads\" title=\"Threads\"><span class=\"social-icon socicon socicon-threads\"></span><span class=\"social-name\">Threads</span></a>`;\n                }\n                if (youtube) {\n                    const ytUrl = youtube.startsWith('http') ? youtube : `https://www.youtube.com/@${youtube.replace('@', '')}`;\n                    html += `<a href=\"${escapeHtml(ytUrl)}\" target=\"_blank\" rel=\"noopener\" class=\"social-btn social-youtube\" title=\"YouTube\"><span class=\"social-icon socicon socicon-youtube\"></span><span class=\"social-name\">YouTube</span></a>`;\n                }\n                \n                html += `</div>\n                        </div>\n                    </div>`;\n            }\n            \n            // Types de commandes\n            if (commissionTypes) {\n                const types = commissionTypes.split(',').map(t => t.trim());\n                html += `\n                    <div class=\"artist-info-row\">\n                        <span class=\"artist-info-icon\">🎨</span>\n                        <div class=\"artist-info-content\">\n                            <div class=\"artist-info-label\">Ce que l'artiste peut réaliser</div>\n                            <div class=\"commission-types\">\n                                ${types.map(t => `<span class=\"commission-tag\">${escapeHtml(t)}</span>`).join('')}\n                            </div>\n                        </div>\n                    </div>`;\n            }\n            \n            html += '</div>'; // Fin colonne gauche\n\n            // Colonne droite - Galerie uniquement\n            const carouselImgs = section.querySelectorAll('.carousel-inner img');\n            if (carouselImgs.length > 0) {\n                html += '<div class=\"artist-modal-right artist-modal-gallery-col\">';\n                html += `\n                    <div class=\"artist-info-row gallery-row\">\n                        <span class=\"artist-info-icon\">🖼️</span>\n                        <div class=\"artist-info-content\">\n                            <div class=\"artist-info-label\">Galerie</div>\n                            <div class=\"artist-gallery-stack\">`;\n                carouselImgs.forEach(img => {\n                    html += `<img src=\"${escapeHtml(img.src)}\" alt=\"${escapeHtml(img.alt || 'Oeuvre')}\" class=\"artist-gallery-img\" onclick=\"openCarouselFullscreen(this)\">`;\n                });\n                html += `</div>\n                        </div>\n                    </div>`;\n                html += '</div>'; // Fin colonne droite galerie\n            }\n            \n            html += '</div>'; // Fin grid\n            \n            corps.innerHTML = html;\n            \n            // Afficher la modal\n            document.body.classList.add('modal-open');\n            modal.classList.add('show');\n            \n            // Events fermeture\n            const closeBtn = modal.querySelector('.artist-modal-close');\n            const overlay = modal.querySelector('.artist-modal-overlay');\n            \n            if (closeBtn) {\n                closeBtn.onclick = () => closeArtistModal(section);\n                closeBtn.focus();\n            }\n            if (overlay) overlay.onclick = () => closeArtistModal(section);\n            \n            // Échap pour fermer\n            if (currentKeyHandler) document.removeEventListener('keydown', currentKeyHandler);\n            currentKeyHandler = (e) => {\n                if (e.key === 'Escape') closeArtistModal(section);\n            };\n            document.addEventListener('keydown', currentKeyHandler);\n        };\n        \n        // Fermer la modal\n        function closeArtistModal(section) {\n            const modal = section.querySelector('.artist-modal');\n            if (modal && modal.classList.contains('show')) {\n                modal.classList.add('closing');\n                document.body.classList.remove('modal-open');\n                setTimeout(() => modal.classList.remove('show', 'closing'), 300);\n                \n                if (currentKeyHandler) {\n                    document.removeEventListener('keydown', currentKeyHandler);\n                    currentKeyHandler = null;\n                }\n                \n                if (lastFocusedElement) {\n                    lastFocusedElement.focus();\n                    lastFocusedElement = null;\n                }\n            }\n        }\n\n        // Ouvrir l'image du carrousel en plein écran\n        window.openCarouselFullscreen = function(img) {\n            const fullscreen = document.createElement('div');\n            fullscreen.className = 'carousel-fullscreen';\n            \n            fullscreen.style.cssText = `\n                position: fixed;\n                top: 0;\n                left: 0;\n                width: 100vw;\n                height: 100vh;\n                z-index: 2147483648;\n                display: flex;\n                align-items: center;\n                justify-content: center;\n                opacity: 0;\n                transition: opacity 0.3s ease;\n            `;\n            \n            fullscreen.innerHTML = `\n                <div class=\"carousel-fullscreen-overlay\" style=\"\n                    position: absolute;\n                    top: 0;\n                    left: 0;\n                    width: 100%;\n                    height: 100%;\n                    background: rgba(60, 60, 60, 0.92);\n                    cursor: pointer;\n                \"></div>\n                <img src=\"${img.src}\" alt=\"${escapeHtml(img.alt || 'Image')}\" style=\"\n                    position: relative;\n                    max-width: 95vw;\n                    max-height: 95vh;\n                    object-fit: contain;\n                    z-index: 1;\n                \">\n                <button class=\"carousel-fullscreen-close\" style=\"\n                    position: absolute;\n                    top: 1.5rem;\n                    right: 1.5rem;\n                    background: rgba(255, 255, 255, 0.2);\n                    border: none;\n                    color: white;\n                    font-size: 2.5rem;\n                    width: 3.5rem;\n                    height: 3.5rem;\n                    border-radius: 50%;\n                    cursor: pointer;\n                    display: flex;\n                    align-items: center;\n                    justify-content: center;\n                    z-index: 2;\n                    transition: all 0.3s;\n                \">×</button>\n            `;\n            document.body.appendChild(fullscreen);\n            \n            const closeBtn = fullscreen.querySelector('.carousel-fullscreen-close');\n            \n            closeBtn.addEventListener('mouseenter', () => {\n                closeBtn.style.background = 'rgba(255, 110, 180, 0.6)';\n                closeBtn.style.transform = 'rotate(90deg) scale(1.1)';\n            });\n            closeBtn.addEventListener('mouseleave', () => {\n                closeBtn.style.background = 'rgba(255, 255, 255, 0.2)';\n                closeBtn.style.transform = 'none';\n            });\n            \n            const close = () => {\n                fullscreen.style.opacity = '0';\n                setTimeout(() => fullscreen.remove(), 300);\n            };\n            \n            fullscreen.querySelector('.carousel-fullscreen-overlay').onclick = close;\n            closeBtn.onclick = close;\n            \n            const keyHandler = (e) => {\n                if (e.key === 'Escape') {\n                    close();\n                    document.removeEventListener('keydown', keyHandler);\n                }\n            };\n            document.addEventListener('keydown', keyHandler);\n            \n            requestAnimationFrame(() => {\n                fullscreen.style.opacity = '1';\n            });\n        };\n    })();\n    </script>"
          ],
          "_PHPplaceholders": [],
          "_anchor": "header09-1s",
          "_isUserblock": true,
          "_cid": "vg0qi9cXO8",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "position": "relative",
            "background-color": "@cornerColor",
            ".module-inner": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)",
              "position": "relative",
              "border-radius": "0 0 30px 30px",
              "overflow": "hidden",
              "& when (@bg-type = \"color\")": {
                "background-color": "@bg-value"
              },
              "& when (@bg-type = \"image\")": {
                "background-image": "url(@bg-value)",
                "background-size": "cover",
                "background-position": "center center"
              }
            },
            ".mbr-overlay": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "pointer-events": "none"
            },
            ".row": {
              "gap": "2rem"
            },
            ".carousel-col": {
              "padding": "0"
            },
            ".artist-info-col": {
              "display": "flex",
              "align-items": "center"
            },
            ".artist-info-wrapper": {
              "padding": "2rem",
              "width": "100%"
            },
            ".artist-name": {
              "margin-bottom": "1.5rem",
              "background": "linear-gradient(90deg, #ff6eb4, #c471ed, #8b5cf6)",
              "-webkit-background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "background-clip": "text",
              "color": "#edefeb"
            },
            ".artist-description": {
              "margin-bottom": "2rem",
              "opacity": "0.9",
              "line-height": "1.7",
              "color": "#edefeb"
            },
            ".artist-btn-wrapper": {
              "margin-top": "1.5rem"
            },
            ".btn-artist-details": {
              "display": "inline-flex",
              "align-items": "center",
              "gap": "0.75rem",
              "padding": "1rem 2rem",
              "background-color": "#ff6eb4",
              "border": "none",
              "border-radius": "30px",
              "color": "#fff",
              "font-size": "1.1rem",
              "font-weight": "600",
              "cursor": "pointer",
              "transition": "all 0.3s ease",
              "box-shadow": "0 4px 20px rgba(0, 0, 0, 0.3)"
            },
            ".btn-artist-details:hover": {
              "transform": "translateY(-3px)",
              "box-shadow": "0 8px 30px rgba(255, 110, 180, 0.6)"
            },
            ".btn-artist-details .btn-icon": {
              "font-size": "1.3rem"
            },
            "@media (min-width: 992px)": {
              ".carousel": {
                "max-height": "(@carouselHeight * 100px)",
                "border-radius": "16px",
