              "color": "inherit"
            },
            ".location-google": {
              "background": "rgba(66, 133, 244, 0.75)",
              "border-color": "rgba(66, 133, 244, 0.5)"
            },
            ".location-google:hover": {
              "background": "#4285F4",
              "box-shadow": "0 4px 14px rgba(66, 133, 244, 0.45)",
              "transform": "translateY(-1px)"
            },
            ".location-waze": {
              "background": "rgba(0, 198, 219, 0.75)",
              "border-color": "rgba(0, 198, 219, 0.5)"
            },
            ".location-waze:hover": {
              "background": "#00C6DB",
              "box-shadow": "0 4px 14px rgba(0, 198, 219, 0.45)",
              "transform": "translateY(-1px)"
            },
            ".location-apple": {
              "background": "rgba(140, 140, 155, 0.75)",
              "border-color": "rgba(140, 140, 155, 0.5)"
            },
            ".location-apple:hover": {
              "background": "#8c8c9b",
              "box-shadow": "0 4px 14px rgba(140, 140, 155, 0.45)",
              "transform": "translateY(-1px)"
            },
            ".event-url-button": {
              "display": "inline-flex",
              "align-items": "center",
              "gap": "0.4rem",
              "margin-top": "0.5rem",
              "padding": "0.55rem 1.1rem",
              "background": "linear-gradient(135deg, #ff6eb4, #c471ed)",
              "color": "#fff !important",
              "text-decoration": "none",
              "border-radius": "20px",
              "font-weight": "600",
              "font-size": "0.88rem",
              "transition": "all 0.2s ease"
            },
            ".event-url-button:hover": {
              "transform": "translateY(-2px)",
              "box-shadow": "0 6px 20px rgba(255, 110, 180, 0.45)",
              "color": "#fff !important"
            },
            "@keyframes modalFadeIn": {
              "from": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              },
              "to": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              }
            },
            "@keyframes modalFadeOut": {
              "from": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              },
              "to": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              }
            },
            "@keyframes events-spin": {
              "0%": {
                "transform": "rotate(0deg)"
              },
              "100%": {
                "transform": "rotate(360deg)"
              }
            },
            "@media (min-width: 768px)": {
              "align-items": "~\"@{verticalAlign}\"",
              ".row": {
                "justify-content": "~\"@{horizontalAlign}\""
              }
            },
            "@media (min-width: 760px)": {
              ".event-modal-body-grid": {
                "grid-template-columns": "1fr 1fr"
              }
            },
            "@media (min-width: 992px)": {
              ".content-wrap": {
                "padding": "2.5rem 2rem"
              }
            },
            "@media (max-width: 991px)": {
              ".events-grid": {
                "grid-template-columns": "repeat(2, minmax(0, 1fr))"
              }
            },
            "@media (max-width: 991px) and (min-width: 768px)": {
              ".content-wrap": {
                "min-width": "70%"
              }
            },
            "@media (max-width: 767px)": {
              "-webkit-align-items": "center",
              "align-items": "center",
              ".row": {
                "-webkit-justify-content": "center",
                "justify-content": "center"
              },
              ".content-wrap": {
                "width": "100%",
                "padding": "1.5rem 0.75rem"
              },
              ".events-grid": {
                "grid-template-columns": "1fr",
                "gap": "0.9rem",
                "padding-top": "0.8rem"
              },
              ".event-modal": {
                "padding": "0 !important",
                "align-items": "stretch !important"
              },
              ".event-modal-overlay": {
                "position": "fixed !important",
                "inset": "0 !important"
              },
              ".event-modal-content": {
                "position": "fixed !important",
                "inset": "0 !important",
                "width": "100vw !important",
                "max-width": "100vw !important",
                "height": "100vh !important",
                "max-height": "100vh !important",
                "margin": "0 !important",
                "border-radius": "0 !important",
                "box-shadow": "none !important",
                "animation": "sheetUp 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
              },
              ".event-modal.closing .event-modal-content": {
                "animation": "sheetDown 0.25s ease forwards"
              },
              ".event-modal-header": {
                "padding": "1.5rem 1.25rem 1rem !important",
                "position": "sticky !important",
                "top": "0 !important",
                "z-index": "10 !important",
                "background": "linear-gradient(155deg, #1e1430 0%, #120d22 60%, #0d0a1c 100%)"
              },
              ".event-modal-body": {
                "padding": "1rem 1.25rem 2rem !important",
                "flex": "1",
                "overflow-y": "auto"
              },
              ".event-modal-title": {
                "font-size": "1.3rem !important"
              },
              ".location-btn": {
                "min-width": "100%"
              }
            },
            "@keyframes sheetUp": {
              "from": {
                "transform": "translateY(100%)"
              },
              "to": {
                "transform": "translateY(0)"
              }
            },
            "@keyframes sheetDown": {
              "from": {
                "transform": "translateY(0)"
              },
              "to": {
                "transform": "translateY(100%)"
              }
            }
          },
          "_name": "header09",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\"\n         class=\"header-actus-fullscreen startm5\"\n         group=\"Headers\"\n         data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\"\n         mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline name=\"contentWidth\" title=\"Content Width\" min=\"6\" max=\"12\" step=\"1\" value=\"12\">\n\n        <header>Show / Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Follow Button\" name=\"showButtons\" checked>\n\n        <select title=\"Vertical Align\" name=\"verticalAlign\" condition=\"fullScreen\">\n            <option value=\"flex-start\">Top</option>\n            <option value=\"center\" selected>Center</option>\n            <option value=\"flex-end\">Bottom</option>\n        </select>\n\n        <select title=\"Horizontal Align\" name=\"horizontalAlign\">\n            <option value=\"flex-start\">Left</option>\n            <option value=\"center\" selected>Center</option>\n            <option value=\"flex-end\">Right</option>\n        </select>\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/img-2921-2000x1186.webp\" selected parallax>\n            <input type=\"color\" title=\"Color\" value=\"#1a1a2e\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#1a1a2e\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\"\n         mbr-if=\"overlay && bg.type !== 'color'\"\n         opacity=\"{{overlayOpacity}}\"\n         bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"content-wrap col-12 col-md-{{contentWidth}}\">\n\n                <h1 class=\"mbr-section-title mbr-fonts-style mbr-white mb-3\"\n                    mbr-theme-style=\"display-2\"\n                    data-app-selector=\".mbr-section-title\"\n                    mbr-if=\"showTitle\">\n                    <b>📢 Les actus de la Meute !</b>\n                </h1>\n\n                <p class=\"mbr-fonts-style mbr-text mbr-white mb-4\"\n                   mbr-theme-style=\"display-7\"\n                   mbr-if=\"showSubtitle\"\n                   data-app-selector=\".mbr-text\">\n                    Découvrez les prochains événements auxquels notre groupe participe.\n                </p>\n\n                <div class=\"events-grid\" id=\"events-grid\" aria-live=\"polite\"></div>\n\n                <p class=\"mbr-fonts-style mbr-white mt-4 mb-2 telegram-note\"\n                   mbr-theme-style=\"display-7\">\n                    <i>Retrouvez ici toutes nos annonces et événements en direct de notre canal Telegram !</i><br>\n                    <i>(Pas besoin d'avoir obligatoirement un compte)</i>\n                </p>\n\n                <div class=\"mbr-section-btn\"\n                     mbr-if=\"showButtons\"\n                     data-toolbar=\"-mbrBtnMove\"\n                     mbr-buttons\n                     mbr-theme-style=\"display-7\">\n                    <a class=\"btn btn-primary\"\n                       href=\"https://t.me/Annonces_Meute_Normande\"\n                       target=\"_blank\"\n                       rel=\"noopener noreferrer\"\n                       data-app-placeholder=\"Type Text\">\n                        <span class=\"telegram-icon p-2 mbr-iconfont socicon-telegram socicon\" aria-hidden=\"true\"></span>\n                        Rejoindre le canal Telegram\n                    </a>\n                </div>\n\n            </div>\n        </div>\n    </div>\n\n    <!-- MODALE standard centrée -->\n    <div class=\"event-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"event-modal-title\" aria-hidden=\"true\">\n        <div class=\"event-modal-overlay\"></div>\n        <div class=\"event-modal-content\" tabindex=\"-1\">\n            <div class=\"event-modal-header\">\n                <h3 class=\"event-modal-title\" id=\"event-modal-title\"></h3>\n                <button class=\"event-modal-close\" aria-label=\"Fermer\">×</button>\n            </div>\n            <div class=\"event-modal-body\"></div>\n        </div>\n    </div>\n\n    [JS_CODE_0]\n</section>\n",
          "_cid": "vfPilZdu2W",
          "_anchor": "header09-1l",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n    (function() {\n        'use strict';\n\n        // Fix z-index navbar + modal fullscreen mobile : injection globale dans <head>\n        // ⚠️ EXCLUT les modules artistes (.module-artiste) et leurs modales (.artist-modal)\n        // EXCLUT les modales gallery bloc (.artistgallery1) et leurs modales (.ag-modal)\n        // EXCLUT les fullscreen overlays (.carousel-fullscreen, .pricing-fullscreen)\n        (function() {\n            var s = document.createElement('style');\n            s.textContent = ''\n                + 'body.modal-open{overflow:hidden}'\n                + 'body.modal-open>*:not(.module-artiste):not(.artistgallery1):not(.carousel-fullscreen):not(.pricing-fullscreen){z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste{z-index:0!important;position:relative}'\n                + 'body.modal-open>.artistgallery1{z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste:has(.artist-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>.artistgallery1:has(.ag-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.event-modal){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.legal-modal){z-index:2147483647!important}'\n                + '.carousel-fullscreen,.pricing-fullscreen{position:fixed!important;z-index:2147483648!important}'\n                + '@media(max-width:767px){'\n                    + '.event-modal{padding:0!important;align-items:stretch!important}'\n                    + '.event-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.event-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:eventSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.event-modal.closing .event-modal-content{animation:eventSheetDown .25s ease forwards}'\n                    + '.event-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.event-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.event-modal-title{font-size:1.3rem!important}'\n                + '}'\n                + '@keyframes eventSheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}'\n                + '@keyframes eventSheetDown{from{transform:translateY(0)}to{transform:translateY(100%)}}';\n            document.head.appendChild(s);\n        })();\n\n        const CONFIG = {\n            ICAL_URL: 'https://lameutenormande.fr/events.ics',\n            MAX_EVENTS: 3,\n            EVENT_FILTER: 'go@events.lameutenormande',\n            FUTURE_DAYS: 365\n        };\n\n        let conventions = [];\n        let currentKeyHandler = null;\n        let lastFocusedElement = null;\n\n        function chargerICAL() {\n            return new Promise((resolve, reject) => {\n                if (typeof ICAL !== 'undefined') {\n                    resolve();\n                    return;\n                }\n                const s = document.createElement('script');\n                s.src = 'https://cdn.jsdelivr.net/npm/ical.js@1.5.0/build/ical.min.js';\n                s.crossOrigin = 'anonymous';\n                s.onload = () => (typeof ICAL !== 'undefined' ? resolve() : reject(new Error('ICAL indéfini')));\n                s.onerror = () => reject(new Error('Échec CDN ICAL.js'));\n                document.head.appendChild(s);\n            });\n        }\n\n        function attendeeContainsFilter(prop, filter) {\n            try {\n                const raw = JSON.stringify(prop.jCal || '').toLowerCase();\n                if (raw.includes(filter)) return true;\n\n                const val = String(prop.getFirstValue() || '').toLowerCase();\n                if (val.includes(filter)) return true;\n\n                const cn = String(prop.getParameter('cn') || '').toLowerCase();\n                if (cn.includes(filter)) return true;\n            } catch (e) {}\n            return false;\n        }\n\n        function parserICSManuel(texte) {\n            const filter = CONFIG.EVENT_FILTER.toLowerCase();\n            const now = new Date();\n            const cutoff = new Date(now.getTime() + CONFIG.FUTURE_DAYS * 86400000);\n            const events = [];\n\n            const blocs = texte.split('BEGIN:VEVENT');\n\n            for (let i = 1; i < blocs.length; i++) {\n                const bloc = blocs[i].split('END:VEVENT');\n                const unfolded = bloc.replace(/\\r\\n[ \\t]/g, '').replace(/\\n[ \\t]/g, '');\n                const lines = unfolded.split(/\\r?\\n/);\n\n                let summary = '';\n                let dtstart = '';\n                let dtend = '';\n                let location = '';\n                let url = '';\n                let description = '';\n                let isGo = false;\n\n                for (const line of lines) {\n                    const ci = line.indexOf(':');\n                    if (ci === -1) continue;\n\n                    const keyFull = line.substring(0, ci);\n                    const key = keyFull.split(';').toUpperCase();\n                    const val = line.substring(ci + 1).trim();\n\n                    if (key === 'SUMMARY') summary = val.replace(/\\\\,/g, ',').replace(/\\\\n/g, '\\n');\n                    else if (key === 'DTSTART') dtstart = val;\n                    else if (key === 'DTEND') dtend = val;\n                    else if (key === 'LOCATION') location = val.replace(/\\\\,/g, ',');\n                    else if (key === 'URL') url = val;\n                    else if (key === 'DESCRIPTION') description = val.replace(/\\\\n/g, '\\n').replace(/\\\\,/g, ',');\n                    else if (key === 'ATTENDEE' && line.toLowerCase().includes(filter)) isGo = true;\n                }\n\n                if (!isGo || !dtstart) continue;\n\n                let startDate = null;\n                try {\n                    const d = dtstart.replace(/[TZ\\-:]/g, '');\n                    const y = +d.substring(0, 4);\n                    const mo = +d.substring(4, 6) - 1;\n                    const day = +d.substring(6, 8);\n                    let h = 0;\n                    let mi = 0;\n                    let s = 0;\n\n                    if (d.length >= 12) {\n                        h = +d.substring(8, 10);\n                        mi = +d.substring(10, 12);\n                    }\n                    if (d.length >= 14) {\n                        s = +d.substring(12, 14);\n                    }\n\n                    startDate = new Date(Date.UTC(y, mo, day, h, mi, s));\n                } catch (e) {\n                    continue;\n                }\n\n                if (!startDate || startDate < now || startDate > cutoff) continue;\n\n                let endDate = null;\n                if (dtend) {\n                    try {\n                        const d = dtend.replace(/[TZ\\-:]/g, '');\n                        const y = +d.substring(0, 4);\n                        const mo = +d.substring(4, 6) - 1;\n                        const day = +d.substring(6, 8);\n                        let h = 0;\n                        let mi = 0;\n                        let s = 0;\n\n                        if (d.length >= 12) {\n                            h = +d.substring(8, 10);\n                            mi = +d.substring(10, 12);\n                        }\n                        if (d.length >= 14) {\n                            s = +d.substring(12, 14);\n                        }\n\n                        endDate = new Date(Date.UTC(y, mo, day, h, mi, s));\n                    } catch (e) {}\n                }\n\n                events.push({\n                    title: summary || 'Convention',\n                    description,\n                    location,\n                    url,\n                    startDate,\n                    endDate\n                });\n            }\n\n            events.sort((a, b) => a.startDate - b.startDate);\n            return events.slice(0, CONFIG.MAX_EVENTS);\n        }\n\n        async function chargerConventions() {\n            const url = CONFIG.ICAL_URL + '?v=' + Date.now();\n            const r = await fetch(url, { cache: 'no-store' });\n\n            if (!r.ok) throw new Error('HTTP ' + r.status);\n\n            const texte = await r.text();\n            if (!texte.includes('BEGIN:VCALENDAR')) {\n                throw new Error('Pas un fichier ICS valide');\n            }\n\n            try {\n                await chargerICAL();\n\n                const now = new Date();\n                const cutoff = new Date(now.getTime() + CONFIG.FUTURE_DAYS * 86400000);\n                const filter = CONFIG.EVENT_FILTER.toLowerCase();\n\n                const comp = new ICAL.Component(ICAL.parse(texte));\n                const vevents = comp.getAllSubcomponents('vevent');\n\n                const events = vevents\n                    .map(v => {\n                        const e = new ICAL.Event(v);\n                        const attendees = v.getAllProperties('attendee');\n                        const isGo = attendees.some(a => attendeeContainsFilter(a, filter));\n\n                        if (!isGo) return null;\n\n                        const startDate = e.startDate ? e.startDate.toJSDate() : null;\n                        const endDate = e.endDate ? e.endDate.toJSDate() : null;\n\n                        if (!startDate || startDate < now || startDate > cutoff) return null;\n\n                        return {\n                            title: e.summary || 'Convention',\n                            description: e.description || '',\n                            location: e.location || '',\n                            url: v.getFirstPropertyValue('url') || '',\n                            startDate,\n                            endDate\n                        };\n                    })\n                    .filter(Boolean);\n\n                events.sort((a, b) => a.startDate - b.startDate);\n                const result = events.slice(0, CONFIG.MAX_EVENTS);\n\n                if (!result.length) {\n                    console.warn('⚠️ ICAL.js 0 résultat → fallback parser manuel');\n                    return parserICSManuel(texte);\n                }\n\n                return result;\n            } catch (e) {\n                console.warn('⚠️ ICAL.js échoué, fallback manuel:', e.message);\n                return parserICSManuel(texte);\n            }\n        }\n\n        function escapeHtml(t) {\n            if (!t) return '';\n            const d = document.createElement('div');\n            d.textContent = t;\n            return d.innerHTML;\n        }\n\n        function linkify(t) {\n            return escapeHtml(t)\n                .replace(/(https?:\\/\\/[^\\s<]+)/g, '<a href=\"$1\" target=\"_blank\" rel=\"noopener noreferrer\">$1</a>')\n                .replace(/\\n/g, '<br>');\n        }\n\n        function formatDate(date) {\n            if (!date) {\n                return { jour: '?', mois: '???', complet: 'Date inconnue' };\n            }\n\n            return {\n                jour: date.getUTCDate(),\n                mois: date\n                    .toLocaleDateString('fr-FR', { month: 'short', timeZone: 'UTC' })\n                    .replace('.', '')\n                    .toUpperCase(),\n                complet: date.toLocaleDateString('fr-FR', {\n                    weekday: 'long',\n                    day: 'numeric',\n                    month: 'long',\n                    year: 'numeric',\n                    timeZone: 'UTC'\n                })\n            };\n        }\n\n        function countdown(date) {\n            if (!date) return '';\n            const diff = Math.ceil((date - new Date()) / 86400000);\n            if (diff === 0) return \"Aujourd'hui !\";\n            if (diff === 1) return 'Demain !';\n            if (diff < 0) return 'Passé';\n            return 'Dans ' + diff + ' jours';\n        }\n\n        function afficherChargement(grid) {\n            grid.innerHTML = `\n                <div class=\"events-loading\">\n                    <div class=\"loading-spinner\" aria-hidden=\"true\"></div>\n                    <p>Chargement des conventions...</p>\n                </div>`;\n        }\n\n        function afficherMessage(grid, msg, isError) {\n            grid.innerHTML = `\n                <div class=\"events-message ${isError ? 'error' : 'info'}\">\n                    <span aria-hidden=\"true\">${isError ? '⚠️' : 'ℹ️'}</span>\n                    <p>${escapeHtml(msg)}</p>\n                </div>`;\n        }\n\n        function genererTuiles(grid) {\n            if (!conventions.length) {\n                afficherMessage(grid, 'Aucune convention prévue pour le moment', false);\n                return;\n            }\n\n            grid.innerHTML = '';\n\n            conventions.forEach(event => {\n                const date = formatDate(event.startDate);\n                const tile = document.createElement('article');\n\n                tile.className = 'event-tile';\n                tile.tabIndex = 0;\n                tile.setAttribute('role', 'button');\n                tile.setAttribute('aria-label', 'Voir les détails de ' + (event.title || 'cet événement'));\n\n                tile.innerHTML = `\n                    <div class=\"event-tile-date\">\n                        <span class=\"event-tile-day\">${date.jour}</span>\n                        <span class=\"event-tile-month\">${date.mois}</span>\n                    </div>\n                    <div class=\"event-tile-content\">\n                        <h3 class=\"event-tile-title\">${escapeHtml(event.title)}</h3>\n                        ${event.location ? `<p class=\"event-tile-location\"><span>📍</span> ${escapeHtml(event.location)}</p>` : ''}\n                        <p class=\"event-tile-countdown\">${countdown(event.startDate)}</p>\n                    </div>\n                    <div class=\"event-tile-arrow\" aria-hidden=\"true\">▶</div>\n                `;\n\n                const open = () => {\n                    lastFocusedElement = tile;\n                    ouvrirPopup(event);\n                };\n\n                tile.addEventListener('click', open);\n                tile.addEventListener('keydown', e => {\n                    if (e.key === 'Enter' || e.key === ' ') {\n                        e.preventDefault();\n                        open();\n                    }\n                });\n\n                grid.appendChild(tile);\n            });\n        }\n\n        function ouvrirPopup(event) {\n            const modal = document.querySelector('.event-modal');\n            const modalContent = document.querySelector('.event-modal-content');\n            const titre = document.querySelector('.event-modal-title');\n            const corps = document.querySelector('.event-modal-body');\n\n            if (!modal || !modalContent || !titre || !corps) return;\n\n            titre.textContent = event.title || 'Convention';\n\n            const opts = {\n                weekday: 'long',\n                day: 'numeric',\n                month: 'long',\n                year: 'numeric',\n                timeZone: 'UTC'\n            };\n\n            let dateStr = event.startDate\n                ? event.startDate.toLocaleDateString('fr-FR', opts)\n                : 'Date inconnue';\n\n            let dateRange = '';\n            if (event.endDate && event.startDate) {\n                const s = event.startDate.toDateString();\n                const e = event.endDate.toDateString();\n                if (s !== e) {\n                    dateRange = ' au ' + event.endDate.toLocaleDateString('fr-FR', opts);\n                }\n            }\n\n            let html = '<div class=\"event-modal-body-grid\"><div class=\"event-modal-left\">';\n            html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">📅</span><div class=\"event-info-content\"><div class=\"event-info-label\">Date</div><div class=\"event-info-text\">${escapeHtml(dateStr + dateRange)}</div></div></div>`;\n\n            if (event.location) {\n                const loc = encodeURIComponent(event.location);\n                html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">📍</span><div class=\"event-info-content\"><div class=\"event-info-label\">Lieu</div><div class=\"event-info-text\">${escapeHtml(event.location)}</div>\n                    <div class=\"event-location-buttons\">\n                        <a href=\"https://www.google.com/maps/search/?api=1&query=${loc}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-btn location-google\"><svg viewBox=\"0 0 32 32\" class=\"location-btn-logo\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M2 11.9556C2 8.47078 2 6.7284 2.67818 5.39739C3.27473 4.22661 4.22661 3.27473 5.39739 2.67818C6.7284 2 8.47078 2 11.9556 2H20.0444C23.5292 2 25.2716 2 26.6026 2.67818C27.7734 3.27473 28.7253 4.22661 29.3218 5.39739C30 6.7284 30 8.47078 30 11.9556V20.0444C30 23.5292 30 25.2716 29.3218 26.6026C28.7253 27.7734 27.7734 28.7253 26.6026 29.3218C25.2716 30 23.5292 30 20.0444 30H11.9556C8.47078 30 6.7284 30 5.39739 29.3218C4.22661 28.7253 3.27473 27.7734 2.67818 26.6026C2 25.2716 2 23.5292 2 20.0444V11.9556Z\" fill=\"white\" fill-opacity=\"0.15\"/><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M24 12.8116L23.9999 12.8541C23.9998 12.872 23.9996 12.8899 23.9994 12.9078C23.9998 12.9287 24 12.9498 24 12.971C24 16.3073 21.4007 19.2604 19.6614 21.2367C19.1567 21.8101 18.7244 22.3013 18.449 22.6957C17.4694 24.0986 16.952