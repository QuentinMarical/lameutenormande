          "_name": "footer04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\"\n        class=\"footer-modern\"\n        group=\"Footers\"\n        global\n        once=\"footers\"\n        mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#111118\" selected>\n        </fieldset>\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111118\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n\n        <!-- Séparateur -->\n        <div class=\"footer-divider\"></div>\n\n        <!-- Crédits -->\n        <div class=\"footer-credits\">\n            <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".footer-credits .mbr-text\">\n                Site réalisé par <a href=\"tg://resolve?domain=NitraFox\" class=\"footer-link footer-link-nitra\">Nitra🦊</a>\n                &amp; calendrier alimenté par <a href=\"tg://resolve?domain=Spyro_The_Bat\" class=\"footer-link footer-link-spyro\">Spyro the bat🦇</a>\n            </p>\n        </div>\n\n        <!-- Liens légaux -->\n        <div class=\"footer-legal-links\">\n            <button class=\"footer-legal-btn\" data-legal=\"mentions\">Mentions légales</button>\n            <span class=\"footer-legal-sep\" aria-hidden=\"true\">•</span>\n            <button class=\"footer-legal-btn\" data-legal=\"confidentialite\">Politique de confidentialité</button>\n            <span class=\"footer-legal-sep\" aria-hidden=\"true\">•</span>\n            <button class=\"footer-legal-btn\" data-legal=\"cookies\">Politique de cookies</button>\n        </div>\n\n    </div>\n\n    <!-- Modale légale -->\n    <div class=\"legal-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"legal-modal-title\" aria-hidden=\"true\">\n        <div class=\"legal-modal-overlay\"></div>\n        <div class=\"legal-modal-content\" tabindex=\"-1\">\n            <div class=\"legal-modal-header\">\n                <h3 class=\"legal-modal-title\" id=\"legal-modal-title\"></h3>\n                <button class=\"legal-modal-close\" aria-label=\"Fermer\">×</button>\n            </div>\n            <div class=\"legal-modal-body\"></div>\n        </div>\n    </div>\n\n    [JS_CODE_0]\n</section>\n",
          "_cid": "v4N9BybemT",
          "_anchor": "footer04-1j",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n    (function() {\n        'use strict';\n\n        // Fix z-index navbar + modal fullscreen mobile : injection globale dans <head>\n        // ⚠️ EXCLUT les modules artistes (.module-artiste) et leurs modales (.artist-modal)\n        // EXCLUT aussi les modales gallery bloc (.artistgallery1) et leurs modales (.ag-modal)\n        (function() {\n            var s = document.createElement('style');\n            s.textContent = ''\n                /* --- z-index global quand modal ouverte --- */\n                + 'body.modal-open{overflow:hidden}'\n                + 'body.modal-open>*:not(.module-artiste):not(.artistgallery1):not(.carousel-fullscreen):not(.pricing-fullscreen){z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste{z-index:0!important;position:relative}'\n                + 'body.modal-open>.artistgallery1{z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste:has(.artist-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>.artistgallery1:has(.ag-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.event-modal){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.legal-modal){z-index:2147483647!important}'\n\n                /* --- Fullscreen overlays toujours au-dessus de tout --- */\n                + '.carousel-fullscreen,.pricing-fullscreen{position:fixed!important;z-index:2147483648!important}'\n\n                /* --- Legal modal fullscreen sur mobile --- */\n                + '@media(max-width:767px){'\n                    + '.legal-modal{padding:0!important;align-items:stretch!important}'\n                    + '.legal-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.legal-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:legalSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.legal-modal.closing .legal-modal-content{animation:legalSheetDown .25s ease forwards}'\n                    + '.legal-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.legal-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.legal-modal-title{font-size:1.2rem!important}'\n                + '}'\n\n                /* --- Artist modal (.module-artiste) fullscreen mobile --- */\n                + '@media(max-width:767px){'\n                    + '.artist-modal{padding:0!important;align-items:stretch!important}'\n                    + '.artist-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.artist-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:artistSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.artist-modal.closing .artist-modal-content{animation:artistSheetDown .25s ease forwards}'\n                    + '.artist-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.artist-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.artist-modal-title{font-size:1.3rem!important}'\n                + '}'\n\n                /* --- AG modal (.artistgallery1) fullscreen mobile --- */\n                + '@media(max-width:767px){'\n                    + '.ag-modal{padding:0!important;align-items:stretch!important}'\n                    + '.ag-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.ag-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:agSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.ag-modal.closing .ag-modal-content{animation:agSheetDown .25s ease forwards}'\n                    + '.ag-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.ag-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.ag-modal-title{font-size:1.3rem!important}'\n                + '}';\n            document.head.appendChild(s);\n        })();\n\n        /* ---------- Année dynamique ---------- */\n        var yearEl = document.querySelector('.footer-modern .footer-year');\n        if (yearEl) yearEl.textContent = new Date().getFullYear();\n\n        /* ---------- Contenus légaux ---------- */\n        var legalContents = {\n            mentions: {\n                title: 'Mentions légales',\n                body: '<h4>Éditeur du site</h4>'\n                    + '<p>Ce site est édité par <strong>La Meute Normande</strong>, groupe informel à but non lucratif, basé en Haute-Normandie.</p>'\n                    + '<p>Responsable de la publication : <strong>Nitra</strong></p>'\n                    + '<p>Contact : via Telegram <a href=\"tg://resolve?domain=NitraFox\" target=\"_blank\" rel=\"noopener\">@NitraFox</a></p>'\n                    + '<h4>Hébergement</h4>'\n                    + '<p>Ce site est hébergé par <strong>GitHub Pages</strong> — GitHub Inc., 88 Colin P. Kelly Jr. Street, San Francisco, CA 94107, États-Unis.</p>'\n                    + '<p>Le nom de domaine <strong>lameutenormande.fr</strong> est enregistré auprès d\\'<strong>OVH</strong> — OVHcloud, 2 rue Kellermann, 59100 Roubaix, France.</p>'\n                    + '<h4>Conception du site</h4>'\n                    + '<p>Site conçu avec <strong>Mobirise</strong> (générateur de sites statiques).</p>'\n                    + '<p>Développement et intégration : <strong>Nitra</strong> — calendrier des événements : <strong>Spyro the bat</strong>.</p>'\n                    + '<h4>Propriété intellectuelle</h4>'\n                    + '<p>L\\'ensemble du contenu de ce site (textes, images, logos, illustrations) est la propriété de La Meute Normande ou de ses contributeurs respectifs (artistes référencés sur la page Artistes). Toute reproduction sans autorisation préalable est interdite.</p>'\n                    + '<p>Les logos et marques de services tiers (Telegram, Discord, Instagram, Google Maps, Waze, Apple Plans, FurAffinity, Furzo) restent la propriété de leurs détenteurs respectifs.</p>'\n                    + '<h4>Responsabilité</h4>'\n                    + '<p>La Meute Normande s\\'efforce de fournir des informations à jour mais ne saurait être tenue responsable d\\'éventuelles erreurs, omissions ou indisponibilités. Les liens externes (sites d\\'événements, réseaux sociaux, cartes) sont fournis à titre indicatif et n\\'engagent pas la responsabilité de La Meute Normande quant à leur contenu.</p>'\n                    + '<h4>Formulaire de contact</h4>'\n                    + '<p>Les données saisies dans le formulaire de contact (nom/pseudo, identifiant ou e-mail, préférence de contact, message et pièce jointe éventuelle) sont transmises via le service <strong>UseBasin</strong> et reçues uniquement par le responsable de la publication. Elles ne sont utilisées que pour répondre à votre demande et ne sont jamais revendues ni partagées avec des tiers.</p>'\n            },\n            confidentialite: {\n                title: 'Politique de confidentialité (RGPD)',\n                body: '<h4>Introduction</h4>'\n                    + '<p>La Meute Normande s\\'engage à protéger la vie privée de ses visiteurs, conformément au <strong>Règlement Général sur la Protection des Données (RGPD — UE 2016/679)</strong> et à la <strong>loi Informatique et Libertés</strong>.</p>'\n                    + '<h4>Responsable du traitement</h4>'\n                    + '<p>Responsable : <strong>Nitra</strong> — Contact : <a href=\"tg://resolve?domain=NitraFox\" target=\"_blank\" rel=\"noopener\">@NitraFox sur Telegram</a></p>'\n                    + '<h4>Données collectées via le formulaire de contact</h4>'\n                    + '<p>Le formulaire de la page Contact collecte les données suivantes :</p>'\n                    + '<ul>'\n                    + '<li><strong>Nom / Prénom / Pseudo</strong> (obligatoire)</li>'\n                    + '<li><strong>Identifiant ou e-mail</strong> (obligatoire)</li>'\n                    + '<li><strong>Préférence de contact</strong> : Discord, Telegram, Twitter/X ou Email (obligatoire)</li>'\n                    + '<li><strong>Message</strong> (obligatoire)</li>'\n                    + '<li><strong>Pièce jointe</strong> (optionnel — formats : jpg, png, gif, webp, pdf, doc, docx, zip, txt)</li>'\n                    + '</ul>'\n                    + '<p>Ces données sont transmises via <strong>UseBasin</strong> (sous-traitant, basé aux États-Unis — <a href=\"https://usebasin.com/privacy\" target=\"_blank\" rel=\"noopener\">politique de confidentialité UseBasin</a>). Le consentement explicite est recueilli avant l\\'envoi via une case à cocher obligatoire.</p>'\n                    + '<p><strong>Base légale :</strong> consentement de l\\'utilisateur (article 6.1.a du RGPD).</p>'\n                    + '<p><strong>Finalité :</strong> répondre à votre demande de contact uniquement.</p>'\n                    + '<p><strong>Durée de conservation :</strong> les données sont conservées le temps nécessaire au traitement de la demande, puis supprimées.</p>'\n                    + '<h4>Données NON collectées</h4>'\n                    + '<p>En dehors du formulaire de contact, ce site <strong>ne collecte aucune donnée personnelle</strong>. Il n\\'y a pas de compte utilisateur, pas de newsletter, pas de base de données, pas de système de commentaires.</p>'\n                    + '<h4>Stockage local (localStorage)</h4>'\n                    + '<p>Le site utilise le <strong>localStorage</strong> de votre navigateur pour :</p>'\n                    + '<ul>'\n                    + '<li>Sauvegarder vos préférences de filtres du calendrier (type d\\'événement, région, département)</li>'\n                    + '<li>Mémoriser si vous avez activé la sauvegarde automatique des filtres</li>'\n                    + '</ul>'\n                    + '<p>Ces données restent <strong>exclusivement sur votre appareil</strong> et ne sont jamais transmises à un serveur. Vous pouvez les supprimer à tout moment via les paramètres de votre navigateur.</p>'\n                    + '<h4>Données de navigation (hébergeur)</h4>'\n                    + '<p><strong>GitHub Pages</strong> peut collecter automatiquement des données techniques de connexion (adresse IP, type de navigateur, pages visitées) conformément à sa propre <a href=\"https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement\" target=\"_blank\" rel=\"noopener\">politique de confidentialité</a>. La Meute Normande n\\'a pas accès à ces données.</p>'\n                    + '<h4>Services tiers</h4>'\n                    + '<p>Le site fait appel aux services tiers suivants, qui peuvent recevoir des données techniques (adresse IP, en-têtes de requête) :</p>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Service</th><th>Usage</th><th>Données potentielles</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td><strong>Google Fonts</strong></td><td>Chargement de la police Inter Tight (toutes les pages)</td><td>Adresse IP, en-tête Referer</td></tr>'\n                    + '<tr><td><strong>cdnjs (Cloudflare)</strong></td><td>Chargement de FullCalendar et ical.js (page Événements)</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>jsDelivr</strong></td><td>Chargement de ical.js (page Actus)</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>UseBasin</strong></td><td>Traitement du formulaire de contact</td><td>Données du formulaire (voir ci-dessus)</td></tr>'\n                    + '<tr><td><strong>GitHub Raw</strong></td><td>Récupération du fichier calendrier ICS</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>api-adresse.data.gouv.fr</strong></td><td>Géocodage pour les filtres du calendrier (page Événements)</td><td>Nom de ville recherché, adresse IP</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Tracking et publicité</h4>'\n                    + '<p>Ce site <strong>n\\'utilise aucun outil de tracking, d\\'analyse ou de publicité</strong> (pas de Google Analytics, pas de Facebook Pixel, pas de Matomo, pas de publicité ciblée).</p>'\n                    + '<h4>Vos droits</h4>'\n                    + '<p>Conformément au RGPD, vous disposez des droits suivants :</p>'\n                    + '<ul>'\n                    + '<li><strong>Droit d\\'accès</strong> — obtenir une copie de vos données</li>'\n                    + '<li><strong>Droit de rectification</strong> — corriger des données inexactes</li>'\n                    + '<li><strong>Droit à l\\'effacement</strong> — demander la suppression de vos données</li>'\n                    + '<li><strong>Droit d\\'opposition</strong> — vous opposer au traitement</li>'\n                    + '<li><strong>Droit à la portabilité</strong> — récupérer vos données dans un format structuré</li>'\n                    + '</ul>'\n                    + '<p>Vous pouvez également introduire une réclamation auprès de la <strong>CNIL</strong> (<a href=\"https://www.cnil.fr\" target=\"_blank\" rel=\"noopener\">www.cnil.fr</a>).</p>'\n                    + '<h4>Mise à jour</h4>'\n                    + '<p>Cette politique peut être modifiée à tout moment. La date de dernière mise à jour est indiquée ci-dessous.</p>'\n                    + '<p><em>Dernière mise à jour : avril 2026</em></p>'\n            },\n            cookies: {\n                title: 'Politique de cookies',\n                body: '<h4>Qu\\'est-ce qu\\'un cookie ?</h4>'\n                    + '<p>Un cookie est un petit fichier texte déposé sur votre appareil lors de la visite d\\'un site web. Il permet de stocker des informations relatives à votre navigation. Le <strong>localStorage</strong> est un mécanisme similaire, propre à votre navigateur, qui stocke des données localement sans les transmettre automatiquement aux serveurs.</p>'\n                    + '<h4>Stockage utilisé par ce site</h4>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Type</th><th>Origine</th><th>Finalité</th><th>Durée</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td>localStorage<br><code>calendarFilterSettings</code></td><td>Ce site (lameutenormande.fr)</td><td>Sauvegarde de vos filtres du calendrier (type, région, département)</td><td>Jusqu\\'à suppression manuelle</td></tr>'\n                    + '<tr><td>localStorage<br><code>calendarFilterSave</code></td><td>Ce site (lameutenormande.fr)</td><td>Mémorise si vous avez activé la sauvegarde des filtres</td><td>Jusqu\\'à suppression manuelle</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Cookies pouvant être déposés par des tiers</h4>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Service</th><th>Type</th><th>Finalité</th><th>Durée</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td>GitHub Pages</td><td>Cookie technique</td><td>Fonctionnement de l\\'hébergement</td><td>Session</td></tr>'\n                    + '<tr><td>Google Fonts (fonts.googleapis.com)</td><td>Cookie technique</td><td>Chargement de la police Inter Tight</td><td>Variable</td></tr>'\n                    + '<tr><td>Cloudflare CDN (cdnjs.cloudflare.com)</td><td>Cookie technique</td><td>Chargement de FullCalendar et ical.js</td><td>Variable</td></tr>'\n                    + '<tr><td>jsDelivr (cdn.jsdelivr.net)</td><td>Cookie technique</td><td>Chargement de ical.js</td><td>Variable</td></tr>'\n                    + '<tr><td>UseBasin (usebasin.com)</td><td>Cookie technique</td><td>Traitement du formulaire de contact</td><td>Session</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Cookies analytiques ou publicitaires</h4>'\n                    + '<p>Ce site <strong>n\\'utilise aucun cookie publicitaire, de tracking ou d\\'analyse</strong> (pas de Google Analytics, pas de Facebook Pixel, pas de Matomo, pas de publicité ciblée).</p>'\n                    + '<h4>Gérer vos cookies</h4>'\n                    + '<p>Vous pouvez à tout moment configurer votre navigateur pour refuser les cookies ou supprimer ceux déjà déposés :</p>'\n                    + '<ul>'\n                    + '<li><strong>Chrome :</strong> Paramètres → Confidentialité et sécurité → Cookies et autres données de site</li>'\n                    + '<li><strong>Firefox :</strong> Paramètres → Vie privée et sécurité → Cookies et données de sites</li>'\n                    + '<li><strong>Safari :</strong> Préférences → Confidentialité → Gérer les données de site web</li>'\n                    + '<li><strong>Edge :</strong> Paramètres → Cookies et autorisations de site</li>'\n                    + '</ul>'\n                    + '<h4>Effacer le localStorage</h4>'\n                    + '<p>Pour supprimer les préférences enregistrées par ce site :</p>'\n                    + '<ul>'\n                    + '<li>Ouvrez les outils développeur de votre navigateur (<strong>F12</strong>)</li>'\n                    + '<li>Allez dans l\\'onglet <strong>Application</strong> (Chrome/Edge) ou <strong>Stockage</strong> (Firefox)</li>'\n                    + '<li>Sélectionnez <strong>localStorage</strong> → <strong>lameutenormande.fr</strong></li>'\n                    + '<li>Supprimez les entrées souhaitées ou cliquez sur « Tout effacer »</li>'\n                    + '</ul>'\n                    + '<p>Vous pouvez aussi effacer les données de navigation de votre navigateur, ce qui supprimera à la fois les cookies et le localStorage.</p>'\n                    + '<p><em>Dernière mise à jour : avril 2026</em></p>'\n            }\n        };\n\n        /* ---------- Modale ---------- */\n        var modal = document.querySelector('.footer-modern .legal-modal');\n        var modalTitle = modal ? modal.querySelector('.legal-modal-title') : null;\n        var modalBody = modal ? modal.querySelector('.legal-modal-body') : null;\n        var modalClose = modal ? modal.querySelector('.legal-modal-close') : null;\n        var modalOverlay = modal ? modal.querySelector('.legal-modal-overlay') : null;\n        var keyHandler = null;\n\n        function openLegal(key) {\n            var data = legalContents[key];\n            if (!data || !modal) return;\n\n            modalTitle.textContent = data.title;\n            modalBody.innerHTML = data.body;\n\n            document.body.classList.add('modal-open');\n            modal.classList.add('show');\n            modal.classList.remove('closing');\n            modal.setAttribute('aria-hidden', 'false');\n\n            if (keyHandler) document.removeEventListener('keydown', keyHandler);\n            keyHandler = function(e) { if (e.key === 'Escape') closeLegal(); };\n            document.addEventListener('keydown', keyHandler);\n\n            setTimeout(function() {\n                if (modalClose) modalClose.focus();\n            }, 50);\n        }\n\n        function closeLegal() {\n            if (!modal || !modal.classList.contains('show')) return;\n\n            modal.classList.add('closing');\n            modal.setAttribute('aria-hidden', 'true');\n            document.body.classList.remove('modal-open');\n\n            setTimeout(function() {\n                modal.classList.remove('show', 'closing');\n            }, 250);\n\n            if (keyHandler) {\n                document.removeEventListener('keydown', keyHandler);\n                keyHandler = null;\n            }\n        }\n\n        if (modalClose) modalClose.addEventListener('click', closeLegal);\n        if (modalOverlay) modalOverlay.addEventListener('click', closeLegal);\n\n        /* ---------- Boutons légaux ---------- */\n        var btns = document.querySelectorAll('.footer-modern .footer-legal-btn');\n        for (var i = 0; i < btns.length; i++) {\n            btns[i].addEventListener('click', function() {\n                openLegal(this.getAttribute('data-legal'));\n            });\n        }\n    })();\n    </script>"
          ],
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    },
    "events.html": {
      "settings": {
        "title": "Les événements - La Meute Normande",
        "order": "1",
        "meta_image": "@PROJECT_PATH@/assets/images/logo-2000x837.png"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
              "margin-right": "0.5rem",
              "line-height": "1",
              "font-size": "inherit",
              "vertical-align": "middle",
              "text-align": "center",
              "overflow": "hidden",
              "transform": "scale(0, 1)",
              "transition": "all 0.25s cubic-bezier(0.4, 0, 0.2, 1)"
            },
            "@media (max-width: 767px)": {
              ".navbar-toggler": {
                "transform": "scale(0.8)"
              }
            },
            ".navbar-brand": {
              "img": {
                "max-width": "100%",
                "max-height": "100%",
                "border-radius": "0px !important",
                "transition": "all 0.5s cubic-bezier(0.22, 1, 0.36, 1)",
                "filter": "drop-shadow(0 2px 4px rgba(0, 0, 0, 0.06))",
                "&:hover": {
                  "transform": "scale(1.06) rotate(-1deg)",
                  "filter": "drop-shadow(0 4px 12px rgba(0, 0, 0, 0.1))"
                }
              },
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "0",
              "padding": "10px 0",
              "transition": "all 0.5s cubic-bezier(0.22, 1, 0.36, 1)",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              }
            },
            ".navbar-nav": {
              "margin": "auto",
              "margin-left": "0",
              "& when (@contentAlign = '2')": {
                "margin-left": "auto"
              },
              "& when (@contentAlign = '3')": {
                "margin-left": "auto",
                "margin-right": "0"
              },
              ".nav-item": {
                "padding": "0 !important",
                "transition": "0.3s all cubic-bezier(0.4, 0, 0.2, 1) !important",
                ".nav-link": {
                  "padding": "10px 18px !important",
                  "margin": "0 4px !important",
                  "border-radius": "0.75rem !important",
                  "transition": "all 0.35s cubic-bezier(0.22, 1, 0.36, 1) !important",
                  "position": "relative",
                  "font-weight": "500",
                  "letter-spacing": "0.02em",
                  "text-transform": "none",
                  "overflow": "hidden",
                  "&::after": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "4px",
                    "left": "50%",
                    "width": "0",
                    "height": "2.5px",
                    "border-radius": "2px",
                    "background": "currentColor",
                    "opacity": "0.6",
                    "transform": "translateX(-50%)",
                    "transition": "width 0.35s cubic-bezier(0.22, 1, 0.36, 1)"
                  },
                  "&:hover": {
                    "background-color": "rgba(27, 31, 10, 0.05)",
                    "&::after": {
                      "width": "50%"
                    }
                  },
                  "&:active": {
                    "transform": "scale(0.97)"
                  },
                  "& when not (@isRoundedButtons)": {
                    "border-radius": "4px !important"
                  }
                }
              },
              ".open": {
                ".nav-link": {
                  "&::after": {
                    "transform": "rotate(180deg)"
                  },
                  "@media (min-width: 992px)": {
                    "&::before": {
                      "content": "\"\"",
                      "width": "100%",
                      "height": "20px",
                      "top": "100%",
                      "background": "transparent",
                      "position": "absolute"
                    }
                  }
                }
              },
              ".dropdown-item": {
                "padding": "10px 16px !important",
                "border-radius": "0.5rem !important",
                "margin": "2px 8px !important",
                "transition": "all 0.3s cubic-bezier(0.22, 1, 0.36, 1) !important",
                "border-left": "3px solid transparent",
                "&:hover": {
                  "background-color": "rgba(27, 31, 10, 0.06)",
                  "border-left-color": "@hamburgerColor",
                  "padding-left": "20px !important"
                },
                "& when not (@isRoundedButtons)": {
                  "border-radius": "4px !important"
                }
              },
              "& when not (@showLogo), (@showBrand)": {
                "@media (min-width: 992px)": {
                  "padding-left": "1.5rem"
                }
              },
              "& when not (@showBrand)": {
                "@media (min-width: 992px)": {
                  "padding-left": "1.5rem"
                }
              }
            },
            ".nav-link": {
              "width": "fit-content",
              "position": "relative"
            },
            ".navbar-logo": {
              "padding-left": "2rem",
              "margin": "0 !important",
              "@media (max-width: 767px)": {
                "padding-left": "1rem"
              }
            },
            ".navbar-caption": {
              "padding-left": "1rem",
              "padding-right": ".5rem",
              "font-weight": "600",
              "letter-spacing": "0.02em",
              "& when not (@showLogo)": {
                "@media (min-width: 767px)": {
                  "padding-left": "2rem"
                }
              }
            },
            ".nav-dropdown": {
              "@media (max-width: 767px)": {
                "padding-bottom": "0.5rem"
              }
            },
            ".nav-dropdown .link.dropdown-toggle::after": {
              "margin-left": "0.5rem",
              "margin-top": "0.2rem",
              "transition": ".3s all"
            },
            ".container": {
              "display": "flex",
              "height": "68px",
              "padding": "0.5rem 1rem",
              "flex-wrap": "nowrap",
              "& when not (@collapsed)": {
                "@media (min-width: 992px)": {},
                "& when (@transparent)": {
                  "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity) !important"
                }
              },
              "left": "0",
              "right": "0",
              "justify-content": "flex-end",
              "align-items": "center",
              "border-radius": "100vw",
              "margin-top": "1.2rem",
              "background-color": "@menuBgColor",
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.12) inset, 0 4px 24px -4px rgba(27, 31, 10, 0.08), 0 1px 3px rgba(27, 31, 10, 0.04)",
              "border": "1px solid rgba(255, 255, 255, 0.22)",
              "transition": "all 0.5s cubic-bezier(0.22, 1, 0.36, 1)",
              "&:hover": {
                "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.18) inset, 0 8px 40px -8px rgba(27, 31, 10, 0.12), 0 2px 6px rgba(27, 31, 10, 0.06)",
                "border-color": "rgba(255, 255, 255, 0.3)"
              },
              "@media (max-width: 992px)": {
                "padding-right": "2rem"
              },
              "@media (max-width: 767px)": {
                "width": "95%",
                "height": "56px !important",
                "padding-right": "1rem",
                "margin-top": "0.5rem"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".iconfont-wrapper": {
              "color": "@iconsColor !important",
              "font-size": "1.35rem",
              "padding-right": "0",
              "display": "inline-flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "38px",
              "height": "38px",
              "border-radius": "50%",
              "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)",
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "inset": "0",
                "border-radius": "50%",
                "background": "currentColor",
                "opacity": "0",
                "transform": "scale(0.6)",
                "transition": "all 0.4s cubic-bezier(0.22, 1, 0.36, 1)"
              },
              "&:hover": {
                "transform": "rotate(8deg) scale(1.15)",
                "&::before": {
                  "opacity": "0.08",
                  "transform": "scale(1)"
                }
              },
              "&:active": {
                "transform": "rotate(0deg) scale(0.95)"
              },
              ".mbr-iconfont": {
                "position": "relative",
                "z-index": "1"
              }
            },
            ".dropdown-menu": {
              "flex-wrap": "wrap",
              "flex-direction": "column",
              "max-width": "100%",
              "padding": "10px 6px !important",
              "border-radius": "1rem",
              "transition": "all 0.35s cubic-bezier(0.22, 1, 0.36, 1) !important",
              "min-width": "auto",
              "background": "@menuBgColor",
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "border": "1px solid rgba(255, 255, 255, 0.2)",
              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.08) inset, 0 16px 48px -8px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.04)",
              "& when (@transparent)": {
                "background": "rgba(red(@menuBgColor), green(@menuBgColor), blue(@menuBgColor), @opacity) !important"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub",
                "&:before": {
                  "display": "inline-block",
                  "transform": "scale(1, 1)",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".collapsed": {
              ".dropdown-menu .dropdown-item:before": {
                "display": "none"
              },
              ".dropdown .dropdown-menu .dropdown-item": {
                "padding": "0.235em 1.5em 0.235em 1.5em !important",
                "transition": "none",
                "margin": "0 !important"
              }
            },
            ".navbar": {
              "min-height": "80px",
              "transition": "all 0.4s cubic-bezier(0.4, 0, 0.2, 1)",
              "border-bottom": "1px solid transparent",
              "background": "transparent !important",
              "&:not(.navbar-short)": {},
              "&.opened": {
                "transition": "all 0.3s"
              },
              ".dropdown-item": {
                "padding": "0.5rem 1.8rem"
              },
              ".navbar-logo img": {
                "width": "auto"
              },
              ".navbar-collapse": {
                "z-index": "1",
                "justify-content": "flex-end"
              },
              "&.collapsed": {
                "justify-content": "center",
                ".nav-item .nav-link::before": {
                  "display": "none"
                },
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  },
                  "@media (min-width: 992px)": {
                    "&:not(.navbar-short) .navbar-collapse when (@showLogo)": {
                      "max-height": "~\"calc(98.5vh - @{logoSize}rem)\""
                    }
                  }
                },
                ".dropdown-menu": {
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle=\"dropdown-submenu\"]:after": {
                    "margin-left": "0.5rem",
                    "margin-top": "0.2rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
