  "pages": {
    "index.html": {
      "settings": {
        "main": true,
        "title": "Accueil - La Meute Normande",
        "meta_descr": "Nous sommes un groupe de passionnés de la culture furry, basé en Haute-Normandie, nous nous retrouvons pour participer à des événements ensemble assez régulièrement.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "meta_image": "@PROJECT_PATH@/assets/images/logo-2000x837.png"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "@easeOut": "cubic-bezier(0.22, 1, 0.36, 1)",
            "@easeStd": "cubic-bezier(0.4, 0, 0.2, 1)",
            "@durFast": "0.25s",
            "@durMed": "0.4s",
            "@durSlow": "0.55s",
            "@radiusItem": "0.75rem",
            "@radiusMenu": "1rem",
            "@radiusPanel": "1.25rem",
            "@ink": "rgb(27, 31, 10)",
            "z-index": "1000",
            "width": "100%",
            "top": "0",
            "left": "0",
            "right": "0",
            "position": "absolute",
            ".container": {
              "display": "flex",
              "flex-wrap": "nowrap",
              "align-items": "center",
              "justify-content": "flex-end",
              "height": "68px",
              "padding": "0.5rem 1rem",
              "margin-top": "1.2rem",
              "left": "0",
              "right": "0",
              "border-radius": "100vw",
              "background-color": "@menuBgColor",
              "& when not (@collapsed)": {
                "& when (@transparent)": {
                  "background": "fade(@menuBgColor, @opacity * 100) !important"
                }
              },
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "border": "1px solid rgba(255, 255, 255, 0.22)",
              "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.12), 0 4px 24px -4px fade(@ink, 8%), 0 1px 3px fade(@ink, 4%)",
              "transition": "box-shadow @durSlow @easeOut, border-color @durSlow @easeOut, height @durMed @easeOut, margin-top @durMed @easeOut",
              "&:hover": {
                "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.18), 0 8px 40px -8px fade(@ink, 12%), 0 2px 6px fade(@ink, 6%)",
                "border-color": "rgba(255, 255, 255, 0.3)"
              },
              "@media (max-width: 991px)": {
                "padding-right": "2rem"
              },
              "@media (max-width: 767px)": {
                "width": "95%",
                "height": "56px !important",
                "padding-right": "1rem",
                "margin-top": "0.5rem"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".navbar-brand": {
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "0",
              "padding": "10px 0",
              "word-break": "break-word",
              "z-index": "1",
              "img": {
                "max-width": "100%",
                "max-height": "100%",
                "border-radius": "0 !important",
                "transition": "transform @durSlow @easeOut, filter @durSlow @easeOut, height @durMed @easeOut",
                "filter": "drop-shadow(0 2px 4px rgba(0, 0, 0, 0.06))",
                "&:hover": {
                  "transform": "scale(1.06) rotate(-1deg)",
                  "filter": "drop-shadow(0 4px 12px rgba(0, 0, 0, 0.1))"
                }
              },
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              }
            },
            ".navbar-logo": {
              "padding-left": "2rem",
              "margin": "0 !important",
              "@media (max-width: 767px)": {
                "padding-left": "1rem"
              }
            },
            ".navbar-caption": {
              "padding-left": "1rem",
              "padding-right": "0.5rem",
              "font-weight": "600",
              "letter-spacing": "0.02em",
              "& when not (@showLogo)": {
                "@media (min-width: 768px)": {
                  "padding-left": "2rem"
                }
              }
            },
            ".navbar-nav": {
              "margin": "auto",
              "margin-left": "0",
              "flex-wrap": "wrap",
              "& when (@contentAlign = '2')": {
                "margin-left": "auto"
              },
              "& when (@contentAlign = '3')": {
                "margin-left": "auto",
                "margin-right": "0"
              },
              "@media (min-width: 992px)": {
                "padding-left": "1.5rem"
              },
              ".nav-item": {
                "padding": "0 !important",
                ".nav-link": {
                  "padding": "10px 18px !important",
                  "margin": "0 4px !important",
                  "border-radius": "@radiusItem !important",
                  "position": "relative",
                  "font-weight": "500",
                  "letter-spacing": "0.02em",
                  "text-transform": "none",
                  "overflow": "hidden",
                  "transition": "background-color @durFast @easeOut, transform @durFast @easeOut",
                  "&:not(.dropdown-toggle)::after": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "4px",
                    "left": "50%",
                    "width": "0",
                    "height": "2.5px",
                    "border-radius": "2px",
                    "background": "currentColor",
                    "opacity": "0.6",
                    "transform": "translateX(-50%)",
                    "transition": "width @durFast @easeOut"
                  },
                  "&:hover": {
                    "background-color": "fade(@ink, 5%)"
                  },
                  "&:not(.dropdown-toggle):hover::after": {
                    "width": "50%"
                  },
                  "&:active": {
                    "transform": "scale(0.97)"
                  },
                  "& when not (@isRoundedButtons)": {
                    "border-radius": "4px !important"
                  }
                }
              },
              ".open": {
                ".nav-link": {
                  "&::after": {
                    "transform": "rotate(180deg)"
                  },
                  "@media (min-width: 992px)": {
                    "&::before": {
                      "content": "\"\"",
                      "width": "100%",
                      "height": "20px",
                      "top": "100%",
                      "background": "transparent",
                      "position": "absolute"
                    }
                  }
                }
              },
              ".dropdown-item": {
                "padding": "10px 16px !important",
                "border-radius": "0.5rem !important",
                "margin": "2px 8px !important",
                "border-left": "3px solid transparent",
                "transition": "background-color @durFast @easeOut, border-color @durFast @easeOut, padding @durFast @easeOut",
                "&:hover": {
                  "background-color": "fade(@ink, 6%)",
                  "border-left-color": "@hamburgerColor",
                  "padding-left": "20px !important"
                },
                "& when not (@isRoundedButtons)": {
                  "border-radius": "4px !important"
                }
              }
            },
            ".nav-link": {
              "width": "fit-content",
              "position": "relative"
            },
            "a.nav-link": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center"
            },
            ".nav-dropdown": {
              "@media (max-width: 767px)": {
                "padding-bottom": "0.5rem"
              }
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin-right": "1.667em",
              "&::after": {
                "margin-left": "0.5rem",
                "margin-top": "0.2rem",
                "transition": "transform @durFast @easeStd"
              },
              "&[aria-expanded=\"true\"]": {
                "margin-right": "0",
                "padding": "0.667em 1.667em"
              }
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown-menu": {
              "flex-wrap": "wrap",
              "flex-direction": "column",
              "max-width": "100%",
              "min-width": "auto",
              "padding": "10px 6px !important",
              "border-radius": "@radiusMenu",
              "background": "@menuBgColor",
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "border": "1px solid rgba(255, 255, 255, 0.2)",
              "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.08), 0 16px 48px -8px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.04)",
              "& when (@transparent)": {
                "background": "fade(@menuBgColor, @opacity * 100) !important"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub"
              }
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar .dropdown > .dropdown-menu": {
              "display": "none",
              "width": "max-content",
              "max-width": "500px !important",
              "top": "~\"calc(100% + 12px)\"",
              "left": "50%",
              "transform": "translateX(-50%) translateY(8px)",
              "animation": "dropdownFadeIn @durFast @easeOut forwards",
              ".dropdown-item": {
                "line-height": "1 !important"
              },
              ".dropdown": {
                ".dropdown-item": {
                  "align-items": "center",
                  "display": "flex",
                  "height": "max-content !important",
                  "min-height": "max-content !important",
                  "&::after": {
                    "display": "inline-block",
                    "position": "static",
                    "margin": "0 0 0 0.5rem",
                    "transition": "transform @durFast @easeStd",
                    "transform": "rotate(-90deg)"
                  }
                }
              },
              ".dropdown.open": {
                ".dropdown-item": {
                  "&::after": {
                    "transform": "rotate(0deg)"
                  }
                }
              }
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "flex"
            },
            ".navbar.navbar-expand-lg .dropdown .dropdown-menu": {
              "background": "@menuBgColor",
              ".dropdown-submenu": {
                "margin": "0",
                "left": "105%",
                "transform": "none",
                "top": "-12px"
              }
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "31px",
              "height": "20px",
              "cursor": "pointer",
              "position": "relative",
              "align-self": "center",
              "margin-left": "12px",
              "margin-right": "8px",
              "order": "1000",
              "@media (max-width: 767px)": {
                "transform": "scale(0.8)"
              },
              "&:hover .hamburger span": {
                "&:nth-child(1)": {
                  "width": "20px"
                },
                "&:nth-child(4)": {
                  "width": "24px"
                }
              },
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "height": "2px",
                "background-color": "@hamburgerColor",
                "border-radius": "4px",
                "&:nth-child(1)": {
                  "top": "0",
                  "width": "26px",
                  "transition": "all @durMed @easeOut"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s @easeOut 0.05s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s @easeOut 0.05s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "width": "18px",
                  "transition": "all @durMed @easeOut"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s @easeOut"
              },
              "&:nth-child(2)": {
                "width": "24px",
                "transform": "rotate(45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(3)": {
                "width": "24px",
                "transform": "rotate(-45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s @easeOut"
              }
            },
            ".icons-menu": {
              "display": "flex",
              "flex-wrap": "nowrap",
              "justify-content": "center",
              "align-items": "center",
              "gap": "4px",
              "padding": "0 0.5rem 0 0.75rem",
              "margin-left": "4px",
              "text-align": "center",
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "left": "0",
                "top": "20%",
                "height": "60%",
                "width": "1px",
                "background": "fade(@ink, 10%)",
                "border-radius": "1px"
              },
              "@media (max-width: 991px)": {
                "justify-content": "flex-start",
                "margin-bottom": "0.5rem",
                "margin-left": "0",
                "&::before": {
                  "display": "none"
                }
              }
            },
            ".iconfont-wrapper": {
              "font-size": "1.35rem",
              "display": "inline-flex",
