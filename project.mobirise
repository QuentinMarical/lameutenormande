 fill=\"#ffffff\" d=\"m 12.937649,5.689685 c -0.11625,-0.68661 -0.388914,-1.33016 -0.810638,-1.91282 -0.476314,-0.65811 -1.127922,-1.20761 -1.884324,-1.58903 -0.7645339,-0.38552 -1.6178829,-0.58938 -2.4678369,-0.58938 -0.239783,0 -0.481475,0.0163 -0.71843,0.0482 -0.992367,0.13407 -1.968118,0.54689 -2.747572,1.16243 -0.878239,0.69354 -1.444993,1.58521 -1.638884,2.57878 -0.05777,0.29537 -0.08238,0.62212 -0.106209,0.93806 -0.03734,0.49456 -0.07594,1.00595 -0.233207,1.34013 -0.107482,0.2284 -0.267856,0.3805 -0.701389,0.3805 -0.238581,0 -0.456585,0.13492 -0.563077,0.34847 -0.10642098,0.21355 -0.08294,0.46889 0.0606,0.65931 0.653164,0.8665 1.505522,1.39133 2.402923,1.70755 -0.04087,0.12346 -0.06385,0.25491 -0.06385,0.39209 0,0.68902 0.558551,1.24757 1.247566,1.24757 0.671972,0 1.218291,-0.53161 1.244949,-1.19701 0.292534,0.0159 1.685483,0.0197 1.840836,0.0153 0.03444,0.65825 0.577502,1.18166 1.244243,1.18166 0.688943,0 1.2474949,-0.55848 1.2474949,-1.24757 0,-0.15705 -0.03026,-0.30674 -0.08316,-0.44513 0.489183,-0.23794 0.95093,-0.55904 1.353845,-0.94576 0.561875,-0.53918 0.974265,-1.1753 1.192764,-1.83964 0.245865,-0.7477 0.307667,-1.4993 0.183355,-2.23378 m -8.2243299,5.876 c -0.227338,0 -0.411684,-0.18421 -0.411684,-0.41169 0,-0.22733 0.184346,-0.41168 0.411684,-0.41168 0.227408,0 0.411683,0.18435 0.411683,0.41168 0,0.22748 -0.184275,0.41169 -0.411683,0.41169 m 4.330028,0 c -0.227409,0 -0.411754,-0.18421 -0.411754,-0.41169 0,-0.22733 0.184345,-0.41168 0.411754,-0.41168 0.227408,0 0.411683,0.18435 0.411683,0.41168 7.1e-5,0.22748 -0.184275,0.41169 -0.411683,0.41169 m 3.1132919,-3.83873 c -0.360276,1.09533 -1.309862,1.9998 -2.3218169,2.46289 -0.215458,-0.17706 -0.490951,-0.28327 -0.791405,-0.28327 -0.484233,0 -0.903058,0.2762 -1.109748,0.67933 -0.210438,0.009 -1.777338,0.003 -2.120219,-0.0202 -0.210155,-0.39223 -0.623818,-0.65917 -1.100061,-0.65917 -0.316788,0 -0.605221,0.11894 -0.825134,0.31354 -0.852358,-0.27543 -1.65734,-0.74608 -2.259025,-1.54449 1.779176,0 1.428092,-1.98827 1.658259,-3.16731 0.350659,-1.79693 2.12835,-3.00518 3.853148,-3.23817 0.212135,-0.0286 0.42427,-0.0426 0.634213,-0.0426 2.8347599,7e-5 5.3581049,2.53098 4.3817889,5.49938 m -4.4056189,0.87435 c -1.023692,0 -1.945914,-0.67119 -2.115056,-1.54978 -0.03281,-0.17056 0.07891,-0.33553 0.249471,-0.36834 0.170627,-0.0329 0.335527,0.0789 0.368337,0.24947 0.09942,0.51648 0.717865,1.06039 1.542221,1.03882 0.858722,-0.0225 1.4259,-0.53599 1.542433,-1.03154 0.03981,-0.16907 0.209378,-0.27379 0.378308,-0.23419 0.169213,0.0398 0.274007,0.20916 0.234197,0.37823 -0.09518,0.40454 -0.35568,0.77932 -0.733634,1.05545 -0.393652,0.28779 -0.879511,0.44718 -1.404757,0.46104 -0.02051,6.3e-4 -0.04108,8.4e-4 -0.06152,8.4e-4 m 2.037132,-3.23958 c 0,0.33369 -0.270542,0.60423 -0.604231,0.60423 -0.333617,0 -0.60416,-0.27054 -0.60416,-0.60423 0,-0.33369 0.270543,-0.60409 0.60416,-0.60409 0.333689,0 0.604231,0.27033 0.604231,0.60409 m -2.822597,0 c 0,0.33369 -0.270472,0.60423 -0.60416,0.60423 -0.333618,0 -0.60416,-0.27054 -0.60416,-0.60423 0,-0.33369 0.270542,-0.60409 0.60416,-0.60409 0.333688,0 0.60416,0.27033 0.60416,0.60409\"/></svg><span class=\"location-btn-label\">Waze</span></a>\n                        <a href=\"https://maps.apple.com/?q=${loc}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-btn location-apple\"><svg viewBox=\"0 0 30 30\" class=\"location-btn-logo\" xmlns=\"http://www.w3.org/2000/svg\"><path fill=\"#ffffff\" d=\"M 9 4 C 8.657 4 8.323 4.0355625 8 4.1015625 L 8 13.275391 C 7.646263 13.401511 7.3068564 13.555772 7 13.761719 L 7 4.421875 C 5.755 4.966875 4.7873594 6.0089688 4.3183594 7.2929688 L 6 8.4707031 L 6 14.611328 L 4 13.210938 L 4 21 C 4 23.049 5.236 24.806125 7 25.578125 L 7 21.238281 C 7.7157567 21.718662 8.5752393 22 9.5 22 C 10.424761 22 11.284243 21.718662 12 21.238281 L 12 26 L 21 26 C 21.369 26 21.726266 25.954906 22.072266 25.878906 L 13.361328 19.773438 C 13.757438 19.103628 14 18.332818 14 17.5 C 14 16.439688 13.615994 15.47704 13 14.707031 L 13 13.376953 L 25.794922 22.345703 C 25.915922 21.914703 26 21.469 26 21 L 26 15.974609 C 19.497 15.716609 14.283391 10.503 14.025391 4 L 12 4 L 12 13.761719 C 11.693144 13.555772 11.353737 13.401511 11 13.275391 L 11 4 L 9 4 z M 18.025391 4 C 18.275391 8.294 21.706 11.723609 26 11.974609 L 26 9 C 26 6.239 23.761 4 21 4 L 18.025391 4 z M 9.5 14 C 10.480989 14 11.364517 14.406452 12 15.056641 C 12.15425 15.214391 12.293344 15.385984 12.416016 15.570312 C 12.538687 15.754641 12.644031 15.951641 12.730469 16.158203 C 12.816906 16.364766 12.884141 16.580234 12.929688 16.804688 C 12.975072 17.029622 13 17.261689 13 17.5 C 13 17.738 12.975234 17.970859 12.929688 18.195312 C 12.884141 18.419766 12.816906 18.635234 12.730469 18.841797 C 12.644031 19.048359 12.538687 19.245359 12.416016 19.429688 C 12.293344 19.614016 12.15425 19.785609 12 19.943359 C 11.364517 20.593548 10.480989 21 9.5 21 C 8.5195528 21 7.6354091 20.59487 7 19.945312 C 6.9818906 19.926763 6.9688744 19.903706 6.9511719 19.884766 C 6.8180905 19.742375 6.6922542 19.592499 6.5839844 19.429688 C 6.4613125 19.245219 6.3559687 19.048422 6.2695312 18.841797 C 6.1830938 18.635172 6.1158594 18.419781 6.0703125 18.195312 C 6.0247656 17.970844 6 17.738 6 17.5 C 6 17.261689 6.0249282 17.029622 6.0703125 16.804688 C 6.1158594 16.580234 6.1830938 16.364766 6.2695312 16.158203 C 6.3559687 15.951641 6.4613125 15.754641 6.5839844 15.570312 C 6.7066562 15.385984 6.84575 15.214391 7 15.056641 C 7.6354827 14.406452 8.519011 14 9.5 14 z M 9.5253906 15.216797 C 9.4297656 15.216297 9.333875 15.271359 9.296875 15.380859 L 8.0136719 19.181641 C 7.9286719 19.436641 8.2455938 19.631453 8.4335938 19.439453 L 9.5273438 18.320312 L 10.5625 19.414062 C 10.7475 19.609063 11.070328 19.418109 10.986328 19.162109 L 9.7519531 15.382812 C 9.7164531 15.273312 9.6210156 15.217297 9.5253906 15.216797 z\"/></svg><span class=\"location-btn-label\">Apple Plans</span></a>\n                    </div></div></div>`;\n            }\n\n            html += '</div><div class=\"event-modal-right\">';\n\n            if (event.description) {\n                html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">📝</span><div class=\"event-info-content\"><div class=\"event-info-label\">Description</div><div class=\"event-info-text\">${linkify(event.description)}</div></div></div>`;\n            }\n\n            if (event.url) {\n                try {\n                    const u = new URL(event.url);\n                    if (u.protocol.indexOf('http') === 0) {\n                        html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">🔗</span><div class=\"event-info-content\"><div class=\"event-info-label\">Site officiel</div><a href=\"${escapeHtml(event.url)}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"event-url-button\">Visiter le site</a></div></div>`;\n                    }\n                } catch (e) {}\n            }\n\n            html += '</div></div>';\n            corps.innerHTML = html;\n\n            document.body.classList.add('modal-open');\n            modal.classList.add('show');\n            modal.classList.remove('closing');\n            modal.setAttribute('aria-hidden', 'false');\n\n            const closeBtn = modal.querySelector('.event-modal-close');\n            const overlay = modal.querySelector('.event-modal-overlay');\n\n            if (closeBtn) closeBtn.onclick = fermerPopup;\n            if (overlay) overlay.onclick = fermerPopup;\n\n            if (currentKeyHandler) {\n                document.removeEventListener('keydown', currentKeyHandler);\n            }\n\n            currentKeyHandler = e => {\n                if (e.key === 'Escape') fermerPopup();\n            };\n            document.addEventListener('keydown', currentKeyHandler);\n\n            setTimeout(() => {\n                if (closeBtn) {\n                    closeBtn.focus();\n                } else {\n                    modalContent.focus();\n                }\n            }, 20);\n        }\n\n        function fermerPopup() {\n            const modal = document.querySelector('.event-modal');\n            if (!modal || !modal.classList.contains('show')) return;\n\n            modal.classList.add('closing');\n            modal.setAttribute('aria-hidden', 'true');\n            document.body.classList.remove('modal-open');\n\n            setTimeout(() => {\n                modal.classList.remove('show', 'closing');\n            }, 250);\n\n            if (currentKeyHandler) {\n                document.removeEventListener('keydown', currentKeyHandler);\n                currentKeyHandler = null;\n            }\n\n            if (lastFocusedElement) {\n                lastFocusedElement.focus();\n                lastFocusedElement = null;\n            }\n        }\n\n        document.addEventListener('DOMContentLoaded', async () => {\n            const grid = document.getElementById('events-grid');\n            if (!grid) return;\n\n            try {\n                afficherChargement(grid);\n                conventions = await chargerConventions();\n                genererTuiles(grid);\n            } catch (e) {\n                console.error('❌', e);\n                afficherMessage(grid, 'Erreur de chargement des événements. Réessayez plus tard.', true);\n            }\n        });\n    })();\n    </script>"
          ],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            "position": "relative",
            "border-radius": "20px 20px 0 0",
            "margin-top": "-20px",
            ".mbr-overlay": {
              "position": "absolute",
              "inset": "0",
              "pointer-events": "none"
            },
            ".footer-divider": {
              "width": "100%",
              "height": "1px",
              "background": "linear-gradient(90deg, transparent, #38bdf8, #f97316, #a855f7, transparent)",
              "margin-bottom": "0.85rem"
            },
            ".container": {
              "position": "relative",
              "z-index": "2",
              "text-align": "center"
            },
            ".footer-credits": {
              "margin-bottom": "0.5rem"
            },
            ".footer-credits .mbr-text": {
              "color": "rgba(255, 255, 255, 0.65)",
              "font-size": "0.92rem",
              "margin": "0"
            },
            ".footer-link": {
              "text-decoration": "none",
              "font-weight": "600",
              "transition": "all 0.25s ease",
              "position": "relative"
            },
            ".footer-link::after": {
              "content": "''",
              "position": "absolute",
              "bottom": "-2px",
              "left": "0",
              "width": "0",
              "height": "1.5px",
              "transition": "width 0.3s ease"
            },
            ".footer-link:hover::after": {
              "width": "100%"
            },
            ".footer-link-nitra": {
              "color": "#38bdf8"
            },
            ".footer-link-nitra:hover": {
              "color": "#7dd3fc",
              "text-shadow": "0 0 12px rgba(56, 189, 248, 0.4)"
            },
            ".footer-link-nitra::after": {
              "background": "#38bdf8"
            },
            ".footer-link-spyro": {
              "color": "#a855f7"
            },
            ".footer-link-spyro:hover": {
              "color": "#c084fc",
              "text-shadow": "0 0 12px rgba(168, 85, 247, 0.45)"
            },
            ".footer-link-spyro::after": {
              "background": "#a855f7"
            },
            ".footer-legal-links": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "flex-wrap": "wrap",
              "gap": "0.35rem",
              "margin-bottom": "0.4rem"
            },
            ".footer-legal-btn": {
              "background": "none",
              "border": "none",
              "color": "rgba(255, 255, 255, 0.45)",
              "font-size": "0.78rem",
              "font-weight": "500",
              "cursor": "pointer",
              "padding": "0.3rem 0.6rem",
              "border-radius": "6px",
              "transition": "all 0.25s ease",
              "letter-spacing": "0.02em"
            },
            ".footer-legal-btn:hover, .footer-legal-btn:focus": {
              "color": "rgba(255, 255, 255, 0.85)",
              "background": "rgba(255, 255, 255, 0.07)",
              "outline": "none"
            },
            ".footer-legal-sep": {
              "color": "rgba(255, 255, 255, 0.2)",
              "font-size": "0.6rem",
              "user-select": "none"
            },
            ".footer-copyright": {
              "padding-bottom": "0.25rem"
            },
            ".footer-copyright .mbr-text": {
              "color": "rgba(255, 255, 255, 0.3)",
              "font-size": "0.75rem",
              "margin": "0",
              "letter-spacing": "0.03em"
            },
            ".legal-modal": {
              "display": "none !important",
              "position": "fixed !important",
              "z-index": "2147483647 !important",
              "inset": "0 !important",
              "width": "100vw !important",
              "height": "100vh !important",
              "align-items": "center",
              "justify-content": "center",
              "padding": "1.25rem",
              "box-sizing": "border-box"
            },
            ".legal-modal.show": {
              "display": "flex !important"
            },
            ".legal-modal.closing .legal-modal-content": {
              "animation": "legalFadeOut 0.25s ease forwards"
            },
            ".legal-modal-overlay": {
              "position": "fixed !important",
              "inset": "0 !important",
              "background": "rgba(10, 5, 20, 0.92) !important",
              "-webkit-backdrop-filter": "blur(12px) !important",
              "backdrop-filter": "blur(12px) !important",
              "z-index": "0 !important",
              "cursor": "pointer"
            },
            ".legal-modal-content": {
              "position": "relative",
              "z-index": "1",
              "width": "100%",
              "max-width": "780px",
              "max-height": "calc(100vh - 2.5rem)",
              "border-radius": "20px",
              "margin": "0 auto",
              "padding": "0",
              "background": "linear-gradient(155deg, #1e1430 0%, #120d22 60%, #0d0a1c 100%)",
              "border": "1px solid rgba(168, 85, 247, 0.15)",
              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.05), 0 24px 60px rgba(0, 0, 0, 0.7), 0 0 80px rgba(168, 85, 247, 0.08)",
              "overflow-y": "auto",
              "overflow-x": "hidden",
              "-webkit-overflow-scrolling": "touch",
              "display": "flex",
              "flex-direction": "column",
              "animation": "legalFadeIn 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
              "scrollbar-width": "thin",
              "scrollbar-color": "rgba(168, 85, 247, 0.4) transparent"
            },
            ".legal-modal-content::-webkit-scrollbar": {
              "width": "6px"
            },
            ".legal-modal-content::-webkit-scrollbar-track": {
              "background": "transparent"
            },
            ".legal-modal-content::-webkit-scrollbar-thumb": {
              "background": "rgba(168, 85, 247, 0.4)",
              "border-radius": "3px"
            },
            ".legal-modal-content::-webkit-scrollbar-thumb:hover": {
              "background": "rgba(168, 85, 247, 0.65)"
            },
            ".legal-modal-header": {
              "display": "flex",
              "align-items": "flex-start",
              "justify-content": "space-between",
              "padding": "1.75rem 2rem 1.25rem",
              "border-bottom": "1px solid rgba(255, 255, 255, 0.08)",
              "background": "linear-gradient(90deg, rgba(168, 85, 247, 0.08), rgba(196, 113, 237, 0.05), transparent)",
              "gap": "1rem"
            },
            ".legal-modal-title": {
              "margin": "0",
              "font-size": "1.4rem",
              "font-weight": "700",
              "line-height": "1.3",
              "background": "linear-gradient(90deg, #a855f7, #c084fc, #e879f9)",
              "-webkit-background-clip": "text",
              "background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "flex": "1",
              "min-width": "0"
            },
            ".legal-modal-close": {
              "flex-shrink": "0",
              "background": "rgba(255, 255, 255, 0.08)",
              "border": "1px solid rgba(255, 255, 255, 0.12)",
              "color": "rgba(255, 255, 255, 0.8)",
              "font-size": "1.4rem",
              "width": "2.5rem",
              "height": "2.5rem",
              "border-radius": "50%",
              "cursor": "pointer",
              "transition": "all 0.25s ease",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "line-height": "1",
              "padding": "0",
              "margin-top": "0.1rem"
            },
            ".legal-modal-close:hover, .legal-modal-close:focus": {
              "background": "rgba(168, 85, 247, 0.25)",
              "border-color": "rgba(168, 85, 247, 0.5)",
              "color": "#fff",
              "transform": "rotate(90deg)",
              "outline": "none"
            },
            ".legal-modal-body": {
              "padding": "1.5rem 2rem 2rem",
              "color": "rgba(255, 255, 255, 0.88)",
              "flex": "1",
              "font-size": "0.92rem",
              "line-height": "1.65"
            },
            ".legal-modal-body h4": {
              "color": "#c084fc",
              "font-size": "1.05rem",
              "font-weight": "700",
              "margin": "1.5rem 0 0.6rem",
              "letter-spacing": "0.01em"
            },
            ".legal-modal-body h4:first-child": {
              "margin-top": "0"
            },
            ".legal-modal-body p": {
              "margin": "0 0 0.75rem",
              "color": "rgba(255, 255, 255, 0.78)"
            },
            ".legal-modal-body a": {
              "color": "#a855f7",
              "text-decoration": "underline",
              "transition": "color 0.2s"
            },
            ".legal-modal-body a:hover": {
              "color": "#e879f9"
            },
            ".legal-modal-body ul": {
              "padding-left": "1.5rem",
              "margin": "0.5rem 0 0.75rem"
            },
            ".legal-modal-body li": {
              "color": "rgba(255, 255, 255, 0.72)",
              "margin-bottom": "0.35rem"
            },
            ".legal-modal-body strong": {
              "color": "rgba(255, 255, 255, 0.95)"
            },
            ".legal-modal-body em": {
              "color": "rgba(255, 255, 255, 0.5)",
              "font-size": "0.85rem"
            },
            ".legal-table": {
              "width": "100%",
              "border-collapse": "collapse",
              "margin": "0.75rem 0 1rem",
              "font-size": "0.84rem"
            },
            ".legal-table thead th": {
              "background": "rgba(168, 85, 247, 0.12)",
              "color": "#c084fc",
              "font-weight": "600",
              "font-size": "0.75rem",
              "text-transform": "uppercase",
              "letter-spacing": "0.06em",
              "padding": "0.6rem 0.75rem",
              "text-align": "left",
              "border-bottom": "1px solid rgba(168, 85, 247, 0.2)"
            },
            ".legal-table tbody td": {
              "padding": "0.55rem 0.75rem",
              "color": "rgba(255, 255, 255, 0.72)",
              "border-bottom": "1px solid rgba(255, 255, 255, 0.06)",
              "vertical-align": "top"
            },
            ".legal-table tbody tr:last-child td": {
              "border-bottom": "none"
            },
            "@keyframes legalFadeIn": {
              "from": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              },
              "to": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              }
            },
            "@keyframes legalFadeOut": {
              "from": {
                "opacity": "1",
                "transform": "scale(1) translateY(0)"
              },
              "to": {
                "opacity": "0",
                "transform": "scale(0.94) translateY(12px)"
              }
            },
            "@media (max-width: 767px)": {
              ".footer-credits .mbr-text": {
                "font-size": "0.84rem"
              },
              ".footer-legal-links": {
                "gap": "0.25rem"
              },
              ".footer-legal-btn": {
                "font-size": "0.72rem",
                "padding": "0.25rem 0.45rem"
              },
              ".legal-modal": {
                "padding": "0 !important",
                "align-items": "stretch !important"
              },
              ".legal-modal-overlay": {
                "position": "fixed !important",
                "inset": "0 !important"
              },
              ".legal-modal-content": {
                "position": "fixed !important",
                "inset": "0 !important",
                "width": "100vw !important",
                "max-width": "100vw !important",
                "height": "100vh !important",
                "max-height": "100vh !important",
                "margin": "0 !important",
                "border-radius": "0 !important",
                "box-shadow": "none !important",
                "animation": "legalSheetUp 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
              },
              ".legal-modal.closing .legal-modal-content": {
                "animation": "legalSheetDown 0.25s ease forwards"
              },
              ".legal-modal-header": {
                "padding": "1.5rem 1.25rem 1rem",
                "position": "sticky",
                "top": "0",
                "z-index": "10",
                "background": "linear-gradient(155deg, #1e1430 0%, #120d22 60%, #0d0a1c 100%)"
              },
              ".legal-modal-body": {
                "padding": "1rem 1.25rem 2rem",
                "flex": "1",
                "overflow-y": "auto"
              },
              ".legal-modal-title": {
                "font-size": "1.2rem"
              },
              ".legal-table": {
                "font-size": "0.76rem"
              },
              ".legal-table thead th, .legal-table tbody td": {
                "padding": "0.45rem 0.5rem"
              }
            },
            "@keyframes legalSheetUp": {
              "from": {
                "transform": "translateY(100%)"
              },
              "to": {
                "transform": "translateY(0)"
              }
            },
            "@keyframes legalSheetDown": {
              "from": {
                "transform": "translateY(0)"
              },
              "to": {
                "transform": "translateY(100%)"
              }
            }
          },
          "_name": "footer04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\"\n        class=\"footer-modern\"\n        group=\"Footers\"\n        global\n        once=\"footers\"\n        mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#111118\" selected>\n        </fieldset>\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#111118\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n\n        <!-- Séparateur -->\n        <div class=\"footer-divider\"></div>\n\n        <!-- Crédits -->\n        <div class=\"footer-credits\">\n            <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".footer-credits .mbr-text\">\n                Site réalisé par <a href=\"tg://resolve?domain=NitraFox\" class=\"footer-link footer-link-nitra\">Nitra🦊</a>\n                &amp; calendrier alimenté par <a href=\"tg://resolve?domain=Spyro_The_Bat\" class=\"footer-link footer-link-spyro\">Spyro the bat🦇</a>\n            </p>\n        </div>\n\n        <!-- Liens légaux -->\n        <div class=\"footer-legal-links\">\n            <button class=\"footer-legal-btn\" data-legal=\"mentions\">Mentions légales</button>\n            <span class=\"footer-legal-sep\" aria-hidden=\"true\">•</span>\n            <button class=\"footer-legal-btn\" data-legal=\"confidentialite\">Politique de confidentialité</button>\n            <span class=\"footer-legal-sep\" aria-hidden=\"true\">•</span>\n            <button class=\"footer-legal-btn\" data-legal=\"cookies\">Politique de cookies</button>\n        </div>\n\n    </div>\n\n    <!-- Modale légale -->\n    <div class=\"legal-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"legal-modal-title\" aria-hidden=\"true\">\n        <div class=\"legal-modal-overlay\"></div>\n        <div class=\"legal-modal-content\" tabindex=\"-1\">\n            <div class=\"legal-modal-header\">\n                <h3 class=\"legal-modal-title\" id=\"legal-modal-title\"></h3>\n                <button class=\"legal-modal-close\" aria-label=\"Fermer\">×</button>\n            </div>\n            <div class=\"legal-modal-body\"></div>\n        </div>\n    </div>\n\n    [JS_CODE_0]\n</section>\n",
          "_cid": "v4N9BybemT",
          "_anchor": "footer04-1j",
          "_PHPplaceholders": [],
          "_JSplaceholders": [
            "<script>\n    (function() {\n        'use strict';\n\n        // Fix z-index navbar + modal fullscreen mobile : injection globale dans <head>\n        // ⚠️ EXCLUT les modules artistes (.module-artiste) et leurs modales (.artist-modal)\n        // EXCLUT aussi les modales gallery bloc (.artistgallery1) et leurs modales (.ag-modal)\n        (function() {\n            var s = document.createElement('style');\n            s.textContent = ''\n                /* --- z-index global quand modal ouverte --- */\n                + 'body.modal-open{overflow:hidden}'\n                + 'body.modal-open>*:not(.module-artiste):not(.artistgallery1):not(.carousel-fullscreen):not(.pricing-fullscreen){z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste{z-index:0!important;position:relative}'\n                + 'body.modal-open>.artistgallery1{z-index:0!important;position:relative}'\n                + 'body.modal-open>.module-artiste:has(.artist-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>.artistgallery1:has(.ag-modal.show){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.event-modal){z-index:2147483647!important}'\n                + 'body.modal-open>:has(.legal-modal){z-index:2147483647!important}'\n\n                /* --- Fullscreen overlays toujours au-dessus de tout --- */\n                + '.carousel-fullscreen,.pricing-fullscreen{position:fixed!important;z-index:2147483648!important}'\n\n                /* --- Legal modal fullscreen sur mobile --- */\n                + '@media(max-width:767px){'\n                    + '.legal-modal{padding:0!important;align-items:stretch!important}'\n                    + '.legal-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.legal-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:legalSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.legal-modal.closing .legal-modal-content{animation:legalSheetDown .25s ease forwards}'\n                    + '.legal-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.legal-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.legal-modal-title{font-size:1.2rem!important}'\n                + '}'\n\n                /* --- Artist modal (.module-artiste) fullscreen mobile --- */\n                + '@media(max-width:767px){'\n                    + '.artist-modal{padding:0!important;align-items:stretch!important}'\n                    + '.artist-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.artist-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:artistSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.artist-modal.closing .artist-modal-content{animation:artistSheetDown .25s ease forwards}'\n                    + '.artist-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.artist-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.artist-modal-title{font-size:1.3rem!important}'\n                + '}'\n\n                /* --- AG modal (.artistgallery1) fullscreen mobile --- */\n                + '@media(max-width:767px){'\n                    + '.ag-modal{padding:0!important;align-items:stretch!important}'\n                    + '.ag-modal-overlay{position:fixed!important;inset:0!important}'\n                    + '.ag-modal-content{position:fixed!important;inset:0!important;width:100vw!important;max-width:100vw!important;height:100vh!important;max-height:100vh!important;margin:0!important;border-radius:0!important;box-shadow:none!important;animation:agSheetUp .32s cubic-bezier(.25,.46,.45,.94)}'\n                    + '.ag-modal.closing .ag-modal-content{animation:agSheetDown .25s ease forwards}'\n                    + '.ag-modal-header{padding:1.5rem 1.25rem 1rem!important;position:sticky!important;top:0!important;z-index:10;background:linear-gradient(155deg,#1e1430 0%,#120d22 60%,#0d0a1c 100%)}'\n                    + '.ag-modal-body{padding:1rem 1.25rem 2rem!important;flex:1;overflow-y:auto}'\n                    + '.ag-modal-title{font-size:1.3rem!important}'\n                + '}';\n            document.head.appendChild(s);\n        })();\n\n        /* ---------- Année dynamique ---------- */\n        var yearEl = document.querySelector('.footer-modern .footer-year');\n        if (yearEl) yearEl.textContent = new Date().getFullYear();\n\n        /* ---------- Contenus légaux ---------- */\n        var legalContents = {\n            mentions: {\n                title: 'Mentions légales',\n                body: '<h4>Éditeur du site</h4>'\n                    + '<p>Ce site est édité par <strong>La Meute Normande</strong>, groupe informel à but non lucratif, basé en Haute-Normandie.</p>'\n                    + '<p>Responsable de la publication : <strong>Nitra</strong></p>'\n                    + '<p>Contact : via Telegram <a href=\"tg://resolve?domain=NitraFox\" target=\"_blank\" rel=\"noopener\">@NitraFox</a></p>'\n                    + '<h4>Hébergement</h4>'\n                    + '<p>Ce site est hébergé par <strong>GitHub Pages</strong> — GitHub Inc., 88 Colin P. Kelly Jr. Street, San Francisco, CA 94107, États-Unis.</p>'\n                    + '<p>Le nom de domaine <strong>lameutenormande.fr</strong> est enregistré auprès d\\'<strong>OVH</strong> — OVHcloud, 2 rue Kellermann, 59100 Roubaix, France.</p>'\n                    + '<h4>Conception du site</h4>'\n                    + '<p>Site conçu avec <strong>Mobirise</strong> (générateur de sites statiques).</p>'\n                    + '<p>Développement et intégration : <strong>Nitra</strong> — calendrier des événements : <strong>Spyro the bat</strong>.</p>'\n                    + '<h4>Propriété intellectuelle</h4>'\n                    + '<p>L\\'ensemble du contenu de ce site (textes, images, logos, illustrations) est la propriété de La Meute Normande ou de ses contributeurs respectifs (artistes référencés sur la page Artistes). Toute reproduction sans autorisation préalable est interdite.</p>'\n                    + '<p>Les logos et marques de services tiers (Telegram, Discord, Instagram, Google Maps, Waze, Apple Plans, FurAffinity, Furzo) restent la propriété de leurs détenteurs respectifs.</p>'\n                    + '<h4>Responsabilité</h4>'\n                    + '<p>La Meute Normande s\\'efforce de fournir des informations à jour mais ne saurait être tenue responsable d\\'éventuelles erreurs, omissions ou indisponibilités. Les liens externes (sites d\\'événements, réseaux sociaux, cartes) sont fournis à titre indicatif et n\\'engagent pas la responsabilité de La Meute Normande quant à leur contenu.</p>'\n                    + '<h4>Formulaire de contact</h4>'\n                    + '<p>Les données saisies dans le formulaire de contact (nom/pseudo, identifiant ou e-mail, préférence de contact, message et pièce jointe éventuelle) sont transmises via le service <strong>UseBasin</strong> et reçues uniquement par le responsable de la publication. Elles ne sont utilisées que pour répondre à votre demande et ne sont jamais revendues ni partagées avec des tiers.</p>'\n            },\n            confidentialite: {\n                title: 'Politique de confidentialité (RGPD)',\n                body: '<h4>Introduction</h4>'\n                    + '<p>La Meute Normande s\\'engage à protéger la vie privée de ses visiteurs, conformément au <strong>Règlement Général sur la Protection des Données (RGPD — UE 2016/679)</strong> et à la <strong>loi Informatique et Libertés</strong>.</p>'\n                    + '<h4>Responsable du traitement</h4>'\n                    + '<p>Responsable : <strong>Nitra</strong> — Contact : <a href=\"tg://resolve?domain=NitraFox\" target=\"_blank\" rel=\"noopener\">@NitraFox sur Telegram</a></p>'\n                    + '<h4>Données collectées via le formulaire de contact</h4>'\n                    + '<p>Le formulaire de la page Contact collecte les données suivantes :</p>'\n                    + '<ul>'\n                    + '<li><strong>Nom / Prénom / Pseudo</strong> (obligatoire)</li>'\n                    + '<li><strong>Identifiant ou e-mail</strong> (obligatoire)</li>'\n                    + '<li><strong>Préférence de contact</strong> : Discord, Telegram, Twitter/X ou Email (obligatoire)</li>'\n                    + '<li><strong>Message</strong> (obligatoire)</li>'\n                    + '<li><strong>Pièce jointe</strong> (optionnel — formats : jpg, png, gif, webp, pdf, doc, docx, zip, txt)</li>'\n                    + '</ul>'\n                    + '<p>Ces données sont transmises via <strong>UseBasin</strong> (sous-traitant, basé aux États-Unis — <a href=\"https://usebasin.com/privacy\" target=\"_blank\" rel=\"noopener\">politique de confidentialité UseBasin</a>). Le consentement explicite est recueilli avant l\\'envoi via une case à cocher obligatoire.</p>'\n                    + '<p><strong>Base légale :</strong> consentement de l\\'utilisateur (article 6.1.a du RGPD).</p>'\n                    + '<p><strong>Finalité :</strong> répondre à votre demande de contact uniquement.</p>'\n                    + '<p><strong>Durée de conservation :</strong> les données sont conservées le temps nécessaire au traitement de la demande, puis supprimées.</p>'\n                    + '<h4>Données NON collectées</h4>'\n                    + '<p>En dehors du formulaire de contact, ce site <strong>ne collecte aucune donnée personnelle</strong>. Il n\\'y a pas de compte utilisateur, pas de newsletter, pas de base de données, pas de système de commentaires.</p>'\n                    + '<h4>Stockage local (localStorage)</h4>'\n                    + '<p>Le site utilise le <strong>localStorage</strong> de votre navigateur pour :</p>'\n                    + '<ul>'\n                    + '<li>Sauvegarder vos préférences de filtres du calendrier (type d\\'événement, région, département)</li>'\n                    + '<li>Mémoriser si vous avez activé la sauvegarde automatique des filtres</li>'\n                    + '</ul>'\n                    + '<p>Ces données restent <strong>exclusivement sur votre appareil</strong> et ne sont jamais transmises à un serveur. Vous pouvez les supprimer à tout moment via les paramètres de votre navigateur.</p>'\n                    + '<h4>Données de navigation (hébergeur)</h4>'\n                    + '<p><strong>GitHub Pages</strong> peut collecter automatiquement des données techniques de connexion (adresse IP, type de navigateur, pages visitées) conformément à sa propre <a href=\"https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement\" target=\"_blank\" rel=\"noopener\">politique de confidentialité</a>. La Meute Normande n\\'a pas accès à ces données.</p>'\n                    + '<h4>Services tiers</h4>'\n                    + '<p>Le site fait appel aux services tiers suivants, qui peuvent recevoir des données techniques (adresse IP, en-têtes de requête) :</p>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Service</th><th>Usage</th><th>Données potentielles</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td><strong>Google Fonts</strong></td><td>Chargement de la police Inter Tight (toutes les pages)</td><td>Adresse IP, en-tête Referer</td></tr>'\n                    + '<tr><td><strong>cdnjs (Cloudflare)</strong></td><td>Chargement de FullCalendar et ical.js (page Événements)</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>jsDelivr</strong></td><td>Chargement de ical.js (page Actus)</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>UseBasin</strong></td><td>Traitement du formulaire de contact</td><td>Données du formulaire (voir ci-dessus)</td></tr>'\n                    + '<tr><td><strong>GitHub Raw</strong></td><td>Récupération du fichier calendrier ICS</td><td>Adresse IP</td></tr>'\n                    + '<tr><td><strong>api-adresse.data.gouv.fr</strong></td><td>Géocodage pour les filtres du calendrier (page Événements)</td><td>Nom de ville recherché, adresse IP</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Tracking et publicité</h4>'\n                    + '<p>Ce site <strong>n\\'utilise aucun outil de tracking, d\\'analyse ou de publicité</strong> (pas de Google Analytics, pas de Facebook Pixel, pas de Matomo, pas de publicité ciblée).</p>'\n                    + '<h4>Vos droits</h4>'\n                    + '<p>Conformément au RGPD, vous disposez des droits suivants :</p>'\n                    + '<ul>'\n                    + '<li><strong>Droit d\\'accès</strong> — obtenir une copie de vos données</li>'\n                    + '<li><strong>Droit de rectification</strong> — corriger des données inexactes</li>'\n                    + '<li><strong>Droit à l\\'effacement</strong> — demander la suppression de vos données</li>'\n                    + '<li><strong>Droit d\\'opposition</strong> — vous opposer au traitement</li>'\n                    + '<li><strong>Droit à la portabilité</strong> — récupérer vos données dans un format structuré</li>'\n                    + '</ul>'\n                    + '<p>Vous pouvez également introduire une réclamation auprès de la <strong>CNIL</strong> (<a href=\"https://www.cnil.fr\" target=\"_blank\" rel=\"noopener\">www.cnil.fr</a>).</p>'\n                    + '<h4>Mise à jour</h4>'\n                    + '<p>Cette politique peut être modifiée à tout moment. La date de dernière mise à jour est indiquée ci-dessous.</p>'\n                    + '<p><em>Dernière mise à jour : avril 2026</em></p>'\n            },\n            cookies: {\n                title: 'Politique de cookies',\n                body: '<h4>Qu\\'est-ce qu\\'un cookie ?</h4>'\n                    + '<p>Un cookie est un petit fichier texte déposé sur votre appareil lors de la visite d\\'un site web. Il permet de stocker des informations relatives à votre navigation. Le <strong>localStorage</strong> est un mécanisme similaire, propre à votre navigateur, qui stocke des données localement sans les transmettre automatiquement aux serveurs.</p>'\n                    + '<h4>Stockage utilisé par ce site</h4>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Type</th><th>Origine</th><th>Finalité</th><th>Durée</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td>localStorage<br><code>calendarFilterSettings</code></td><td>Ce site (lameutenormande.fr)</td><td>Sauvegarde de vos filtres du calendrier (type, région, département)</td><td>Jusqu\\'à suppression manuelle</td></tr>'\n                    + '<tr><td>localStorage<br><code>calendarFilterSave</code></td><td>Ce site (lameutenormande.fr)</td><td>Mémorise si vous avez activé la sauvegarde des filtres</td><td>Jusqu\\'à suppression manuelle</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Cookies pouvant être déposés par des tiers</h4>'\n                    + '<table class=\"legal-table\">'\n                    + '<thead><tr><th>Service</th><th>Type</th><th>Finalité</th><th>Durée</th></tr></thead>'\n                    + '<tbody>'\n                    + '<tr><td>GitHub Pages</td><td>Cookie technique</td><td>Fonctionnement de l\\'hébergement</td><td>Session</td></tr>'\n                    + '<tr><td>Google Fonts (fonts.googleapis.com)</td><td>Cookie technique</td><td>Chargement de la police Inter Tight</td><td>Variable</td></tr>'\n                    + '<tr><td>Cloudflare CDN (cdnjs.cloudflare.com)</td><td>Cookie technique</td><td>Chargement de FullCalendar et ical.js</td><td>Variable</td></tr>'\n                    + '<tr><td>jsDelivr (cdn.jsdelivr.net)</td><td>Cookie technique</td><td>Chargement de ical.js</td><td>Variable</td></tr>'\n                    + '<tr><td>UseBasin (usebasin.com)</td><td>Cookie technique</td><td>Traitement du formulaire de contact</td><td>Session</td></tr>'\n                    + '</tbody></table>'\n                    + '<h4>Cookies analytiques ou publicitaires</h4>'\n                    + '<p>Ce site <strong>n\\'utilise aucun cookie publicitaire, de tracking ou d\\'analyse</strong> (pas de Google Analytics, pas de Facebook Pixel, pas de Matomo, pas de publicité ciblée).</p>'\n                    + '<h4>Gérer vos cookies</h4>'\n                    + '<p>Vous pouvez à tout moment configurer votre navigateur pour refuser les cookies ou supprimer ceux déjà déposés :</p>'\n                    + '<ul>'\n                    + '<li><strong>Chrome :</strong> Paramètres → Confidentialité et sécurité → Cookies et autres données de site</li>'\n                    + '<li><strong>Firefox :</strong> Paramètres → Vie privée et sécurité → Cookies et données de sites</li>'\n                    + '<li><strong>Safari :</strong> Préférences → Confidentialité → Gérer les données de site web</li>'\n                    + '<li><strong>Edge :</strong> Paramètres → Cookies et autorisations de site</li>'\n                    + '</ul>'\n                    + '<h4>Effacer le localStorage</h4>'\n                    + '<p>Pour supprimer les préférences enregistrées par ce site :</p>'\n                    + '<ul>'\n                    + '<li>Ouvrez les outils développeur de votre navigateur (<strong>F12</strong>)</li>'\n                    + '<li>Allez dans l\\'onglet <strong>Application</strong> (Chrome/Edge) ou <strong>Stockage</strong> (Firefox)</li>'\n                    + '<li>Sélectionnez <strong>localStorage</strong> → <strong>lameutenormande.fr</strong></li>'\n                    + '<li>Supprimez les entrées souhaitées ou cliquez sur « Tout effacer »</li>'\n                    + '</ul>'\n                    + '<p>Vous pouvez aussi effacer les données de navigation de votre navigateur, ce qui supprimera à la fois les cookies et le localStorage.</p>'\n                    + '<p><em>Dernière mise à jour : avril 2026</em></p>'\n            }\n        };\n\n        /* ---------- Modale ---------- */\n        var modal = document.querySelector('.footer-modern .legal-modal');\n        var modalTitle = modal ? modal.querySelector('.legal-modal-title') : null;\n        var modalBody = modal ? modal.querySelector('.legal-modal-body') : null;\n        var modalClose = modal ? modal.querySelector('.legal-modal-close') : null;\n        var modalOverlay = modal ? modal.querySelector('.legal-modal-overlay') : null;\n        var keyHandler = null;\n\n        function openLegal(key) {\n            var data = legalContents[key];\n            if (!data || !modal) return;\n\n            modalTitle.textContent = data.title;\n            modalBody.innerHTML = data.body;\n\n            document.body.classList.add('modal-open');\n            modal.classList.add('show');\n            modal.classList.remove('closing');\n            modal.setAttribute('aria-hidden', 'false');\n\n            if (keyHandler) document.removeEventListener('keydown', keyHandler);\n            keyHandler = function(e) { if (e.key === 'Escape') closeLegal(); };\n            document.addEventListener('keydown', keyHandler);\n\n            setTimeout(function() {\n                if (modalClose) modalClose.focus();\n            }, 50);\n        }\n\n        function closeLegal() {\n            if (!modal || !modal.classList.contains('show')) return;\n\n            modal.classList.add('closing');\n            modal.setAttribute('aria-hidden', 'true');\n            document.body.classList.remove('modal-open');\n\n            setTimeout(function() {\n                modal.classList.remove('show', 'closing');\n            }, 250);\n\n            if (keyHandler) {\n                document.removeEventListener('keydown', keyHandler);\n                keyHandler = null;\n            }\n        }\n\n        if (modalClose) modalClose.addEventListener('click', closeLegal);\n        if (modalOverlay) modalOverlay.addEventListener('click', closeLegal);\n\n        /* ---------- Boutons légaux ---------- */\n        var btns = document.querySelectorAll('.footer-modern .footer-legal-btn');\n        for (var i = 0; i < btns.length; i++) {\n            btns[i].addEventListener('click', function() {\n                openLegal(this.getAttribute('data-legal'));\n            });\n        }\n    })();\n    </script>"
          ],
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    },
    "formulaire.html": {
      "settings": {
        "title": "Formulaire envoyé - La Meute Normande",
        "order": "5",
        "meta_image": "@PROJECT_PATH@/assets/images/logo-2000x837.png"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "@easeOut": "cubic-bezier(0.22, 1, 0.36, 1)",
            "@easeStd": "cubic-bezier(0.4, 0, 0.2, 1)",
            "@durFast": "0.25s",
            "@durMed": "0.4s",
            "@durSlow": "0.55s",
            "@radiusItem": "0.75rem",
            "@radiusMenu": "1rem",
            "@radiusPanel": "1.25rem",
            "@ink": "rgb(27, 31, 10)",
            "z-index": "1000",
            "width": "100%",
            "top": "0",
            "left": "0",
            "right": "0",
            "position": "absolute",
            ".container": {
              "display": "flex",
              "flex-wrap": "nowrap",
              "align-items": "center",
              "justify-content": "flex-end",
              "height": "68px",
              "padding": "0.5rem 1rem",
              "margin-top": "1.2rem",
              "left": "0",
              "right": "0",
              "border-radius": "100vw",
              "background-color": "@menuBgColor",
              "& when not (@collapsed)": {
                "& when (@transparent)": {
                  "background": "fade(@menuBgColor, @opacity * 100) !important"
                }
              },
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "border": "1px solid rgba(255, 255, 255, 0.22)",
              "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.12), 0 4px 24px -4px fade(@ink, 8%), 0 1px 3px fade(@ink, 4%)",
              "transition": "box-shadow @durSlow @easeOut, border-color @durSlow @easeOut, height @durMed @easeOut, margin-top @durMed @easeOut",
              "&:hover": {
                "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.18), 0 8px 40px -8px fade(@ink, 12%), 0 2px 6px fade(@ink, 6%)",
                "border-color": "rgba(255, 255, 255, 0.3)"
              },
              "@media (max-width: 991px)": {
                "padding-right": "2rem"
              },
              "@media (max-width: 767px)": {
                "width": "95%",
                "height": "56px !important",
                "padding-right": "1rem",
                "margin-top": "0.5rem"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".navbar-brand": {
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "0",
              "padding": "10px 0",
              "word-break": "break-word",
              "z-index": "1",
              "img": {
                "max-width": "100%",
                "max-height": "100%",
                "border-radius": "0 !important",
                "transition": "transform @durSlow @easeOut, filter @durSlow @easeOut, height @durMed @easeOut",
                "filter": "drop-shadow(0 2px 4px rgba(0, 0, 0, 0.06))",
                "&:hover": {
                  "transform": "scale(1.06) rotate(-1deg)",
                  "filter": "drop-shadow(0 4px 12px rgba(0, 0, 0, 0.1))"
                }
              },
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none"
              }
            },
            ".navbar-logo": {
              "padding-left": "2rem",
              "margin": "0 !important",
              "@media (max-width: 767px)": {
                "padding-left": "1rem"
              }
            },
            ".navbar-caption": {
              "padding-left": "1rem",
              "padding-right": "0.5rem",
              "font-weight": "600",
              "letter-spacing": "0.02em",
              "& when not (@showLogo)": {
                "@media (min-width: 768px)": {
                  "padding-left": "2rem"
                }
              }
            },
            ".navbar-nav": {
              "margin": "auto",
              "margin-left": "0",
              "flex-wrap": "wrap",
              "& when (@contentAlign = '2')": {
                "margin-left": "auto"
              },
              "& when (@contentAlign = '3')": {
                "margin-left": "auto",
                "margin-right": "0"
              },
              "@media (min-width: 992px)": {
                "padding-left": "1.5rem"
              },
              ".nav-item": {
                "padding": "0 !important",
                ".nav-link": {
                  "padding": "10px 18px !important",
                  "margin": "0 4px !important",
                  "border-radius": "@radiusItem !important",
                  "position": "relative",
                  "font-weight": "500",
                  "letter-spacing": "0.02em",
                  "text-transform": "none",
                  "overflow": "hidden",
                  "transition": "background-color @durFast @easeOut, transform @durFast @easeOut",
                  "&:not(.dropdown-toggle)::after": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "4px",
                    "left": "50%",
                    "width": "0",
                    "height": "2.5px",
                    "border-radius": "2px",
                    "background": "currentColor",
                    "opacity": "0.6",
                    "transform": "translateX(-50%)",
                    "transition": "width @durFast @easeOut"
                  },
                  "&:hover": {
                    "background-color": "fade(@ink, 5%)"
                  },
                  "&:not(.dropdown-toggle):hover::after": {
                    "width": "50%"
                  },
                  "&:active": {
                    "transform": "scale(0.97)"
                  },
                  "& when not (@isRoundedButtons)": {
                    "border-radius": "4px !important"
                  }
                }
              },
              ".open": {
                ".nav-link": {
                  "&::after": {
                    "transform": "rotate(180deg)"
                  },
                  "@media (min-width: 992px)": {
                    "&::before": {
                      "content": "\"\"",
                      "width": "100%",
                      "height": "20px",
                      "top": "100%",
                      "background": "transparent",
                      "position": "absolute"
                    }
                  }
                }
              },
              ".dropdown-item": {
                "padding": "10px 16px !important",
                "border-radius": "0.5rem !important",
                "margin": "2px 8px !important",
                "border-left": "3px solid transparent",
                "transition": "background-color @durFast @easeOut, border-color @durFast @easeOut, padding @durFast @easeOut",
                "&:hover": {
                  "background-color": "fade(@ink, 6%)",
                  "border-left-color": "@hamburgerColor",
                  "padding-left": "20px !important"
                },
                "& when not (@isRoundedButtons)": {
                  "border-radius": "4px !important"
                }
              }
            },
            ".nav-link": {
              "width": "fit-content",
              "position": "relative"
            },
            "a.nav-link": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center"
            },
            ".nav-dropdown": {
              "@media (max-width: 767px)": {
                "padding-bottom": "0.5rem"
              }
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin-right": "1.667em",
              "&::after": {
                "margin-left": "0.5rem",
                "margin-top": "0.2rem",
                "transition": "transform @durFast @easeStd"
              },
              "&[aria-expanded=\"true\"]": {
                "margin-right": "0",
                "padding": "0.667em 1.667em"
              }
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".dropdown-menu": {
              "flex-wrap": "wrap",
              "flex-direction": "column",
              "max-width": "100%",
              "min-width": "auto",
              "padding": "10px 6px !important",
              "border-radius": "@radiusMenu",
              "background": "@menuBgColor",
              "backdrop-filter": "saturate(180%) blur(24px)",
              "-webkit-backdrop-filter": "saturate(180%) blur(24px)",
              "border": "1px solid rgba(255, 255, 255, 0.2)",
              "box-shadow": "inset 0 0 0 1px rgba(255, 255, 255, 0.08), 0 16px 48px -8px rgba(0, 0, 0, 0.1), 0 2px 8px rgba(0, 0, 0, 0.04)",
              "& when (@transparent)": {
                "background": "fade(@menuBgColor, @opacity * 100) !important"
              },
              "& when not (@isRoundedButtons)": {
                "border-radius": "4px !important"
              }
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-right": "0.5rem",
                "vertical-align": "sub"
              }
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar .dropdown > .dropdown-menu": {
              "display": "none",
              "width": "max-content",
              "max-width": "500px !important",
              "top": "~\"calc(100% + 12px)\"",
              "left": "50%",
              "transform": "translateX(-50%) translateY(8px)",
              "animation": "dropdownFadeIn @durFast @easeOut forwards",
              ".dropdown-item": {
                "line-height": "1 !important"
              },
              ".dropdown": {
                ".dropdown-item": {
                  "align-items": "center",
                  "display": "flex",
                  "height": "max-content !important",
                  "min-height": "max-content !important",
                  "&::after": {
                    "display": "inline-block",
                    "position": "static",
                    "margin": "0 0 0 0.5rem",
                    "transition": "transform @durFast @easeStd",
                    "transform": "rotate(-90deg)"
                  }
                }
              },
              ".dropdown.open": {
                ".dropdown-item": {
                  "&::after": {
                    "transform": "rotate(0deg)"
                  }
                }
              }
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "flex"
            },
            ".navbar.navbar-expand-lg .dropdown .dropdown-menu": {
              "background": "@menuBgColor",
              ".dropdown-submenu": {
                "margin": "0",
                "left": "105%",
                "transform": "none",
                "top": "-12px"
              }
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "31px",
              "height": "20px",
              "cursor": "pointer",
              "position": "relative",
              "align-self": "center",
              "margin-left": "12px",
              "margin-right": "8px",
              "order": "1000",
              "@media (max-width: 767px)": {
                "transform": "scale(0.8)"
              },
              "&:hover .hamburger span": {
                "&:nth-child(1)": {
                  "width": "20px"
                },
                "&:nth-child(4)": {
                  "width": "24px"
                }
              },
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "height": "2px",
                "background-color": "@hamburgerColor",
                "border-radius": "4px",
                "&:nth-child(1)": {
                  "top": "0",
                  "width": "26px",
                  "transition": "all @durMed @easeOut"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s @easeOut 0.05s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "width": "24px",
                  "transition": "all 0.3s @easeOut 0.05s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "width": "18px",
                  "transition": "all @durMed @easeOut"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.35s @easeOut"
              },
              "&:nth-child(2)": {
                "width": "24px",
                "transform": "rotate(45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(3)": {
                "width": "24px",
                "transform": "rotate(-45deg)",
                "transition": "all @durMed @easeOut 0.1s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
