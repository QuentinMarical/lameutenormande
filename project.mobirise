                "font-size": "0.9rem !important"
              },
              ".fc .fc-list-event-time": {
                "font-size": "0.85rem !important"
              }
            },
            "@media (max-width: 480px)": {
              ".container-calendar": {
                "padding": "0 0.25rem"
              },
              ".calendar-wrapper": {
                "padding": "0.4rem",
                "border-radius": "10px"
              },
              ".fc .fc-daygrid-day": {
                "min-height": "0",
                "padding": "0.2rem"
              },
              ".fc .fc-event": {
                "font-size": "0.75rem !important",
                "padding": "2px 5px !important"
              },
              ".fc .fc-daygrid-block-event": {
                "min-height": "1.4em !important"
              },
              ".fc .fc-event-title": {
                "font-size": "0.8rem !important"
              },
              ".fc .fc-col-header-cell": {
                "padding": "0.4rem 0.25rem",
                "font-size": "0.65rem"
              },
              ".fc .fc-daygrid-day-number": {
                "font-size": "0.65rem"
              },
              ".fc .fc-list-event .fc-event-title": {
                "font-size": "0.95rem !important"
              },
              ".fc .fc-list-event-time": {
                "font-size": "0.9rem !important"
              },
              "html, body": {
                "overflow-x": "hidden",
                "height": "100%"
              },
              ".calendar-root": {
                "display": "flex",
                "flex-direction": "column",
                "min-height": "100vh"
              },
              ".calendar-root > .container-calendar": {
                "flex": "1 1 auto",
                "display": "flex",
                "flex-direction": "column"
              },
              ".calendar-root .calendar-zone": {
                "flex": "1 1 auto"
              },
              ".calendar-zone, .calendar-wrapper": {
                "min-height": "0"
              },
              ".calendar-header": {
                "gap": "0.25rem",
                "padding": "0.4rem 0.5rem"
              },
              ".calendar-filters-row": {
                "flex-direction": "column",
                "gap": "0.3rem"
              },
              ".calendar-filter-group": {
                "min-width": "100%"
              },
              ".calendar-filter-group-location": {
