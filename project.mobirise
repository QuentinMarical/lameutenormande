              "font-size": "1.4rem",
              "width": "2.5rem",
              "height": "2.5rem",
              "border-radius": "50%",
              "cursor": "pointer",
              "transition": "all 0.25s ease",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "line-height": "1",
              "padding": "0",
              "margin-top": "0.15rem"
            },
            ".artist-modal-close:hover, .artist-modal-close:focus": {
              "background": "rgba(233, 30, 99, 0.25)",
              "border-color": "rgba(233, 30, 99, 0.5)",
              "color": "#fff",
              "transform": "rotate(90deg)"
            },
            ".artist-modal-title": {
              "margin": "0",
              "font-size": "1.5rem",
              "font-weight": "700",
              "line-height": "1.3",
              "background": "linear-gradient(90deg, #ff6eb4, #c471ed, #8b5cf6)",
              "-webkit-background-clip": "text",
              "background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "flex": "1",
              "min-width": "0"
            },
            ".artist-modal-body": {
              "padding": "1.5rem 2rem 2rem",
              "color": "#fff",
              "flex": "1"
            },
            ".artist-modal-grid": {
              "display": "grid",
