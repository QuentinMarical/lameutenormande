              "top": "1.5rem",
              "right": "1.5rem",
              "background": "rgba(255, 255, 255, 0.2)",
              "border": "none",
              "color": "white",
              "font-size": "2.5rem",
              "width": "3.5rem",
              "height": "3.5rem",
              "border-radius": "50%",
              "cursor": "pointer",
              "transition": "all 0.3s",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center"
            },
            ".carousel-fullscreen-close:hover": {
              "background": "rgba(255, 110, 180, 0.6)",
              "transform": "rotate(90deg) scale(1.1)"
            },
            "@keyframes artistSheetUp": {
              "from": {
                "transform": "translateY(100%)"
              },
              "to": {
                "transform": "translateY(0)"
              }
            },
            "@keyframes artistSheetDown": {
              "from": {
                "transform": "translateY(0)"
              },
              "to": {
                "transform": "translateY(100%)"
              }
            },
            "SPAN": {
