              "gap": "1.5rem"
            },
            "@media (min-width: 900px)": {
              ".artist-modal-grid": {
                "grid-template-columns": "1fr 1fr"
              }
            },
            ".artist-modal-left, .artist-modal-right": {
              "display": "flex",
              "flex-direction": "column",
              "gap": "1rem"
            },
            ".artist-info-row": {
              "display": "flex",
              "align-items": "flex-start",
              "gap": "1rem",
              "padding": "1.25rem",
              "background": "rgba(255, 255, 255, 0.05)",
              "border-radius": "12px",
              "border": "1px solid rgba(255, 255, 255, 0.08)",
              "transition": "all 0.3s ease"
            },
            ".artist-info-row:hover": {
              "background": "rgba(255, 255, 255, 0.08)",
              "border-color": "rgba(255, 110, 180, 0.3)"
            },
            ".artist-info-icon": {
              "font-size": "1.5rem",
              "min-width": "35px",
              "flex-shrink": "0"
            },
            ".artist-info-content": {
              "flex": "1",
              "min-width": "0"
            },
            ".artist-info-label": {
