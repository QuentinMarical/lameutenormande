 fill=\"#ffffff\" d=\"m 12.937649,5.689685 c -0.11625,-0.68661 -0.388914,-1.33016 -0.810638,-1.91282 -0.476314,-0.65811 -1.127922,-1.20761 -1.884324,-1.58903 -0.7645339,-0.38552 -1.6178829,-0.58938 -2.4678369,-0.58938 -0.239783,0 -0.481475,0.0163 -0.71843,0.0482 -0.992367,0.13407 -1.968118,0.54689 -2.747572,1.16243 -0.878239,0.69354 -1.444993,1.58521 -1.638884,2.57878 -0.05777,0.29537 -0.08238,0.62212 -0.106209,0.93806 -0.03734,0.49456 -0.07594,1.00595 -0.233207,1.34013 -0.107482,0.2284 -0.267856,0.3805 -0.701389,0.3805 -0.238581,0 -0.456585,0.13492 -0.563077,0.34847 -0.10642098,0.21355 -0.08294,0.46889 0.0606,0.65931 0.653164,0.8665 1.505522,1.39133 2.402923,1.70755 -0.04087,0.12346 -0.06385,0.25491 -0.06385,0.39209 0,0.68902 0.558551,1.24757 1.247566,1.24757 0.671972,0 1.218291,-0.53161 1.244949,-1.19701 0.292534,0.0159 1.685483,0.0197 1.840836,0.0153 0.03444,0.65825 0.577502,1.18166 1.244243,1.18166 0.688943,0 1.2474949,-0.55848 1.2474949,-1.24757 0,-0.15705 -0.03026,-0.30674 -0.08316,-0.44513 0.489183,-0.23794 0.95093,-0.55904 1.353845,-0.94576 0.561875,-0.53918 0.974265,-1.1753 1.192764,-1.83964 0.245865,-0.7477 0.307667,-1.4993 0.183355,-2.23378 m -8.2243299,5.876 c -0.227338,0 -0.411684,-0.18421 -0.411684,-0.41169 0,-0.22733 0.184346,-0.41168 0.411684,-0.41168 0.227408,0 0.411683,0.18435 0.411683,0.41168 0,0.22748 -0.184275,0.41169 -0.411683,0.41169 m 4.330028,0 c -0.227409,0 -0.411754,-0.18421 -0.411754,-0.41169 0,-0.22733 0.184345,-0.41168 0.411754,-0.41168 0.227408,0 0.411683,0.18435 0.411683,0.41168 7.1e-5,0.22748 -0.184275,0.41169 -0.411683,0.41169 m 3.1132919,-3.83873 c -0.360276,1.09533 -1.309862,1.9998 -2.3218169,2.46289 -0.215458,-0.17706 -0.490951,-0.28327 -0.791405,-0.28327 -0.484233,0 -0.903058,0.2762 -1.109748,0.67933 -0.210438,0.009 -1.777338,0.003 -2.120219,-0.0202 -0.210155,-0.39223 -0.623818,-0.65917 -1.100061,-0.65917 -0.316788,0 -0.605221,0.11894 -0.825134,0.31354 -0.852358,-0.27543 -1.65734,-0.74608 -2.259025,-1.54449 1.779176,0 1.428092,-1.98827 1.658259,-3.16731 0.350659,-1.79693 2.12835,-3.00518 3.853148,-3.23817 0.212135,-0.0286 0.42427,-0.0426 0.634213,-0.0426 2.8347599,7e-5 5.3581049,2.53098 4.3817889,5.49938 m -4.4056189,0.87435 c -1.023692,0 -1.945914,-0.67119 -2.115056,-1.54978 -0.03281,-0.17056 0.07891,-0.33553 0.249471,-0.36834 0.170627,-0.0329 0.335527,0.0789 0.368337,0.24947 0.09942,0.51648 0.717865,1.06039 1.542221,1.03882 0.858722,-0.0225 1.4259,-0.53599 1.542433,-1.03154 0.03981,-0.16907 0.209378,-0.27379 0.378308,-0.23419 0.169213,0.0398 0.274007,0.20916 0.234197,0.37823 -0.09518,0.40454 -0.35568,0.77932 -0.733634,1.05545 -0.393652,0.28779 -0.879511,0.44718 -1.404757,0.46104 -0.02051,6.3e-4 -0.04108,8.4e-4 -0.06152,8.4e-4 m 2.037132,-3.23958 c 0,0.33369 -0.270542,0.60423 -0.604231,0.60423 -0.333617,0 -0.60416,-0.27054 -0.60416,-0.60423 0,-0.33369 0.270543,-0.60409 0.60416,-0.60409 0.333689,0 0.604231,0.27033 0.604231,0.60409 m -2.822597,0 c 0,0.33369 -0.270472,0.60423 -0.60416,0.60423 -0.333618,0 -0.60416,-0.27054 -0.60416,-0.60423 0,-0.33369 0.270542,-0.60409 0.60416,-0.60409 0.333688,0 0.60416,0.27033 0.60416,0.60409\"/></svg><span class=\"location-btn-label\">Waze</span></a>\n                        <a href=\"https://maps.apple.com/?q=${loc}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"location-btn location-apple\"><svg viewBox=\"0 0 30 30\" class=\"location-btn-logo\" xmlns=\"http://www.w3.org/2000/svg\"><path fill=\"#ffffff\" d=\"M 9 4 C 8.657 4 8.323 4.0355625 8 4.1015625 L 8 13.275391 C 7.646263 13.401511 7.3068564 13.555772 7 13.761719 L 7 4.421875 C 5.755 4.966875 4.7873594 6.0089688 4.3183594 7.2929688 L 6 8.4707031 L 6 14.611328 L 4 13.210938 L 4 21 C 4 23.049 5.236 24.806125 7 25.578125 L 7 21.238281 C 7.7157567 21.718662 8.5752393 22 9.5 22 C 10.424761 22 11.284243 21.718662 12 21.238281 L 12 26 L 21 26 C 21.369 26 21.726266 25.954906 22.072266 25.878906 L 13.361328 19.773438 C 13.757438 19.103628 14 18.332818 14 17.5 C 14 16.439688 13.615994 15.47704 13 14.707031 L 13 13.376953 L 25.794922 22.345703 C 25.915922 21.914703 26 21.469 26 21 L 26 15.974609 C 19.497 15.716609 14.283391 10.503 14.025391 4 L 12 4 L 12 13.761719 C 11.693144 13.555772 11.353737 13.401511 11 13.275391 L 11 4 L 9 4 z M 18.025391 4 C 18.275391 8.294 21.706 11.723609 26 11.974609 L 26 9 C 26 6.239 23.761 4 21 4 L 18.025391 4 z M 9.5 14 C 10.480989 14 11.364517 14.406452 12 15.056641 C 12.15425 15.214391 12.293344 15.385984 12.416016 15.570312 C 12.538687 15.754641 12.644031 15.951641 12.730469 16.158203 C 12.816906 16.364766 12.884141 16.580234 12.929688 16.804688 C 12.975072 17.029622 13 17.261689 13 17.5 C 13 17.738 12.975234 17.970859 12.929688 18.195312 C 12.884141 18.419766 12.816906 18.635234 12.730469 18.841797 C 12.644031 19.048359 12.538687 19.245359 12.416016 19.429688 C 12.293344 19.614016 12.15425 19.785609 12 19.943359 C 11.364517 20.593548 10.480989 21 9.5 21 C 8.5195528 21 7.6354091 20.59487 7 19.945312 C 6.9818906 19.926763 6.9688744 19.903706 6.9511719 19.884766 C 6.8180905 19.742375 6.6922542 19.592499 6.5839844 19.429688 C 6.4613125 19.245219 6.3559687 19.048422 6.2695312 18.841797 C 6.1830938 18.635172 6.1158594 18.419781 6.0703125 18.195312 C 6.0247656 17.970844 6 17.738 6 17.5 C 6 17.261689 6.0249282 17.029622 6.0703125 16.804688 C 6.1158594 16.580234 6.1830938 16.364766 6.2695312 16.158203 C 6.3559687 15.951641 6.4613125 15.754641 6.5839844 15.570312 C 6.7066562 15.385984 6.84575 15.214391 7 15.056641 C 7.6354827 14.406452 8.519011 14 9.5 14 z M 9.5253906 15.216797 C 9.4297656 15.216297 9.333875 15.271359 9.296875 15.380859 L 8.0136719 19.181641 C 7.9286719 19.436641 8.2455938 19.631453 8.4335938 19.439453 L 9.5273438 18.320312 L 10.5625 19.414062 C 10.7475 19.609063 11.070328 19.418109 10.986328 19.162109 L 9.7519531 15.382812 C 9.7164531 15.273312 9.6210156 15.217297 9.5253906 15.216797 z\"/></svg><span class=\"location-btn-label\">Apple Plans</span></a>\n                    </div></div></div>`;\n            }\n\n            html += '</div><div class=\"event-modal-right\">';\n\n            if (event.description) {\n                html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">📝</span><div class=\"event-info-content\"><div class=\"event-info-label\">Description</div><div class=\"event-info-text\">${linkify(event.description)}</div></div></div>`;\n            }\n\n            if (event.url) {\n                try {\n                    const u = new URL(event.url);\n                    if (u.protocol.indexOf('http') === 0) {\n                        html += `<div class=\"event-info-row\"><span class=\"event-info-icon\">🔗</span><div class=\"event-info-content\"><div class=\"event-info-label\">Site officiel</div><a href=\"${escapeHtml(event.url)}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"event-url-button\">Visiter le site</a></div></div>`;\n                    }\n                } catch (e) {}\n            }\n\n            html += '</div></div>';\n            corps.innerHTML = html;\n\n            document.body.classList.add('modal-open');\n            modal.classList.add('show');\n            modal.classList.remove('closing');\n            modal.setAttribute('aria-hidden', 'false');\n\n            const closeBtn = modal.querySelector('.event-modal-close');\n            const overlay = modal.querySelector('.event-modal-overlay');\n\n            if (closeBtn) closeBtn.onclick = fermerPopup;\n            if (overlay) overlay.onclick = fermerPopup;\n\n            if (currentKeyHandler) {\n                document.removeEventListener('keydown', currentKeyHandler);\n            }\n\n            currentKeyHandler = e => {\n                if (e.key === 'Escape') fermerPopup();\n            };\n            document.addEventListener('keydown', currentKeyHandler);\n\n            setTimeout(() => {\n                if (closeBtn) {\n                    closeBtn.focus();\n                } else {\n                    modalContent.focus();\n                }\n            }, 20);\n        }\n\n        function fermerPopup() {\n            const modal = document.querySelector('.event-modal');\n            if (!modal || !modal.classList.contains('show')) return;\n\n            modal.classList.add('closing');\n            modal.setAttribute('aria-hidden', 'true');\n            document.body.classList.remove('modal-open');\n\n            setTimeout(() => {\n                modal.classList.remove('show', 'closing');\n            }, 250);\n\n            if (currentKeyHandler) {\n                document.removeEventListener('keydown', currentKeyHandler);\n                currentKeyHandler = null;\n            }\n\n            if (lastFocusedElement) {\n                lastFocusedElement.focus();\n                lastFocusedElement = null;\n            }\n        }\n\n        document.addEventListener('DOMContentLoaded', async () => {\n            const grid = document.getElementById('events-grid');\n            if (!grid) return;\n\n            try {\n                afficherChargement(grid);\n                conventions = await chargerConventions();\n                genererTuiles(grid);\n            } catch (e) {\n                console.error('❌', e);\n                afficherMessage(grid, 'Erreur de chargement des événements. Réessayez plus tard.', true);\n            }\n        });\n    })();\n    </script>"
          ],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden",
            "position": "relative",
            "border-radius": "20px 20px 0 0",
            "margin-top": "-20px",
            ".mbr-overlay": {
              "position": "absolute",
              "inset": "0",
              "pointer-events": "none"
            },
            ".footer-divider": {
              "width": "100%",
              "height": "1px",
              "background": "linear-gradient(90deg, transparent, #38bdf8, #f97316, #a855f7, transparent)",
              "margin-bottom": "0.85rem"
            },
            ".container": {
              "position": "relative",
              "z-index": "2",
              "text-align": "center"
            },
            ".footer-credits": {
              "margin-bottom": "0.5rem"
            },
            ".footer-credits .mbr-text": {
              "color": "rgba(255, 255, 255, 0.65)",
