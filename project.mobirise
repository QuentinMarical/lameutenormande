        {
          "alias": false,
          "_styles": {
            "display": "flex",
            "position": "relative",
            "min-height": "100vh",
            "overflow": "hidden",
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "background-size": "cover",
              "background-position": "center center",
              "background-repeat": "no-repeat",
              "background-attachment": "fixed",
              ".mbr-overlay": {
                "background-color": "@overlayColor",
                "opacity": "@overlayOpacity",
                "position": "absolute",
                "inset": "0",
                "pointer-events": "none"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "inset": "0",
              "& when (@bg-type = \"video\")": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".container, .container-fluid": {
              "position": "relative",
              "z-index": "2",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "center",
              "min-height": "100vh",
              "width": "100%"
            },
            ".row": {
              "width": "100%",
              "justify-content": "center",
              "display": "flex",
              "flex-wrap": "wrap",
              "margin": "0"
            },
            ".content-wrap": {
              "width": "100%",
              "max-width": "1400px",
              "margin": "0 auto",
              "padding": "2rem 1rem",
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-text, .mbr-section-btn, .telegram-note": {
              "text-align": "center"
            },
            ".telegram-note": {
              "opacity": "0.92",
              "max-width": "820px",
              "margin-left": "auto",
              "margin-right": "auto"
            },
            ".telegram-icon": {
              "display": "inline-flex",
              "align-items": "center",
              "justify-content": "center",
              "margin-right": "8px"
            },
            ".btn-primary .socicon-telegram": {
              "color": "#fff",
              "fill": "#fff"
            },
            ".mb-2": {
              "margin-bottom": "0.5rem"
            },
            ".mb-3": {
              "margin-bottom": "1rem"
            },
            ".mb-4": {
              "margin-bottom": "1.25rem"
            },
            ".mt-4": {
              "margin-top": "1.25rem"
            },
            ".btn-primary": {
              "background": "linear-gradient(135deg, #0088cc 0%, #00aced 100%)",
              "border": "none",
              "border-radius": "25px",
              "box-shadow": "0 4px 15px rgba(0, 136, 204, 0.4)",
              "font-weight": "600",
              "padding": "12px 30px",
              "transition": "all 0.3s ease"
            },
            ".btn-primary:hover, .btn-primary:focus": {
              "background": "linear-gradient(135deg, #00aced 0%, #0088cc 100%)",
              "box-shadow": "0 6px 20px rgba(0, 136, 204, 0.6)",
              "transform": "translateY(-2px)"
            },
            ".events-grid": {
              "display": "grid",
              "grid-template-columns": "repeat(3, minmax(0, 1fr))",
              "gap": "1rem",
              "padding": "1rem 0 0",
              "width": "100%",
              "margin": "0 auto",
              "justify-items": "stretch"
            },
            ".events-loading, .events-message": {
              "grid-column": "(1 / -1)",
              "width": "100%",
              "margin": "0 auto",
              "justify-self": "stretch",
              "align-self": "center",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "padding": "1.25rem 1.5rem",
              "text-align": "center",
              "color": "rgba(255, 255, 255, 0.78)"
            },
            ".events-loading": {
              "flex-direction": "column",
              "min-height": "140px"
            },
            ".events-loading .loading-spinner": {
              "width": "48px",
              "height": "48px",
              "border": "3px solid rgba(255, 255, 255, 0.15)",
              "border-top-color": "#E91E63",
              "border-radius": "50%",
              "animation": "events-spin 0.8s linear infinite",
              "margin-bottom": "1rem"
            },
            ".events-message": {
              "flex-direction": "row",
              "gap": "0.75rem",
              "min-height": "72px",
              "border-radius": "12px"
            },
            ".events-message.error": {
              "color": "#ff8b8b",
              "background": "rgba(255, 107, 107, 0.12)",
              "border": "1px solid rgba(255, 107, 107, 0.25)"
            },
            ".events-message.info": {
              "max-width": "none",
              "margin": "0.5rem 0",
              "padding": "1.25rem 1.5rem",
              "display": "flex",
              "flex-direction": "column",
              "align-items": "center",
              "justify-content": "center",
              "color": "rgba(255, 255, 255, 0.72)",
              "background": "rgba(255, 255, 255, 0.06)",
              "border-radius": "12px"
            },
            ".events-message p, .events-loading p": {
              "margin": "0",
              "width": "100%",
              "text-align": "center"
            },
            ".events-message span": {
              "font-size": "1.5rem",
              "flex-shrink": "0"
            },
            ".events-message.info span": {
              "margin-bottom": "0.5rem"
            },
            ".event-tile": {
              "display": "flex",
              "align-items": "stretch",
              "min-height": "130px",
              "border-radius": "16px",
              "overflow": "hidden",
              "background": "linear-gradient(135deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.04))",
              "border": "1px solid rgba(255, 255, 255, 0.14)",
              "box-shadow": "0 4px 20px rgba(0, 0, 0, 0.28)",
              "cursor": "pointer",
              "transition": "all 0.3s ease",
              "-webkit-backdrop-filter": "blur(10px)",
              "backdrop-filter": "blur(10px)"
            },
            ".event-tile:hover": {
              "transform": "translateY(-4px)",
              "box-shadow": "0 8px 30px rgba(233, 30, 99, 0.25)",
              "border-color": "rgba(233, 30, 99, 0.35)"
            },
            ".event-tile:hover .event-tile-arrow": {
              "color": "#E91E63",
              "transform": "translateX(3px)"
            },
            ".event-tile:focus": {
              "outline": "none",
              "box-shadow": "0 8px 30px rgba(233, 30, 99, 0.25), 0 0 0 3px rgba(233, 30, 99, 0.45)"
            },
            ".event-tile:focus-visible": {
              "outline": "2px solid #E91E63",
              "outline-offset": "2px"
            },
            ".event-tile-date": {
              "display": "flex",
              "flex-direction": "column",
              "align-items": "center",
              "justify-content": "center",
              "min-width": "78px",
              "padding": "0.9rem",
              "background": "linear-gradient(180deg, #e91e63 0%, #9c27b0 100%)",
              "color": "#fff"
            },
            ".event-tile-day": {
              "font-size": "1.9rem",
              "font-weight": "800",
              "line-height": "1"
            },
            ".event-tile-month": {
              "font-size": "0.8rem",
              "font-weight": "600",
              "text-transform": "uppercase",
              "letter-spacing": "0.05em",
              "margin-top": "0.25rem",
              "opacity": "0.9"
            },
            ".event-tile-content": {
              "flex": "1",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "center",
              "padding": "0.85rem 1rem",
              "min-width": "0"
            },
            ".event-tile-title": {
              "font-size": "0.95rem",
              "font-weight": "700",
              "color": "#fff",
              "margin": "0 0 0.45rem 0",
              "line-height": "1.3",
              "overflow": "hidden",
              "text-overflow": "ellipsis",
              "display": "-webkit-box",
              "-webkit-line-clamp": "2",
              "-webkit-box-orient": "vertical"
            },
            ".event-tile-location": {
              "display": "flex",
              "align-items": "flex-start",
              "gap": "0.4rem",
              "font-size": "0.84rem",
              "color": "rgba(255, 255, 255, 0.68)",
              "margin": "0 0 0.45rem 0",
              "line-height": "1.3"
            },
            ".event-tile-location span": {
              "flex-shrink": "0"
            },
            ".event-tile-countdown": {
              "font-size": "0.78rem",
              "font-weight": "700",
              "color": "#66d17a",
              "margin": "0",
              "text-transform": "uppercase",
              "letter-spacing": "0.03em"
            },
            ".event-tile-arrow": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "min-width": "38px",
              "padding": "0 0.65rem",
              "color": "rgba(255, 255, 255, 0.45)",
              "font-size": "1rem",
              "transition": "all 0.3s ease"
            },
            ".event-modal": {
              "display": "none !important",
              "position": "fixed !important",
              "z-index": "2147483647 !important",
              "inset": "0 !important",
              "width": "100vw !important",
              "height": "100vh !important",
              "align-items": "center",
              "justify-content": "center",
              "padding": "1.25rem",
              "box-sizing": "border-box"
            },
            ".event-modal.show": {
              "display": "flex !important"
            },
            ".event-modal.closing .event-modal-content": {
              "animation": "modalFadeOut 0.25s ease forwards"
            },
            ".event-modal-overlay": {
              "position": "fixed !important",
              "inset": "0 !important",
              "background": "rgba(10, 5, 20, 0.92) !important",
              "-webkit-backdrop-filter": "blur(12px) !important",
              "backdrop-filter": "blur(12px) !important",
              "z-index": "0 !important",
              "cursor": "pointer"
            },
            ".event-modal-content": {
              "position": "relative",
              "z-index": "1",
              "width": "100%",
              "max-width": "860px",
              "max-height": "calc(100vh - 2.5rem)",
              "border-radius": "20px !important",
              "margin": "0 auto",
              "padding": "0",
              "background": "linear-gradient(155deg, #1e1430 0%, #120d22 60%, #0d0a1c 100%)",
              "border": "1px solid rgba(255, 110, 180, 0.18)",
              "box-shadow": "0 0 0 1px rgba(255, 255, 255, 0.06), 0 24px 60px rgba(0, 0, 0, 0.7), 0 0 80px rgba(196, 113, 237, 0.12)",
              "overflow-y": "auto",
              "overflow-x": "hidden",
              "-webkit-overflow-scrolling": "touch",
              "display": "flex",
              "flex-direction": "column",
              "animation": "modalFadeIn 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
              "scrollbar-width": "thin",
              "scrollbar-color": "rgba(255, 110, 180, 0.45) transparent"
            },
            ".event-modal-content::-webkit-scrollbar": {
              "width": "6px"
            },
            ".event-modal-content::-webkit-scrollbar-track": {
              "background": "transparent"
            },
            ".event-modal-content::-webkit-scrollbar-thumb": {
              "background": "rgba(255, 110, 180, 0.45)",
              "border-radius": "3px"
            },
            ".event-modal-content::-webkit-scrollbar-thumb:hover": {
              "background": "rgba(255, 110, 180, 0.7)"
            },
            ".event-modal-header": {
              "display": "flex",
              "align-items": "flex-start",
              "justify-content": "space-between",
              "padding": "1.75rem 2rem 1.25rem",
              "border-bottom": "1px solid rgba(255, 255, 255, 0.1)",
              "background": "linear-gradient(90deg, rgba(233, 30, 99, 0.08), rgba(196, 113, 237, 0.06), transparent)",
              "gap": "1rem"
            },
            ".event-modal-title": {
              "margin": "0",
              "font-size": "1.5rem",
              "font-weight": "700",
              "line-height": "1.3",
              "background": "linear-gradient(90deg, #ff6eb4, #c471ed, #8b5cf6)",
              "-webkit-background-clip": "text",
              "background-clip": "text",
              "-webkit-text-fill-color": "transparent",
              "flex": "1",
              "min-width": "0"
            },
            ".event-modal-close": {
              "flex-shrink": "0",
              "background": "rgba(255, 255, 255, 0.1)",
              "border": "1px solid rgba(255, 255, 255, 0.15)",
              "color": "rgba(255, 255, 255, 0.85)",
              "font-size": "1.4rem",
              "width": "2.5rem",
              "height": "2.5rem",
              "border-radius": "50%",
              "cursor": "pointer",
              "transition": "all 0.25s ease",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "line-height": "1",
              "padding": "0",
              "margin-top": "0.15rem"
            },
            ".event-modal-close:hover, .event-modal-close:focus": {
              "background": "rgba(233, 30, 99, 0.25)",
              "border-color": "rgba(233, 30, 99, 0.5)",
              "color": "#fff",
              "transform": "rotate(90deg)"
            },
            ".event-modal-body": {
              "padding": "1.5rem 2rem 2rem",
              "color": "#fff",
              "flex": "1"
            },
            ".event-modal-body-grid": {
              "display": "grid",
              "grid-template-columns": "1fr",
              "gap": "0.75rem"
            },
            ".event-modal-left, .event-modal-right": {
              "display": "flex",
              "flex-direction": "column",
              "gap": "0.75rem"
            },
            ".event-info-row": {
              "display": "flex",
              "align-items": "flex-start",
              "gap": "0.9rem",
              "padding": "1rem 1.25rem",
              "background": "rgba(255, 255, 255, 0.04)",
              "border": "1px solid rgba(255, 255, 255, 0.07)",
              "border-radius": "12px",
              "transition": "background 0.2s ease"
            },
            ".event-info-row:hover": {
              "background": "rgba(255, 255, 255, 0.07)"
            },
            ".event-info-icon": {
              "font-size": "1.35rem",
              "min-width": "28px",
              "flex-shrink": "0",
              "margin-top": "0.1rem"
            },
            ".event-info-content": {
              "flex": "1",
              "min-width": "0"
            },
            ".event-info-label": {
              "font-size": "0.73rem",
              "letter-spacing": "0.1em",
              "text-transform": "uppercase",
              "font-weight": "700",
              "color": "rgba(255, 110, 180, 0.85)",
              "margin-bottom": "0.35rem"
            },
            ".event-info-text": {
              "font-size": "1rem",
              "line-height": "1.55",
              "font-weight": "500",
              "word-break": "break-word",
              "color": "rgba(255, 255, 255, 0.92)"
            },
            ".event-info-text a": {
              "color": "#ff6eb4",
              "text-decoration": "underline",
              "transition": "color 0.2s"
            },
            ".event-info-text a:hover": {
              "color": "#c471ed"
            },
            ".event-location-buttons": {
              "display": "flex",
              "flex-wrap": "wrap",
              "gap": "0.6rem",
              "margin-top": "0.85rem",
              "padding-top": "0.85rem",
              "border-top": "1px solid rgba(255, 255, 255, 0.1)"
            },
            ".location-btn": {
